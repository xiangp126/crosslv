{
  "log": {
    "level": "info"
  },
  // ========================
  // DNS Configuration
  // ========================
  "dns": {
    "servers": [
      // China domains: Alibaba public DoH, direct
      {
        "type": "https",
        "tag": "dns-local",
        "server": "223.5.5.5",
        "strategy": "ipv4_only"
      },
      // NVIDIA intranet DNS: via corporate VPN outbound
      {
        "type": "udp",
        "tag": "nvidia-dns",
        "server": "10.19.185.31",
        "detour": "nvidia-vpn",
        "strategy": "ipv4_only"
      }
    ],
    "independent_cache": true,
    "rules": [
      {
        "rule_set": "nvidia-internal",
        "server": "nvidia-dns"
      },
      {
        "rule_set": "geosite-cn",
        "server": "dns-local"
      }
    ],
    // Unmatched domains default to corporate VPN DNS
    "final": "nvidia-dns"
  },
  // ========================
  // Inbound Configuration
  // ========================
  "inbounds": [
    // HTTP/SOCKS5 mixed proxy for manual configuration
    {
      "type": "mixed",
      "tag": "mixed-in",
      "listen": "127.0.0.1",
      "listen_port": 2080
    },
    // TUN transparent proxy, captures all system traffic
    // gvisor stack: all packets handled in userspace (avoids mixed stack crash on macOS)
    {
      "type": "tun",
      "tag": "tun-in",
      "interface_name": "utun10",
      "address": [
        "172.19.0.1/30"
      ],
      "auto_route": true,
      "strict_route": true,
      "mtu": 1280,
      "stack": "gvisor",
      // Exclude WireGuard server IP from TUN capture to prevent routing loops.
      "route_exclude_address": [
        "10.228.132.0/24"
      ]
    }
  ],
  // ========================
  // Endpoint Configuration (sing-box 1.11+)
  // ========================
  "endpoints": [
    // Main proxy: WireGuard tunnel to remote VPS
    {
      "type": "wireguard",
      "tag": "proxy",
      "address": [
        "10.66.66.2/32"
      ],
      "private_key": "WG_PRIVATE_KEY",
      "peers": [
        {
          "address": "10.228.132.85",
          "port": 51820,
          "public_key": "WG_PUBLIC_KEY",
          "pre_shared_key": "WG_PRESHARED_KEY",
          "allowed_ips": [
            "0.0.0.0/0"
          ],
          "persistent_keepalive_interval": 25
        }
      ],
      "mtu": 1280
    }
  ],
  // ========================
  // Outbound Configuration
  // ========================
  "outbounds": [
    // Direct: use default network interface
    {
      "type": "direct",
      "tag": "direct-local"
    },
    // NVIDIA corporate VPN: bind to utun4 (GlobalProtect tunnel interface)
    {
      "type": "direct",
      "tag": "nvidia-vpn",
      "bind_interface": "utun4"
    }
  ],
  // ========================
  // Route Configuration
  // ========================
  "route": {
    "auto_detect_interface": true,
    "default_domain_resolver": "nvidia-dns",
    // ---------- Rule Set Definitions ----------
    "rule_set": [
      {
        "tag": "geosite-google",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-google.srs",
        "download_detour": "proxy",
        "update_interval": "7d"
      },
      {
        "tag": "geosite-cn",
        "type": "remote",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-cn.srs",
        "download_detour": "proxy",
        "update_interval": "7d"
      },
      // NVIDIA internal domain matching rules
      {
        "tag": "nvidia-internal",
        "type": "inline",
        "rules": [
          {
            "domain_keyword": [
              "nvidia",
              "mellanox"
            ]
          },
          {
            "domain_suffix": [
              "nvda.com",
              "atlassian.net",
              "atlassian.com"
            ]
          }
        ]
      },
      // NVIDIA intranet IP ranges
      {
        "tag": "nvidia-subnets",
        "type": "inline",
        "rules": [
          {
            "ip_cidr": [
              "10.19.172.0/22",
              "10.19.176.0/24",
              "10.19.177.0/24",
              "10.19.240.0/22",
              "10.19.244.0/24",
              "10.19.245.0/24",
              "10.19.248.0/22",
              "10.18.128.0/21",
              "10.19.160.0/21",
              "10.19.216.0/23",
              "10.19.210.0/23",
              "172.29.224.0/20",
              "172.29.240.0/21",
              "172.29.248.0/21",
              "10.228.132.0/24",
              "10.19.184.0/21"
            ]
          }
        ]
      }
    ],
    // ---------- Routing Rules (matched top-down by priority) ----------
    "rules": [
      // Protocol sniffing: detect HTTP/TLS/QUIC traffic
      {
        "action": "sniff",
        "sniffer": [
          "http",
          "tls",
          "quic"
        ],
        "timeout": "100ms"
      },
      // DNS hijack: intercept all DNS queries for sing-box to handle
      {
        "protocol": "dns",
        "action": "hijack-dns"
      },
      // Loop prevention: Alibaba DNS IPs must go direct before any proxy rules
      {
        "ip_cidr": ["223.5.5.5/32", "223.6.6.6/32"],
        "action": "route",
        "outbound": "direct-local"
      },
      // --- NVIDIA intranet traffic (domains + IPs) -> corporate VPN ---
      {
        "rule_set": ["nvidia-internal", "nvidia-subnets"],
        "action": "route",
        "outbound": "nvidia-vpn"
      },
      // --- NTP (port 123) -> direct for lower latency ---
      {
        "port": 123,
        "action": "route",
        "outbound": "direct-local"
      },
      // --- Google -> proxy (before geosite-cn to avoid misclassification) ---
      {
        "rule_set": "geosite-google",
        "action": "route",
        "outbound": "proxy"
      },
      // --- AI Services (Claude/ChatGPT) -> proxy ---
      {
        "domain_suffix": [
          "anthropic.com",
          "claude.ai",
          "workos.com",
          "claudeusercontent.com",
          "intercom.io",
          "intercomcdn.com",
          "sentry.io",
          "statsigapi.net",
          "stripe.com",
          "openai.com",
          "chatgpt.com",
          "oaistatic.com",
          "oaiusercontent.com",
          "auth0.com"
        ],
        "action": "route",
        "outbound": "proxy"
      },
      // --- China traffic -> direct (domain + IP based) ---
      {
        "rule_set": "geosite-cn",
        "action": "route",
        "outbound": "direct-local"
      },
      // --- Private IPs -> direct (LAN, Docker, etc.) ---
      {
        "ip_is_private": true,
        "action": "route",
        "outbound": "direct-local"
      },
      // --- Fallback: all remaining traffic -> proxy ---
      {
        "action": "route",
        "outbound": "proxy"
      }
    ]
  },
  // ========================
  // Experimental: Clash API for debugging and monitoring
  // Access dashboard at http://127.0.0.1:9090/ui via Yacd or Metacubexd
  // ========================
  "experimental": {
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "metacubexd",
      "external_ui_download_url": "https://github.com/MetaCubeX/metacubexd/archive/refs/heads/gh-pages.zip",
      "external_ui_download_detour": "proxy"
    }
  }
}
