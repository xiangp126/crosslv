#!/usr/bin/env bash
# WireGuard wrapper: enhanced showconf with full server + client summary

CYAN='\033[36m'
RED='\033[31m'
BOLD='\033[1m'
GREEN='\033[32m'
BLUE='\033[34m'
GREY='\033[90m'
RESET='\033[0m'

# Extract value after first '=' in a config line, preserving '=' in base64 values
_wg_val() {
    echo "$1" | awk "/^$2/"'{sub(/^[^=]*=[[:space:]]*/, ""); print}'
}

showFullConfig() {
    local iface="${1:-wg0}"
    local confFile="/etc/wireguard/${iface}.conf"

    if ! sudo test -f "$confFile"; then
        echo -e "${RED}Error: Config not found: ${confFile}${RESET}"
        return 1
    fi

    local confContent
    confContent=$(sudo cat "$confFile")

    local serverPrivKey=$(_wg_val "$confContent" "PrivateKey")
    local serverPubKey=$(echo "$serverPrivKey" | wg pubkey 2>/dev/null)
    local serverAddr=$(_wg_val "$confContent" "Address")
    local port=$(_wg_val "$confContent" "ListenPort")
    local netIf=$(echo "$confContent" | awk '/PostUp/{match($0, /-o ([^ ]+)/, a); print a[1]}')
    [[ -z "$netIf" ]] && netIf=$(ip route show default 2>/dev/null | awk '{print $5}' | head -1)

    local ip
    ip=$(hostname -I 2>/dev/null | awk '{print $1}')

    echo
    echo -e "====================================================="
    echo -e "${CYAN}▸${RESET} ${BOLD}WireGuard Server${RESET}"
    echo -e "====================================================="
    echo -e "  ${GREY}Endpoint:${RESET}        ${ip}:${port}"
    echo -e "  ${GREY}Server Address:${RESET}  $serverAddr"
    echo -e "  ${GREY}Server PubKey:${RESET}   $serverPubKey"
    echo -e "  ${GREY}Interface:${RESET}       $netIf"
    echo -e "====================================================="

    local clientDir="/etc/wireguard/clients"
    local clientFiles
    clientFiles=$(sudo find "$clientDir" -maxdepth 1 -name '*.conf' 2>/dev/null)
    for clientConf in $clientFiles; do
        local clientName=$(basename "$clientConf" .conf)
        local clientContent=$(sudo cat "$clientConf")

        local clientAddr=$(_wg_val "$clientContent" "Address")
        local clientDns=$(_wg_val "$clientContent" "DNS")
        local clientAllowed=$(echo "$clientContent" | awk '/^\[Peer\]/,0' | awk '/^AllowedIPs/{sub(/^[^=]*=[[:space:]]*/, ""); print}')

        echo -e "${CYAN}▸${RESET} ${BOLD}Client: ${CYAN}$clientName${RESET}"
        echo -e "====================================================="
        echo -e "  ${GREY}Address:${RESET}         $clientAddr"
        echo -e "  ${GREY}DNS:${RESET}             $clientDns"
        echo -e "  ${GREY}AllowedIPs:${RESET}      $clientAllowed"
        echo -e "  ${GREY}Config file:${RESET}     $clientConf"
        echo -e "====================================================="
        echo -e "  ${GREY}Client config:${RESET}"
        echo
        echo -e "${BLUE}${clientContent}${RESET}"
        echo
        echo -e "====================================================="
    done
    echo
}

if [[ "$1" == "showconf" ]]; then
    showFullConfig "$2"
else
    sudo wg "$@"
fi
