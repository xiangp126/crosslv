#!/usr/bin/env bash
# shellcheck disable=SC2034,SC2155,SC2168
#
# ja — Auto-approve confirmation prompts for Claude Code and Codex CLI
#
# Monitors a tmux pane and sends the affirmative option whenever a known
# permission prompt is detected.
#
# Usage:
#   ja                        # auto-detect the pane running claude/codex
#   ja -t main:0.1            # explicit tmux target (session:window.pane)

SCRIPT_NAME=$(basename "$0")

# Options
fTmuxTarget=      # tmux target pane in session[:window[.pane]] format
fList=            # list detected AI panes and exit
fApproveDelay=0   # seconds to wait before approving
fPollInterval=0.3 # seconds to poll for new prompts
fAiName=          # AI running in the target pane (claude|codex|...)
fApprovedCount=0  # number of prompts approved
fLockFile=        # populated AFTER fTmuxTarget is finalised; see main flow
fVerbose=         # debug logging to stderr
fAiFilter=        # "claude", "codex", or empty (any); set by --claude/--codex
fDaemon=          # 1 = stay alive across AI restarts (--daemon/-D)
fStartedTs=       # unix seconds when mainLoop started (for --status uptime)
fHost=            # where ja itself started: "<sess:win.pane>" if launched
                  # inside tmux, "<tty>" if outside tmux but attached to a
                  # terminal, empty string if fully detached (no ctty).
                  # Computed once at mainLoop start by _resolveHostLocation
                  # and frozen — does not track tty changes after launch.
fTargetPaneId=    # tmux pane_id (eg. "%47") of fTmuxTarget at startup.
                  # Frozen anchor for detecting silent target hijack:
                  # if move-window/rename-session causes another pane to
                  # take over fTmuxTarget's string, mainLoop notices the
                  # pane_id mismatch and exits cleanly instead of
                  # blindly monitoring the wrong pane.
fPaused=          # 1 while daemon is paused (no AI in pane); empty otherwise
fStop=            # 1 = --stop:     stop the daemon for the resolved target
fStatus=          # 1 = --status:   show daemon status (single or all)
fLog=             # 1 = --log:      tail -F the daemon's log file
fLogFull=         # 1 = --log-full: print full log then tail -F it

# =============================================================================
# AI CATALOG — single source of truth for which AIs ja recognises
# =============================================================================
#
# To add support for a new AI tool, append ONE line below:
#
#   "<canonical_name>;<cmd_regex>;<node_pattern>"
#
#   canonical_name  Name shown in output and used by --ai <name>.
#                   Lowercase, alphanumeric, no spaces.
#
#   cmd_regex       Bash extended regex matched against tmux's
#                   pane_current_command. Anchor with `^`. Use `([-.]|$)`
#                   to accept arch-suffixed (e.g. codex-aarch64-a) or
#                   .exe variants.
#
#   node_pattern    If this AI is sometimes distributed as a node script
#                   (so pane_current_command shows "node" instead of the
#                   AI's name), put a pgrep -f pattern here that matches
#                   one of its child process argvs. Empty = no node
#                   fallback. Used only for codex today.
#
# Delimiter is `;` (NOT `|`) because `|` is a regex alternation operator
# and would collide with patterns like `([-.]|$)`.
#
# All detection / filtering / error messages flow through this list via
# _classifyAi / _isKnownAi / _aiNamesPretty — no other place in the script
# hardcodes "claude" or "codex".
fAiCatalog=(
    "claude;^claude([-.]|$);"
    "codex;^codex([-.]|$);codex"
)

# Colors
RED='\033[31m'
GREEN='\033[32m'
MAGENTA='\033[35m'
CYAN='\033[36m'
LIGHTYELLOW='\033[93m'
LIGHTMAGENTA='\033[95m'
GREY='\033[90m'
BLUE='\033[34m'
RESET='\033[0m'

usage() {
    cat << _EOF
Usage: $SCRIPT_NAME [-t session[:window[.pane]]] [OPTIONS]

Auto-approve confirmation prompts for Claude Code and Codex CLI running in a
tmux pane. Monitors the pane screen and sends the affirmative option when a
known permission prompt is detected.

Options:
    -h, --help       Show this help message
    -t, --target TARGET
                     Tmux target pane in session[:window[.pane]] format
                     (default: auto-detect the pane running claude or codex)
    -w, --wait SEC   Wait before approving (default: 0, approve immediately)
    -l, --list       List detected AI panes and exit
    -v, --verbose    Print debug info to stderr (detector matches, send-keys
                     events, screen change outcomes)
    -D, --daemon     Stay alive across AI restarts. When the AI in the target
                     pane exits, $SCRIPT_NAME pauses prompt detection (so it won't spam
                     keys at the bare shell) and waits for an AI to come back
                     in the same pane, then resumes monitoring automatically.
                     Only the pane disappearing or Ctrl+C will stop it.
    --claude         Restrict detection/listing to panes running Claude Code
    --codex          Restrict detection/listing to panes running Codex CLI
                     (--claude and --codex are mutually exclusive)

Daemon control (operate on already-running daemons):
    -S, --stop       Stop the daemon monitoring the target pane (default: the
                     current pane; pass -t to stop a specific one). Cleans
                     up stale lockfiles automatically.
    -s, --status     Show all running daemons (summary row + detail block
                     each). Inside tmux, the daemon for the current pane is
                     marked with '*' in the index column.
    -L, --log        Tail -F the daemon's log file (default: current pane;
                     pass -t for a specific one). Ctrl+C to exit.
    --log-full       Like --log, but print the full log first, then follow.
                     Useful for catching up on a long-running daemon.

Supports:
    Claude Code      Numbered options (1. Yes / 2. No) — sends the number
    Codex CLI        Numbered options (1. Yes, proceed) — sends the number

Examples:
    $SCRIPT_NAME                   # auto-detect, approve immediately
    $SCRIPT_NAME -t main:0.1       # target specific pane
    $SCRIPT_NAME -w 3              # wait 3s before each approval (Ctrl+C to abort)
    $SCRIPT_NAME -D                # daemon mode: survive claude restarts
    $SCRIPT_NAME -s                # see what daemons are running
    $SCRIPT_NAME -L                # follow current pane's daemon log
    $SCRIPT_NAME -S                # stop the daemon for the current pane


Stop:
    Press Ctrl+C, run $SCRIPT_NAME -S, or: pkill -f '$SCRIPT_NAME'

_EOF
    exit 0
}

parseOptions() {
    local GETOPT_BIN="getopt"
    if command -v /opt/homebrew/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/opt/homebrew/opt/gnu-getopt/bin/getopt"
    elif command -v /usr/local/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/usr/local/opt/gnu-getopt/bin/getopt"
    fi

    local SHORTOPTS="ht:w:lvDsSL"
    local LONGOPTS="help,target:,wait:,list,verbose,daemon,claude,codex,stop,status,log,log-full"

    local PARSED
    if ! PARSED=$("$GETOPT_BIN" --options="$SHORTOPTS" --longoptions="$LONGOPTS" --name "$SCRIPT_NAME" -- "$@"); then
        echo -e "${RED}Failed to parse arguments.${RESET}" >&2
        echo -e "${CYAN}Tip: On macOS, install GNU getopt: ${GREY}brew install gnu-getopt${RESET}" >&2
        exit 1
    fi

    eval set -- "$PARSED"

    while true; do
        case "$1" in
            -h|--help)
                usage
                ;;
            -t|--target)
                fTmuxTarget="$2"
                shift 2
                ;;
            -w|--wait)
                fApproveDelay="$2"
                shift 2
                ;;
            -l|--list)
                fList=1
                shift
                ;;
            -v|--verbose)
                fVerbose=1
                shift
                ;;
            -D|--daemon)
                fDaemon=1
                shift
                ;;
            -S|--stop)
                fStop=1
                shift
                ;;
            -s|--status)
                fStatus=1
                shift
                ;;
            -L|--log)
                fLog=1
                shift
                ;;
            --log-full)
                fLogFull=1
                shift
                ;;
            --claude|--codex)
                # Mutually exclusive — refuse if the other was already set.
                # The catalog still drives detection internally, but these
                # two flags stay hardcoded for now (one explicit flag per
                # AI). Add a new --foo case here when registering a new AI
                # in fAiCatalog.
                local _newFilter="${1#--}"
                if [ -n "$fAiFilter" ] && [ "$fAiFilter" != "$_newFilter" ]; then
                    echo -e "${RED}Error: --claude and --codex are mutually exclusive${RESET}" >&2
                    exit 1
                fi
                fAiFilter="$_newFilter"
                shift
                ;;
            --)
                shift
                break
                ;;
            *)
                echo -e "${RED}Error: Unknown option: $1${RESET}" >&2
                echo "Use $SCRIPT_NAME -h for help." >&2
                exit 1
                ;;
        esac
    done
}

# Path helpers — single source of truth for ja's runtime files.
# All three derive paths from _runtimeDir + a sanitised target name (the
# rule is `${target//[:.]/-}` — replace `:` and `.` with `-`), so the
# layout stays consistent across lockfile acquisition, --stop, --log,
# --status, and any wrapper that redirects logs.
#
# Eg:  target=M:6.1 → ~/.local/ja/M-6-1.lock
#                   → ~/.local/ja/M-6-1.log
#                   → ~/.local/ja/M-6-1.state.json
#
# Why ~/.local/ja and not /tmp:
#   - macOS's periodic /tmp cleanup (and tmpwatch on some Linux distros)
#     reaps files whose mtime is older than ~3 days. The lockfile is
#     written once at daemon startup and never re-touched, so a
#     long-paused daemon's lockfile got silently reaped — leaving
#     --stop unable to find it while --status (state file, rewritten
#     on every event) still showed it running.
#   - $HOME storage is per-user, persistent, and not subject to any
#     systemwide reaper.
#
# Every site that needs one of these paths must call these helpers —
# never duplicate the path-build expression. Otherwise a future change
# to the directory or sanitisation rule would silently desync.
# Per-user runtime directory holding the lockfile, log file, and state
# JSON for every daemon. mkdir -p is a no-op if the directory already
# exists, so calling it on every path lookup is cheap (one stat).
# Doing it here rather than in writers means even a fresh install can
# `ja -D` without an explicit init step. Failures (rare: $HOME
# readonly, quota) silently fall through; the subsequent open/write
# will surface the real error.
_runtimeDir() {
    local d="${HOME}/.local/${SCRIPT_NAME}"
    mkdir -p "$d" 2>/dev/null
    echo "$d"
}
_lockFilePath()  { echo "$(_runtimeDir)/${1//[:.]/-}.lock"; }
_logFilePath()   { echo "$(_runtimeDir)/${1//[:.]/-}.log"; }
_stateFilePath() { echo "$(_runtimeDir)/${1//[:.]/-}.state.json"; }

# Write a state snapshot for --status to read. Called from mainLoop on
# every notable event (start, approve, paused, resumed, dropped).
#
# Schema:
#   {
#     "pid":              <int>,
#     "target":           "<session:window.pane>",
#     "ai":               "<claude|codex|...>",
#     "ai_filter":        "<claude|codex|>",     # empty if no --claude/--codex
#     "daemon":           <0|1>,
#     "started_ts":       <unix seconds>,
#     "approved_count":   <int>,
#     "paused":           <true|false>,
#     "last_event_ts":    <unix seconds>,
#     "last_event_type":  "<start|approve|paused|resumed|dropped>",
#     "log_file":         "<runtime_dir>/<sanitized>.log",
#     "host":             "<sess:win.pane>" | "<tty>" | "",  # see fHost
#     "target_pane_id":   "<%N>"                              # see fTargetPaneId
#   }
#
# Written via mv-from-tmp for atomic replacement; readers see either the
# old snapshot or the new one, never half-written content.
#
# Globals consumed: fTmuxTarget, fAiName, fAiFilter, fDaemon,
#                   fStartedTs (set in mainLoop start), fApprovedCount,
#                   fPaused (toggled by mainLoop paused/resumed handling),
#                   fHost (frozen at mainLoop start by _resolveHostLocation),
#                   fTargetPaneId (frozen at mainLoop start).
#
# Arg 1 is the event type that triggered this write (one of the strings
# listed in the schema). It updates last_event_type/ts but doesn't
# otherwise gate the write.
_writeState() {
    local event="$1"
    [ -n "$fTmuxTarget" ] || return 0   # nothing to write before resolveTarget
    local sf=$(_stateFilePath "$fTmuxTarget")
    local lf=$(_logFilePath "$fTmuxTarget")
    local now=$(date +%s)
    local paused_str="false"
    [ -n "$fPaused" ] && paused_str="true"
    local daemon_int=0
    [ -n "$fDaemon" ] && daemon_int=1
    # Use a tmpfile + mv for atomic replacement. Suffix with $$ so two ja
    # processes can't collide on the same tmpname (paranoia — they'd be
    # blocked by the lockfile check anyway).
    local tmp="${sf}.tmp.$$"
    printf '{\n  "pid": %d,\n  "target": "%s",\n  "ai": "%s",\n  "ai_filter": "%s",\n  "daemon": %d,\n  "started_ts": %s,\n  "approved_count": %d,\n  "paused": %s,\n  "last_event_ts": %d,\n  "last_event_type": "%s",\n  "log_file": "%s",\n  "host": "%s",\n  "target_pane_id": "%s"\n}\n' \
        "$$" \
        "$fTmuxTarget" \
        "${fAiName//\"/\\\"}" \
        "${fAiFilter//\"/\\\"}" \
        "$daemon_int" \
        "${fStartedTs:-$now}" \
        "${fApprovedCount:-0}" \
        "$paused_str" \
        "$now" \
        "$event" \
        "$lf" \
        "${fHost//\"/\\\"}" \
        "${fTargetPaneId//\"/\\\"}" \
        > "$tmp" 2>/dev/null \
        && mv -f "$tmp" "$sf" 2>/dev/null
    rm -f "$tmp" 2>/dev/null
    return 0   # never let state-write failure kill ja
}

# Validate a tmux target exists
validateTarget() {
    local target="$1"
    if ! tmux has-session -t "${target%%.*}" 2>/dev/null && \
       ! tmux has-session -t "${target%%:*}" 2>/dev/null; then
        echo -e "${RED}Error: tmux target '$target' not found${RESET}" >&2
        exit 1
    fi
}

# Return the pid of a live monitor process currently watching `target`,
# or empty (with non-zero exit) if no live monitor exists.
#
# Tries two sources, in order:
#   1. Lockfile — fast path, written once at daemon startup with $$.
#   2. State file's "pid" field — defensive fallback. The state file
#      is rewritten on every event by _writeState, the lockfile is
#      written exactly once. If something deletes the lockfile out
#      from under a running daemon (manual `rm`, accidental cleanup
#      script, etc.), the state file still has the truth — falling
#      back here keeps --stop / --status / --list / acquireLockfile
#      honest instead of silently treating the daemon as gone.
_monitorPid() {
    local target="$1"
    local lockfile=$(_lockFilePath "$target")
    local statefile=$(_stateFilePath "$target")
    local pid=""
    if [ -f "$lockfile" ]; then
        pid=$(cat "$lockfile" 2>/dev/null)
    fi
    if [ -z "$pid" ] && [ -f "$statefile" ]; then
        pid=$(_readStateField "$statefile" pid)
    fi
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    echo "$pid"
}

# Return the tty name of a pid (e.g. "pts/4"), or empty (with non-zero
# exit) if the pid has no controlling tty or doesn't exist. The "?"
# value in ps output means "no controlling tty" (daemons, detached
# processes); we treat that as no tty.
_ttyOfPid() {
    local pid="$1"
    [ -n "$pid" ] || return 1
    local tty
    tty=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d '[:space:]')
    [ -n "$tty" ] && [ "$tty" != "?" ] || return 1
    printf '%s' "$tty"
}

# Return the tmux target (session:window.pane) that a pid is running in,
# or empty if the pid isn't attached to a tmux pane (e.g. a plain shell
# without tmux, or the pid has died). Works by matching the pid's tty
# against tmux's pane_tty list.
_paneOfPid() {
    local pid="$1"
    local tty
    tty=$(_ttyOfPid "$pid") || return 1
    tmux list-panes -a -F '#{pane_tty} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null \
        | awk -v t="/dev/$tty" '$1==t{print $2; exit}'
}

# Determine where THIS ja process was launched from. Returns:
#   • "<sess:win.pane>" — launched inside tmux and its tty maps to a pane
#   • "<tty>"           — launched outside tmux but attached to a terminal
#   • ""                — fully detached (no controlling tty)
#
# Called once at mainLoop start; the result is frozen into $fHost and
# written to the state file. We deliberately do NOT re-check at each
# event — host as recorded means "where ja was started", not "where it's
# attached right now". Runtime tty migration / re-parenting is rare and
# tracking it would bloat the schema for no real value.
_resolveHostLocation() {
    # Try pane mapping first (only meaningful inside tmux).
    if [ -n "$TMUX" ]; then
        local pane
        pane=$(_paneOfPid $$)
        if [ -n "$pane" ]; then
            printf '%s' "$pane"
            return 0
        fi
    fi
    # Fallback: bare tty (terminal outside tmux, or tmux pane lookup failed).
    local tty
    tty=$(_ttyOfPid $$)
    if [ -n "$tty" ]; then
        printf '%s' "$tty"
        return 0
    fi
    # Truly detached — no ctty. Return empty (caller will treat as "daemon").
    return 1
}

# Build a horizontal rule of N `─` characters. printf's %s precision
# works on bytes (not characters) and `─` is multibyte UTF-8, so we
# build the rule by repeated concatenation instead.
_hr() {
    local n="$1" out=""
    while [ "$n" -gt 0 ]; do out+="─"; n=$((n - 1)); done
    printf '%s' "$out"
}

# Render the standard "AI sessions" table given a list of "pid|target|name"
# lines as positional args. Used by both the `-l` listing block and
# autoDetectTarget's multi-session picker so the two stay visually in sync.
#
# Output: header row, separator row, then one row per pane with a Status
# column reflecting whether a monitor process is already watching that target.
#
# Usage: _renderAiTable "${panes[@]}"
_renderAiTable() {
    local panes=("$@")
    local pid t c
    local tool_width=4    # min "Tool"
    local target_width=6  # min "Target"
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t c <<<"$p"
        [ ${#c} -gt "$tool_width" ] && tool_width=${#c}
        [ ${#t} -gt "$target_width" ] && target_width=${#t}
    done

    local _gap_str=""
    printf "${_gap_str}${GREY}%-3s %-${tool_width}s  %-${target_width}s  %s${RESET}\n" \
        "#" "Tool" "Target" "Status"
    printf "${_gap_str}${GREY}%s %s  %s  %s${RESET}\n" \
        "$(_hr 3)" "$(_hr "$tool_width")" "$(_hr "$target_width")" "$(_hr 22)"

    local i=1 mon_pid mon_pane mon_tty mon_loc status p
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t c <<<"$p"
        mon_pid=$(_monitorPid "$t")
        if [ -n "$mon_pid" ]; then
            # Two-tier location lookup:
            #   1. Try to map the monitor pid to a tmux target (best case;
            #      user can jump there with `tmux switch -t <addr>`).
            #   2. Fall back to the bare tty if the monitor is running
            #      outside tmux (still useful — tells the user which
            #      terminal owns the process).
            #   3. If neither resolves (detached / nohup'd), suppress the
            #      suffix entirely via ${var:+text}.
            mon_pane=$(_paneOfPid "$mon_pid")
            if [ -n "$mon_pane" ]; then
                mon_loc=", from $mon_pane"
            else
                mon_tty=$(_ttyOfPid "$mon_pid")
                mon_loc="${mon_tty:+, on tty $mon_tty}"
            fi
            status="${LIGHTYELLOW}●${RESET} ${SCRIPT_NAME} monitoring ${GREY}(pid $mon_pid$mon_loc)${RESET}"
        else
            status="${GREEN}○${RESET} idle"
        fi
        # %b on the status field: $status contains dynamic ANSI escapes
        # built via "${COLOR}..." which produce LITERAL backslash bytes
        # at variable expansion time. printf only re-interprets backslash
        # escapes in arguments under %b (not %s).
        printf "${_gap_str}${CYAN}%-3d${RESET} %-${tool_width}s  ${BLUE}%-${target_width}s${RESET}  %b\n" \
            "$i" "$c" "$t" "$status"
        i=$((i + 1))
    done
}

# Catalog accessors — every AI-detection / filtering / error path goes
# through these so adding a new AI only touches fAiCatalog.

# Classify a (cmd, pane_pid) pair against the catalog.
# Prints the canonical name on match, nothing on miss; returns 0/1 to match.
_classifyAi() {
    local cmd="$1" pane_pid="$2"
    local entry name regex node_pat
    # Direct match: cmd's name pattern
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name regex node_pat <<<"$entry"
        if [[ "$cmd" =~ $regex ]]; then
            echo "$name"
            return 0
        fi
    done
    # Indirect match: cmd is "node", but a child process matches an AI's
    # node_pattern (e.g. codex shipped as node script).
    if [ "$cmd" = "node" ]; then
        for entry in "${fAiCatalog[@]}"; do
            IFS=';' read -r name regex node_pat <<<"$entry"
            [ -z "$node_pat" ] && continue
            if pgrep -P "$pane_pid" -f "$node_pat" >/dev/null 2>&1; then
                echo "$name"
                return 0
            fi
        done
    fi
    return 1
}

# True if `name` is one of the canonical names in the catalog.
_isKnownAi() {
    local target="$1"
    local entry name rest
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name rest <<<"$entry"
        [ "$name" = "$target" ] && return 0
    done
    return 1
}

# Render the catalog's canonical names as a natural-language list:
#   1 entry  → "claude"
#   2 entries → "claude or codex"
#   3+       → "claude, codex, or gemini"
# Used in error messages to keep them in sync with the catalog.
_aiNamesPretty() {
    local entry name rest
    local names=()
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name rest <<<"$entry"
        names+=("$name")
    done
    local n=${#names[@]}
    case "$n" in
        0) echo "(no AIs configured)" ;;
        1) echo "${names[0]}" ;;
        2) echo "${names[0]} or ${names[1]}" ;;
        *)
            local out="${names[0]}" i
            for ((i = 1; i < n - 1; i++)); do
                out="$out, ${names[i]}"
            done
            echo "$out, or ${names[n - 1]}"
            ;;
    esac
}

# Identify the AI running in a single, already-known tmux target.
# Returns the canonical AI name on match, the raw cmd otherwise (so the
# fallback path in autoDetectTarget's banner can still display something
# useful for non-AI panes the user manually targeted).
detectAiNameForTarget() {
    local target="$1"
    local info cmd pane_pid matched
    info=$(tmux display-message -t "$target" -p '#{pane_current_command}|#{pane_pid}' 2>/dev/null)
    [ -z "$info" ] && return
    cmd="${info%%|*}"
    pane_pid="${info##*|}"
    matched=$(_classifyAi "$cmd" "$pane_pid")
    if [ -n "$matched" ]; then
        echo "$matched"
    else
        echo "$cmd"
    fi
}

# Scan all tmux panes and emit one "<pid>|<target>|<canonical>" line per AI pane.
# See the design block above for the full algorithm and gotchas.
findAiPanes() {
    local panes=()
    local pane_pid pane_target cmd matchedAi
    while IFS='|' read -r pane_pid pane_target cmd; do
        [ -z "$pane_pid" ] && continue
        matchedAi=$(_classifyAi "$cmd" "$pane_pid")
        [ -z "$matchedAi" ] && continue
        # Filter by --claude/--codex if set (else keep all matched panes).
        if [ -z "$fAiFilter" ] || [ "$fAiFilter" = "$matchedAi" ]; then
            panes+=("$pane_pid|$pane_target|$matchedAi")
        fi
    done < <(tmux list-panes -a -F '#{pane_pid}|#{session_name}:#{window_index}.#{pane_index}|#{pane_current_command}' 2>/dev/null)
    printf '%s\n' "${panes[@]}"
}

# Auto-detect or prompt user to pick a target pane
autoDetectTarget() {
    local panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && panes+=("$line")
    done < <(findAiPanes)

    local count=${#panes[@]}

    if [ "$count" -eq 0 ]; then
        if [ -n "$fAiFilter" ]; then
            echo -e "${RED}Error: No pane running ${fAiFilter} found${RESET}" >&2
        else
            echo -e "${RED}Error: No pane running $(_aiNamesPretty) found${RESET}" >&2
        fi
        echo -e "${GREY}Start an AI tool in a tmux pane first, or use -t to specify a target.${RESET}" >&2
        echo -e "${GREY}If the tool runs inside another process (e.g. bash), use -t to specify the pane manually.${RESET}" >&2
        exit 1
    elif [ "$count" -eq 1 ]; then
        local pane_pid target cmd
        IFS='|' read -r pane_pid target cmd <<<"${panes[0]}"
        echo -e "${GREEN}Auto-detected:${RESET} ${CYAN}$cmd${RESET} at ${BLUE}$target${RESET}"
        echo -e "${GREY}\nIf a session is missing, use -t to specify it manually.${RESET}"
        fTmuxTarget="$target"
        fAiName="$cmd"
    else
        # echo ""
        # echo -e "${LIGHTYELLOW}Multiple AI sessions found ($count)${RESET}"
        echo ""
        _renderAiTable "${panes[@]}"
        echo ""
        echo -e "${GREY}(If a session is missing, use -t to specify it manually.)${RESET}"
        echo ""
        local _pid
        while true; do
            read -rp "Select target (1-$count): " choice || { echo ""; exit 0; }
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$count" ]; then
                IFS='|' read -r _pid fTmuxTarget fAiName <<<"${panes[$((choice - 1))]}"
                # echo -e "${GREEN}Selected:${RESET} ${BLUE}$fTmuxTarget${RESET}"
                break
            fi
            echo -e "${RED}Invalid choice. Enter a number between 1 and $count.${RESET}"
        done
    fi
}

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }

# Single source of truth for log timestamp prefix. Full date because
# long-running daemons cross day boundaries (bare HH:MM:SS would be
# ambiguous in `ja --log-full`). _log / _dbg / _dbgBlock all route
# through here, so one timestamp() change updates every log surface.
# Body is echo -e'd verbatim — callers can embed ${COLOR} freely.
_log() {
    echo -e "${GREY}[$(timestamp)]${RESET} $*"
}

# Portable hash: Linux has md5sum; macOS has `md5 -r` (GNU-like output).
if command -v md5sum &>/dev/null; then
    _hash() { md5sum | cut -c1-12; }
else
    _hash() { md5 -r | cut -c1-12; }
fi

# Debug logging — only emits when -v/--verbose was passed. Output goes to
# stderr so it doesn't get tangled with the script's normal stdout (the
# approval log lines, banner, etc.).
_dbg() {
    [ -n "$fVerbose" ] || return 0
    echo -e "${GREY}[$(timestamp)] [DBG]${RESET} $*" >&2
}

# Multi-line dbg: dump a labelled block of content with `│ ` prefix so it's
# visually distinct from normal log lines. Read content from stdin so the
# caller can pipe / heredoc / `<<<` it.
_dbgBlock() {
    [ -n "$fVerbose" ] || return 0
    local label="$1"
    echo -e "${GREY}[$(timestamp)] [DBG]${RESET} $label" >&2
    while IFS= read -r _line; do
        echo "    │ $_line" >&2
    done
}

# Wait (silently) before approving so Ctrl+C still has a window to abort.
applyApproveDelay() {
    if [ "$fApproveDelay" != "0" ]; then
        sleep "$fApproveDelay"
    fi
}

# Poll the pane until its hash differs from oldFp, or maxWaitMs elapses.
# Prints the resulting hash (new on change, old on timeout) to stdout.
# Returns 0 on change, 1 on timeout.
#
# Using a poll instead of a fixed sleep matters because:
#   - Fast render (<200ms): don't waste the rest of a 1s sleep.
#   - Slow render (>1s): don't prematurely declare the keystroke lost
#     and re-send — double-pressing a number key in Claude Code can
#     jump to a different option and approve the wrong thing.
waitForScreenChange() {
    local oldFp="$1"
    local maxWaitMs="${2:-2000}"
    local intervalMs=100
    local elapsedMs=0
    local post postTail fp
    while [ "$elapsedMs" -lt "$maxWaitMs" ]; do
        # Must mirror the loop-start fingerprint computation:
        # capture -> variable (strips trailing blanks) -> echo | tail | hash.
        # A direct pipeline leaves trailing blank lines in and produces a
        # different hash, breaking the compare.
        post=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
        postTail=$(echo "$post" | tail -20)
        fp=$(echo "$postTail" | _hash)
        if [ "$fp" != "$oldFp" ]; then
            printf '%s' "$fp"
            return 0
        fi
        sleep 0.1
        elapsedMs=$((elapsedMs + intervalMs))
    done
    printf '%s' "$oldFp"
    return 1
}

# Detect a permission prompt in the captured pane tail and return which
# option number to press. Empty output + non-zero exit means "no prompt".
#
# The detector is deliberately STRUCTURAL, not phrase-based: question
# wording keeps changing across Claude Code / Codex CLI versions
# ("Do you want to proceed?", "Do you want to make this edit ...",
# "Allow the <X> MCP server to run tool ...", future variants we can't
# enumerate). Instead we rely on the one visual invariant shared by
# every interactive selection prompt in both tools: a block of numbered
# options with a cursor indicator (❯ or ›) pointing at one of them.
#
# Stage A — "is this a permission prompt at all?"
#   Require BOTH:
#     • at least one numbered line carrying a cursor glyph
#       (e.g. "❯ 1. Yes", "› 1. Allow")
#     • at least two numbered option lines in total (a real menu, not
#       a stray list item)
#   Free-form Claude/Codex response text almost never contains a cursor
#   glyph directly before a numbered line, so this yields ~zero false
#   positives while being wording-agnostic.
#
# Stage B — "which option should we press?"
#   Still filtered by an affirmative word list (Yes|Allow|Accept|
#   Approve|Proceed|Confirm|Continue). That's the safety net: if a
#   future prompt is structurally a menu but has no affirmative option
#   (e.g. a neutral "pick one of these files"), Stage B returns empty
#   and the monitor does nothing instead of blindly pressing "1".
#
# Adding a new affirmative word is the only maintenance knob; adding
# new question phrasings requires no change.
detectPromptOption() {
    local tail="$1"

    # Stage A: structural gate — cursor + 2+ numbered options.
    if ! echo "$tail" | grep -qE '^[[:space:]]*[❯›][[:space:]]*[0-9]+\.'; then
        return 1
    fi
    local numOpts
    numOpts=$(echo "$tail" | grep -cE '^[[:space:]]*[❯›]?[[:space:]]*[0-9]+\.[[:space:]]+[^[:space:]]')
    if [ "$numOpts" -lt 2 ]; then
        return 1
    fi

    # Stage B: pick the best affirmative option, preferring the most
    # persistent form of approval available. Three priority tiers:
    #
    #   Tier 1 — PERMANENT remember. Matches any option whose line
    #            contains both an affirmative word and a "never ask
    #            again" marker:
    #              * "Yes, and don't ask again ..."
    #              * "Yes, and don't ..."
    #              * "Always allow" (Codex)
    #              * "Permanently …", "Forever …"
    #
    #   Tier 2 — SESSION remember. An affirmative option that scopes
    #            itself to the current session:
    #              * "Yes, and allow ... for this session"
    #              * "Allow for this session"
    #
    #   Tier 3 — PLAIN affirmative. Just "Yes" / "Allow" / etc.
    #
    # We walk tiers top-down and stop at the first hit, so for the
    # Claude settings prompt ("1. Yes" / "2. Yes, and allow ... for this
    # session" / "3. No") we correctly pick #2 rather than #1.
    local affirmRe='(Yes|Allow|Accept|Approve|Proceed|Confirm|Continue)'
    local optLineRe='^[[:space:]]*[❯›]?[[:space:]]*[0-9]+\.[[:space:]]+'
    local permanentRe='(don.t ask again|and don|always|permanently|forever)'
    local sessionRe='(for this session|this session|for this)'

    local line
    # Tier 1 — permanent remember
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$permanentRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 2 — session scope
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$sessionRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 3 — plain affirmative
    line=$(echo "$tail" \
        | grep -oE "${optLineRe}${affirmRe}" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi
    return 1
}

# =============================================================================
# AUTO-APPROVE SIGNAL FLOW — high-level view of one mainLoop iteration
# =============================================================================
#
#   tmux pane content
#         │
#         │ capture-pane (every fPollInterval, default 0.3s)
#         ▼
#     last 20 lines
#         │
#         │ _hash
#         ▼
#     12-char fingerprint ─────→ compare against lastHandledFp
#         │                            │
#         │                            └→ equal = screen unchanged → skip
#         │
#         │ tail text
#         ▼
#     detectPromptOption
#         │
#         │ Stage A: structural gate (cursor + ≥2 numbered options)
#         ▼
#     is this a menu?
#         │
#         │ Stage B: 3-tier picker (permanent → session → plain)
#         ▼
#     option number N (1–9)
#         │
#         │ tmux send-keys "N"
#         ▼
#     pane receives key → prompt vanishes → new content appears
#         │
#         │ waitForScreenChange (poll the pane hash, capped at 2s)
#         ▼
#     post-send fingerprint _postFp
#         │
#         │ _postFp != _preSendFp ?  yes → success
#         │                          no  → re-run detector to verify;
#         │                                if prompt still on screen, retry
#         ▼
#     log "✔ Approved (option N)"
#         │
#         ▼
#     lastHandledFp = _preSendFp   (note: NOT _postFp — using post-send
#                                     would dedup-skip the very next
#                                     prompt if Claude/Codex emits one
#                                     during our 2s wait window)
#         │
#         ▼
#     back to capture-pane, next iteration
#
# =============================================================================
mainLoop() {
    # Fingerprint of the screen state we already took action on (approved,
    # or gave up after retries). Top-of-loop dedup skips iterations whose
    # fingerprint matches this — meaning the screen hasn't changed since
    # we handled it, so there's nothing new to do.
    # Empty string at startup so the first iteration always proceeds.
    local lastHandledFp=""

    # Daemon-mode pause flag (global so --status / _writeState can read it).
    # Set when the pane is currently running something we don't monitor
    # (bash, filtered-out AI). Cleared the next iteration we see a known
    # AI again — the transition from set → unset is what triggers the
    # "Resumed" log line, regardless of whether the AI that came back has
    # the same name as the original ($fAiName unchanged) or a different
    # one ($fAiName updated).
    fPaused=""

    # Record start time for --status uptime calculation, freeze where ja
    # was launched (host pane / tty / detached), capture the target
    # pane's pane_id as a stable anchor, and write an initial state
    # snapshot so --status can answer "is daemon up?" the very next
    # moment after we launch (don't wait for first event).
    fStartedTs=$(date +%s)
    fHost=$(_resolveHostLocation || true)
    fTargetPaneId=$(tmux display-message -t "$fTmuxTarget" -p '#{pane_id}' 2>/dev/null)
    _writeState start

    # Compact two-line banner: title + watch summary on the first line,
    # config + stop hint on the second, single horizontal rule below to
    # mark where the run-time log starts. Rule width tracks the wider of
    # the two banner lines plus a small overshoot so the underline always
    # extends a few cells past the last visible glyph — gives the banner
    # an obvious "this is the bottom edge" feel instead of butting flush
    # against text (which can read as accidental wrap). The overshoot
    # also absorbs minor variation: a long $fTmuxTarget or the optional
    # "· daemon" suffix can push lines past the old hardcoded 60 cols
    # without truncating the rule. bash's ${#var} counts UTF-8 code
    # points correctly under a UTF-8 locale, so the multi-byte glyphs
    # (▶ → · ─) measure as 1 column each — matching their rendered width.
    local _line1Plain _line2Plain _daemonNotePlain=""
    echo
    if [ -n "$fAiName" ]; then
        _line1Plain="▶ ${SCRIPT_NAME} AUTO-APPROVE · ${fAiName} → ${fTmuxTarget}"
    else
        _line1Plain="▶ ${SCRIPT_NAME} AUTO-APPROVE · ${fTmuxTarget}"
    fi
    [ -n "$fDaemon" ] && _daemonNotePlain=" · daemon"
    _line2Plain="  poll ${fPollInterval}s · delay ${fApproveDelay}s${_daemonNotePlain} · Ctrl+C to stop"
    local _ruleW=${#_line1Plain}
    [ ${#_line2Plain} -gt "$_ruleW" ] && _ruleW=${#_line2Plain}
    # Overshoot: 4 cells past the widest visible content. Small enough
    # that the rule still reads as "tight" framing for the banner, large
    # enough that the underline is clearly separated from the trailing
    # word at the eye-flick scale. Matches the visual rhythm jc/jmake
    # use for similar two-line banners.
    _ruleW=$((_ruleW + 4))

    # No leading blank line — the banner is the very first thing in the
    # log file and a leading blank reads as "ja --log silently ate a
    # line" when the user runs it. Trailing blank below stays (it
    # visually separates the banner from the run-time events).
    if [ -n "$fAiName" ]; then
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${CYAN}${fAiName}${RESET} ${GREY}→${RESET} ${BLUE}${fTmuxTarget}${RESET}"
    else
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${BLUE}${fTmuxTarget}${RESET}"
    fi
    local _daemonNote=""
    [ -n "$fDaemon" ] && _daemonNote=" ${GREY}·${RESET} ${MAGENTA}daemon${RESET}"
    echo -e "  ${GREY}poll${RESET} ${fPollInterval}s ${GREY}·${RESET} ${GREY}delay${RESET} ${fApproveDelay}s${_daemonNote} ${GREY}·${RESET} ${GREY}Ctrl+C to stop${RESET}"
    echo -e "${GREY}$(_hr "$_ruleW")${RESET}"
    echo ""

    while true; do
        local content
        content=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
        if [ $? -ne 0 ]; then
            _log "${RED}Target pane gone. Exiting.${RESET}"
            break
        fi

        # Hijack check: did some other pane take over our target string?
        # tmux pane_id (eg. "%47") is permanent — it does NOT change on
        # move-window / rename-session. So if the pane_id currently
        # mapped to fTmuxTarget differs from what we recorded at launch
        # in fTargetPaneId, the original pane has been moved away and
        # something else now answers to fTmuxTarget. Refuse to keep
        # monitoring (we'd be reading the wrong pane's content and could
        # silently send-keys into an unrelated pane). Only enforced when
        # we successfully captured the original pane_id at startup.
        if [ -n "$fTargetPaneId" ]; then
            local _curPaneId
            _curPaneId=$(tmux display-message -t "$fTmuxTarget" -p '#{pane_id}' 2>/dev/null)
            if [ -n "$_curPaneId" ] && [ "$_curPaneId" != "$fTargetPaneId" ]; then
                _log "${RED}Target pane ${fTmuxTarget} was replaced (was ${fTargetPaneId}, now ${_curPaneId}). Exiting.${RESET}"
                break
            fi
        fi

        # Sanity check: AI process still running in the pane?
        # If claude/codex exits while ja keeps running, the pane returns to
        # bash but the AI's prompt text often stays in scrollback. The
        # detector then matches that stale text on every iteration and ja
        # spams `tmux send-keys '1'` into the now-bash pane (each "1" is
        # echoed by bash, the screen changes, dedup fails to fire — tight
        # loop). Guard against this by re-checking the AI on every iter.
        #
        # Two behaviours, gated by --daemon:
        #   default        : current cmd != fAiName → exit (original).
        #   --daemon (-D)  : if pane is running a known (and filter-allowed)
        #                    AI, monitor it — adopting a new name if needed.
        #                    Otherwise skip detection this iter and keep
        #                    polling. Never feed bash output to the detector.
        local currentAi
        currentAi=$(detectAiNameForTarget "$fTmuxTarget")

        if [ -z "$fDaemon" ]; then
            # Original (non-daemon) behaviour preserved verbatim.
            if [ -n "$currentAi" ] && [ "$currentAi" != "$fAiName" ]; then
                _log "${RED}'${fAiName}' no longer running in ${fTmuxTarget} (now '${currentAi}'). Exiting.${RESET}"
                break
            fi
        else
            # Daemon mode. Decide if the current pane content is something
            # we should actively monitor. Two checks:
            #   • _isKnownAi: filters out plain shells / unknown commands.
            #   • fAiFilter: when --claude/--codex was set, only that AI
            #     counts as "ours".
            local _shouldMonitor=""
            if [ -n "$currentAi" ] && _isKnownAi "$currentAi" && \
               { [ -z "$fAiFilter" ] || [ "$currentAi" = "$fAiFilter" ]; }; then
                _shouldMonitor=1
            fi

            if [ -z "$_shouldMonitor" ]; then
                # Pane is on bash / a filtered-out AI. Skip detection this
                # iter — DO NOT fall through to detectPromptOption, which
                # would happily match stale menu text in scrollback and
                # start spamming digits at the bare shell.
                if [ -z "$fPaused" ]; then
                    _log "${LIGHTYELLOW}⏸ Paused${RESET} — pane currently '${currentAi:-?}', not an AI we monitor. Waiting for ${fAiName}…"
                    fPaused=1
                    _writeState paused
                fi
                sleep "$fPollInterval"
                continue
            fi

            # An AI is in the pane and we're allowed to monitor it. If we
            # were paused, or the AI's identity changed mid-run, announce
            # the resume + reset dedup so a fresh prompt isn't skipped by
            # a stale fingerprint match.
            if [ -n "$fPaused" ] || [ "$currentAi" != "$fAiName" ]; then
                _log "${GREEN}▶ Resumed${RESET} — monitoring '${CYAN}${currentAi}${RESET}' in ${BLUE}${fTmuxTarget}${RESET}"
                fAiName="$currentAi"
                lastHandledFp=""
                fPaused=""
                _writeState resumed
            fi
        fi

        local tail
        tail=$(echo "$content" | tail -20)

        # Fingerprint to avoid double-pressing
        local fingerprint
        fingerprint=$(echo "$tail" | _hash)
        if [ "$fingerprint" = "$lastHandledFp" ]; then
            sleep "$fPollInterval"
            continue
        fi

        # Detect a permission prompt (Claude Code or Codex CLI — same
        # structural shape) and pick the option number to approve.
        local promptOption
        promptOption=$(detectPromptOption "$tail")
        if [ -n "$promptOption" ]; then
            _dbg "detector matched: option=$promptOption fp=$fingerprint"
            _dbgBlock "tail content (the 20 lines fed to detectPromptOption):" <<<"$tail"
            applyApproveDelay
            # Both Claude Code and Codex CLI (macOS + Linux) accept the
            # option number as a hotkey in the permission prompt. Sending
            # the number selects + submits in one shot, which avoids any
            # dependence on detecting the currently highlighted row.
            #
            # A single send-keys can be lost (pane mid-render, app not yet
            # accepting input, tmux race). Poll waitForScreenChange after
            # each send: react as soon as the pane updates, but wait a full
            # 2s before declaring the key lost. Only then retry, because
            # double-pressing a number key in Claude Code can silently jump
            # to a different option.
            #
            # KNOWN LIMITATION — multi-digit option numbers
            # ─────────────────────────────────────────────
            # detectPromptOption uses [0-9]+ in the regex, so an option
            # numbered "10" or higher would be returned as a multi-char
            # string. tmux send-keys treats each character as a separate
            # keystroke, so passing "10" sends "1" then "0":
            #     - "1" already selects + submits option 1
            #     - "0" lands on whatever state comes next (usually a no-op,
            #       but could land on an unintended target)
            # → wrong option approved.
            #
            # In practice neither Claude Code nor Codex CLI exposes more
            # than ~3 options today, so this hasn't bitten us. If a future
            # version surfaces 10+ options, two possible fixes:
            #   (a) Conservative — clamp the detector to [1-9] and let the
            #       user approve manually when there are more options.
            #   (b) Adaptive — send the digits one-by-one followed by Enter
            #       (`send-keys "$promptOption" Enter`); requires verifying
            #       that Claude/Codex's prompt UI actually accepts that
            #       form (single-digit hotkeys auto-submit, but multi-digit
            #       entry mode may not exist).
            # Until that version ships, this branch trusts that
            # $promptOption is a single ASCII digit.
            #
            # KNOWN LIMITATION — slow-transition prompts (trust prompt)
            # ──────────────────────────────────────────────────────────
            # The trust prompt is the one prompt where pressing the
            # option number is correctly accepted but the visible UI
            # takes 10+ seconds to transition (codex/claude do config
            # loading, MCP startup, etc. before the menu is replaced).
            # All other prompts transition in well under 1 second.
            #
            # Real wording (so future regex detection has examples):
            #
            #   Codex CLI:
            #     "Do you trust the contents of this directory? ..."
            #     "› 1. Yes, continue / 2. No, quit"
            #     "Press enter to continue"
            #
            #   Claude Code:
            #     "Quick safety check: Is this a project you created
            #      or one you trust? ..."
            #     "❯ 1. Yes, I trust this folder / 2. No, exit"
            #     "Enter to confirm · Esc to cancel"
            #
            # Common markers across both: word "trust" near the question,
            # and a footer hint mentioning "Enter to (confirm|continue)".
            #
            # Effect: waitForScreenChange's 2s budget expires while the
            # menu is still on screen; verify-and-retry then misclassifies
            # this as "key dropped" and resends. The second keystroke
            # leaks into whatever input context comes next (typically the
            # main UI's text input → a stray "1" appears in the prompt
            # box).
            #
            # Why it's not fixed:
            #   - Bumping the global timeout to 15-30s slows down EVERY
            #     dropped-key recovery for the 99% of fast prompts.
            #   - Detecting the trust prompt by phrase ("do you trust")
            #     and bypassing retry would work but adds a maintenance
            #     knob and a regex that has to track future wording.
            #   - The damage is small: one extra digit in the input box,
            #     trivially deleted with backspace. Trust prompts only
            #     appear once per untrusted directory, so this is
            #     low-frequency.
            # Tracked here so future regressions (more frequent or more
            # damaging variants) can find the rationale and the proposed
            # fixes (see brainstorm in commit history).
            local _preSendFp="$fingerprint"
            local _maxRetries=3
            local _attempt=0
            local _postFp="$_preSendFp"
            while true; do
                _dbg "send-keys '$promptOption' (attempt $((_attempt + 1))/$_maxRetries)"
                tmux send-keys -t "$fTmuxTarget" "$promptOption"
                _postFp=$(waitForScreenChange "$_preSendFp" 2000)
                if [ "$_postFp" != "$_preSendFp" ]; then
                    _dbg "screen changed: $_preSendFp → $_postFp"
                    break
                fi
                _dbg "screen unchanged after 2s, verifying prompt is still visible..."

                # Timeout: before re-sending, confirm the prompt is
                # still on-screen. If detectPromptOption returns empty,
                # the keystroke took effect and we only missed the hash
                # change (stable header, tiny diff); treat as success.
                # Only retry when the prompt truly is still visible —
                # this is what prevents a second digit key from landing
                # in a different state and approving the wrong option.
                local _verifyContent _verifyTail
                _verifyContent=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
                _verifyTail=$(echo "$_verifyContent" | tail -20)
                if [ -z "$(detectPromptOption "$_verifyTail")" ]; then
                    _dbg "prompt vanished from screen → treating as success (key likely took effect, hash diff was missed)"
                    _postFp=$(echo "$_verifyTail" | _hash)
                    break
                fi

                _dbg "prompt still on screen → key likely dropped, will retry"
                _attempt=$((_attempt + 1))
                [ "$_attempt" -ge "$_maxRetries" ] && break
            done
            if [ "$_postFp" = "$_preSendFp" ]; then
                _log "${RED}⚠ Keystroke dropped (option $promptOption) after $_maxRetries attempts${RESET}"
                _writeState dropped
            else
                fApprovedCount=$((fApprovedCount + 1))
                local _retryNote=""
                [ "$_attempt" -gt 0 ] && _retryNote=" (${LIGHTMAGENTA}retry $_attempt${RESET})"
                _log "${GREEN}✔ Approved${RESET} (option $promptOption)${_retryNote} [#$fApprovedCount]"
                _writeState approve
            fi
            # Track the PRE-send fingerprint, not the post-send one.
            # Rationale: if Claude finishes the approved command quickly and
            # shows the next permission prompt during our wait window,
            # $_postFp captures that new prompt's hash — and the top-of-loop
            # dedup would then skip it forever. Using $_preSendFp ensures
            # dedup only fires when the EXACT prompt we just approved is
            # still on screen (i.e., the keystroke was dropped), while a
            # brand-new prompt has a different hash and is handled normally.
            lastHandledFp="$_preSendFp"
            _dbg "lastHandledFp ← $_preSendFp (pre-send fp)"
            continue
        fi

        # Screen changed but detector didn't match — useful signal when
        # diagnosing why a stale-but-visible prompt stops triggering on
        # later iterations.
        _dbg "no prompt detected (fp=$fingerprint, but screen changed since fp=$lastHandledFp)"

        sleep "$fPollInterval"
    done
}

# =============================================================================
# MAIN FLOW — modeled on jc's structure
# =============================================================================
#
#   main()
#     ├── parseOptions       (fills fXxx globals)
#     ├── doEarlyExitJobs    (handles task-mode flags like -l; never returns)
#     ├── checkTmuxAvailable (sanity check)
#     ├── resolveTarget      (autoDetect or validate -t; sets fTmuxTarget/fAiName)
#     ├── acquireLockfile    (single-instance guard; sets fLockFile)
#     ├── setupCleanupTrap   (defines _cleanup; arms trap)
#     └── mainLoop           (the watch-and-approve loop)
#
# Adding a new task-mode flag (e.g. --status, --stop, --log) means:
#   1. parseOptions registers it
#   2. doEarlyExitJobs dispatches it to a handler
#   3. write the handler
# The handler runs and exits, never reaching the monitor flow below.
# =============================================================================

# Dispatch task-mode flags. Each handler runs to completion and exits;
# control never returns to main(). Mirrors jc's doEarlyExitJobs pattern.
#
# Order matters when multiple flags collide — the first one that fires
# wins. We pick the order that makes accidental combinations harmless:
# --stop wins over --status / --log (you wanted to stop, not query),
# --list stays first as the historical default.
doEarlyExitJobs() {
    [ -n "$fList" ]    && { handleListMode;            exit 0;  }
    [ -n "$fStop" ]    && { handleStopRequest;         exit $?; }
    [ -n "$fStatus" ]  && { handleStatusRequest;       exit $?; }
    [ -n "$fLogFull" ] && { handleLogRequest full;     exit $?; }
    [ -n "$fLog" ]     && { handleLogRequest tail;     exit $?; }
}

# `-l` / `--list` handler — list every tmux pane currently running an AI,
# annotated with whether ja is already monitoring it. Honors --claude /
# --codex filtering.
handleListMode() {
    local _panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && _panes+=("$line")
    done < <(findAiPanes)

    if [ ${#_panes[@]} -eq 0 ]; then
        if [ -n "$fAiFilter" ]; then
            echo -e "${RED}No pane running ${fAiFilter} found${RESET}"
        else
            echo -e "${RED}No pane running $(_aiNamesPretty) found${RESET}"
        fi
        return 0
    fi

    echo ""
    if [ -n "$fAiFilter" ]; then
        echo -e "${LIGHTYELLOW}AI sessions on tmux server (${#_panes[@]}) ${GREY}[filter: ${fAiFilter}]${RESET}"
    else
        echo -e "${LIGHTYELLOW}AI sessions on tmux server (${#_panes[@]})${RESET}"
    fi
    echo ""
    _renderAiTable "${_panes[@]}"
    echo ""
}

# Shared target resolution for --stop / --status / --log. Three sources:
#   1. -t was passed → use it as-is. Validation is left to the caller —
#      --stop and --status should be tolerant of a target that no longer
#      exists (no daemon there anyway), but --log and the monitor flow
#      need a live target.
#   2. inside tmux, -t not passed → use the current pane's target.
#   3. outside tmux, -t not passed → return empty (caller decides
#      whether that's an error or a "list-all" fallback).
#
# Echoes the resolved target on stdout. Returns 0 if a target was
# found, 1 if running outside tmux without -t.
_resolveTargetForTaskMode() {
    if [ -n "$fTmuxTarget" ]; then
        printf '%s' "$fTmuxTarget"
        return 0
    fi
    if [ -n "$TMUX" ]; then
        local cur
        cur=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
        if [ -n "$cur" ]; then
            printf '%s' "$cur"
            return 0
        fi
    fi
    return 1
}

# Stop the daemon monitoring a target pane. Idempotent — "already not
# running" is reported but exits 0. Cleans up stale lockfile/state if
# the recorded pid is dead.
handleStopRequest() {
    local target
    if ! target=$(_resolveTargetForTaskMode) || [ -z "$target" ]; then
        echo -e "${RED}Error: ${SCRIPT_NAME} --stop without -t requires running inside tmux${RESET}" >&2
        echo -e "${GREY}Pass an explicit target: ${SCRIPT_NAME} --stop -t session:window.pane${RESET}" >&2
        return 1
    fi
    local lockfile=$(_lockFilePath "$target")
    local statefile=$(_stateFilePath "$target")
    # Recover the daemon's pid from whichever file is still around.
    # Lockfile is canonical; state file is the defensive fallback if
    # the lockfile was deleted out from under a running daemon (see
    # _monitorPid for the rationale).
    local pid=""
    if [ -f "$lockfile" ]; then
        pid=$(cat "$lockfile" 2>/dev/null)
    fi
    if [ -z "$pid" ] && [ -f "$statefile" ]; then
        pid=$(_readStateField "$statefile" pid)
    fi
    if [ -z "$pid" ]; then
        # ○ idle (yellow open circle) — no daemon, nothing to stop.
        # Mirrors the empty-state symbol used by `ja --status`.
        echo -e "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME}: ${GREY}no daemon running for pane${RESET} ${BLUE}${target}${RESET}"
        return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
        # Stale state — daemon died without cleaning up. Remove the
        # detritus so next launch isn't blocked.
        rm -f "$lockfile" "$statefile"
        # ⚠ lightyellow — not an error but worth noticing (you intended
        # to stop something that wasn't fully there).
        echo -e "${LIGHTYELLOW}⚠${RESET} ${SCRIPT_NAME}: ${GREY}stale state cleaned${RESET} ${GREY}(no live daemon for pane${RESET} ${BLUE}${target}${GREY})${RESET}"
        return 0
    fi
    if kill "$pid" 2>/dev/null; then
        # Wait briefly for the daemon's TERM trap to clean up its own
        # lockfile/state. If it's slow or stuck, force-clean ourselves.
        local i
        for i in 1 2 3 4 5; do
            kill -0 "$pid" 2>/dev/null || break
            sleep 0.1
        done
        rm -f "$lockfile" "$statefile" 2>/dev/null
        # ▶ magenta + green "stopped" — same palette as wrapper's
        # "ja running / ja already running" status lines so all daemon
        # life-cycle messages share a vocabulary. pid stays cyan.
        echo -e "${MAGENTA}▶${RESET} ${SCRIPT_NAME} ${GREEN}stopped${RESET} ${GREY}·${RESET} pid ${CYAN}${pid}${RESET} ${GREY}·${RESET} pane ${BLUE}${target}${RESET}"
        return 0
    fi
    echo -e "${RED}✗${RESET} ${SCRIPT_NAME}: ${RED}failed to kill pid ${pid}${RESET} ${GREY}(permission denied?)${RESET}" >&2
    return 1
}

# Pretty-format a duration in seconds as "Xm Ys" or "Xh Ym Zs".
_fmtDuration() {
    local s="$1" h m
    if [ "$s" -lt 60 ]; then echo "${s}s"; return; fi
    if [ "$s" -lt 3600 ]; then m=$((s / 60)); echo "${m}m $((s % 60))s"; return; fi
    h=$((s / 3600)); m=$(((s % 3600) / 60))
    echo "${h}h ${m}m $((s % 3600 % 60))s"
}

# Format unix-seconds as "YYYY-MM-DD HH:MM:SS" for --status. GNU date
# uses `-d "@ts"`, BSD/macOS uses `-r ts` — try GNU first, fall back.
# Echo raw ts on total failure so the cell stays readable.
_fmtEventTime() {
    local ts="$1"
    [[ "$ts" =~ ^[0-9]+$ ]] || { echo "?"; return; }
    date -d "@$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || date -r "$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || echo "$ts"
}

# Read a single field from a state JSON file. Crude but adequate — our
# schema is flat and we control the writer (_writeState), so we don't
# need a real JSON parser. Strips wrapping quotes and trailing comma.
_readStateField() {
    local file="$1" field="$2"
    grep -E "\"${field}\":" "$file" 2>/dev/null \
        | sed -E "s/.*\"${field}\":[[:space:]]*//; s/,[[:space:]]*$//; s/^\"//; s/\"$//" \
        | head -1
}

# Single status renderer — one entry per daemon, formatted as a summary
# row plus an indented detail block. Always shows every daemon, no -t /
# --all / tmux-aware branching. If the caller is currently inside tmux,
# the row corresponding to the caller's pane is marked with `*` in the
# `#` column (decorative only — doesn't change layout or behavior).
handleStatusRequest() {
    local files=( "$(_runtimeDir)"/*.state.json )
    # Glob with no match expands to a literal that doesn't exist — guard.
    if [ ! -e "${files[0]}" ]; then
        # Empty-state output uses ○ (open circle) + yellow to mirror the
        # `-l` listing's "● monitoring / ○ idle" convention, then a grey
        # hint pointing at how to start one. Avoids looking like an error
        # (no red) while still being more visible than plain grey.
        echo -e "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME}: no daemons running"
        echo -e "  ${GREY}Start one with:${RESET} ${CYAN}claude -y${RESET} ${GREY}or${RESET} ${CYAN}${SCRIPT_NAME} -D${RESET}"
        return 0
    fi

    # Best-effort: identify the caller's current pane so we can mark its
    # row. Failure is silent — outside tmux we just don't mark anything.
    local current_pane=""
    if [ -n "$TMUX" ]; then
        current_pane=$(tmux display-message -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null)
    fi

    echo -e "${LIGHTYELLOW}${SCRIPT_NAME} daemons running (${#files[@]})${RESET}"
    echo

    # Layout: every line is `Label: value` in a two-column grid. First
    # line starts with "[N] " (or "[N*] ") as index marker; subsequent
    # lines indent with 5 spaces. Per-line:
    #   indent/marker(5) + label1(_labW) + " " + value1(_valW)
    #                    + " " + label2(_lab2W) + " " + value2
    # _labW/_lab2W=12 fit longest labels ("Persistent:", "Event Time:").
    # _valW=19 fits state_pad, PID, target, event type.
    # Hoisted to loop top because state_pad's padding reuses _valW.
    local _labW=12 _valW=19 _lab2W=12

    local i=1 f target pid ai filter daemon_int started approved paused
    local last_ts last_type host state_plain state_colored state_pad last_when
    local now=$(date +%s)
    local uptime index_label
    for f in "${files[@]}"; do
        target=$(_readStateField "$f" target)
        pid=$(_readStateField "$f" pid)
        ai=$(_readStateField "$f" ai)
        filter=$(_readStateField "$f" ai_filter)
        daemon_int=$(_readStateField "$f" daemon)
        started=$(_readStateField "$f" started_ts)
        approved=$(_readStateField "$f" approved_count)
        paused=$(_readStateField "$f" paused)
        last_ts=$(_readStateField "$f" last_event_ts)
        last_type=$(_readStateField "$f" last_event_type)
        host=$(_readStateField "$f" host)

        # State: pad-then-color (ANSI escapes throw off %-Ns downstream).
        if ! kill -0 "$pid" 2>/dev/null; then
            state_plain="dead";    state_colored="${RED}dead${RESET}"
        elif [ "$paused" = "true" ]; then
            state_plain="paused";  state_colored="${LIGHTYELLOW}paused${RESET}"
        else
            state_plain="active";  state_colored="${GREEN}active${RESET}"
        fi
        state_pad=$(printf "%-${_valW}s" "$state_plain")
        state_pad="${state_colored}${state_pad#$state_plain}"

        last_when=$(_fmtEventTime "$last_ts")
        uptime="?"
        [[ "$started" =~ ^[0-9]+$ ]] && uptime=$(_fmtDuration $((now - started)))

        # Index marker — "[N]" or "[N*]" if this is the caller's current
        # pane. Fits 5 chars for N=1..99; overflows gracefully for 100+.
        if [ -n "$current_pane" ] && [ "$target" = "$current_pane" ]; then
            index_label="[${i}*]"
        else
            index_label="[${i}]"
        fi

        # Filter label: "--claude" / "--codex" / "(none)" if not filtered.
        local filter_label="(none)"
        [ -n "$filter" ] && filter_label="--$filter"

        # Persistent label — reflects the startup-time `-D/--daemon` flag
        # the ja was launched with. Names this "Persistent" rather than
        # "Daemon" because in our flag it really means "stay alive across
        # AI restarts", not "detached unix daemon". The actual runtime
        # detached/foreground status is shown separately as Mode below.
        local persistent_label="no"
        [ "$daemon_int" = "1" ] && persistent_label="yes"

        # Mode label — describes the daemon's controlling-tty binding,
        # which determines whether closing the host pane / terminal will
        # send the daemon SIGHUP. Two states:
        #
        #   • "attached to <X>" — daemon has a controlling tty inheriting
        #     from the shell where it was launched. Closing that pane (or
        #     terminal) will send SIGHUP and kill the daemon. This is the
        #     case for `claude -y` launches today, because bash's
        #     `& disown` only detaches from the job table — it does NOT
        #     release the ctty, which requires setsid(2).
        #
        #   • "detached" — no ctty. The daemon survives pane / terminal
        #     close. Achieved via `setsid ja -D ...` in the wrapper, or
        #     by tools like nohup setsid.
        #
        # Keeping the word "daemon" out of this column entirely — that
        # word is already used by the --daemon / Persistent flag, which
        # describes lifecycle (stay alive across AI restarts), not ctty
        # binding. Two distinct concepts deserve two distinct vocabularies.
        local mode_label
        if [ -z "$host" ]; then
            mode_label="${MAGENTA}detached${RESET}"
        else
            mode_label="attached to ${GREY}${host}${RESET}"
        fi

        local logf=$(_logFilePath "$target")
        local lockf=$(_lockFilePath "$target")

        # printf (not echo -e): color vars are already-expanded ANSI bytes
        # by the time printf sees them. %b on state_pad / mode_label since
        # they carry pre-baked ANSI (width pre-applied for state_pad).

        # [N] + Target / AI
        printf "${CYAN}%-5s${RESET}${GREY}%-${_labW}s${RESET} ${BLUE}%-${_valW}s${RESET} ${GREY}%-${_lab2W}s${RESET} ${CYAN}%s${RESET}\n" \
            "$index_label" "Target:" "$target" "AI:" "$ai"

        # State / Approved
        printf "     ${GREY}%-${_labW}s${RESET} %b ${GREY}%-${_lab2W}s${RESET} ${GREEN}%s${RESET}\n" \
            "State:" "$state_pad" "Approved:" "$approved"

        # Last Event / Event Time
        printf "     ${GREY}%-${_labW}s${RESET} %-${_valW}s ${GREY}%-${_lab2W}s${RESET} %s\n" \
            "Last Event:" "$last_type" "Event Time:" "$last_when"

        # PID / Uptime
        printf "     ${GREY}%-${_labW}s${RESET} ${CYAN}%-${_valW}s${RESET} ${GREY}%-${_lab2W}s${RESET} %s\n" \
            "PID:" "$pid" "Uptime:" "$uptime"

        # Persistent / Mode
        printf "     ${GREY}%-${_labW}s${RESET} %-${_valW}s ${GREY}%-${_lab2W}s${RESET} %b\n" \
            "Persistent:" "$persistent_label" "Mode:" "$mode_label"

        # Filter (single column — no natural pair value)
        printf "     ${GREY}%-${_labW}s${RESET} %s\n" \
            "Filter:" "$filter_label"

        # Paths — full-width. `Statefile:` (renamed from `State:`)
        # disambiguates the path label from the daemon-state field above.
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Lockfile:"  "$lockf"
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Logfile:"   "$logf"
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Statefile:" "$f"
        echo

        i=$((i + 1))
    done
}

# Tail the daemon's log file. `-F` (capital) follows by name not fd, so
# log rotation (or daemon restart writing a new file) is handled.
#
# Mode arg controls the starting point:
#   • "tail" (default) — last 15 lines, then follow. Maps to --log / -L.
#                        15 (vs tail's default of 10) gives enough context
#                        to see the most recent ✔ Approved / ⚠ events
#                        without scrolling.
#   • "full"           — every line from line 1, then follow. Maps to
#                        --log-full. Implemented as `tail -F -n +1` (single
#                        process) rather than `cat … && tail -F …` so no
#                        appends written between the cat finishing and tail
#                        starting can be missed.
handleLogRequest() {
    local mode="${1:-tail}"
    local target
    if ! target=$(_resolveTargetForTaskMode) || [ -z "$target" ]; then
        local _flag="--log"
        [ "$mode" = "full" ] && _flag="--log-full"
        echo -e "${RED}Error: ${SCRIPT_NAME} ${_flag} without -t requires running inside tmux${RESET}" >&2
        echo -e "${GREY}Pass an explicit target: ${SCRIPT_NAME} ${_flag} -t session:window.pane${RESET}" >&2
        return 1
    fi
    local logfile=$(_logFilePath "$target")
    local lockfile=$(_lockFilePath "$target")
    if [ ! -f "$logfile" ]; then
        if [ -f "$lockfile" ]; then
            echo -e "${LIGHTYELLOW}${SCRIPT_NAME}: daemon running for ${BLUE}${target}${LIGHTYELLOW} but log file missing at ${GREY}${logfile}${RESET}" >&2
            echo -e "${GREY}(daemon may have been started without log redirection)${RESET}" >&2
            return 1
        fi
        echo -e "${GREY}${SCRIPT_NAME}: no daemon running for pane ${BLUE}${target}${RESET}"
        echo -e "${GREY}Start one with:${RESET} ${SCRIPT_NAME} -D -t ${target}"
        return 1
    fi
    # exec replaces our shell with tail so Ctrl+C goes straight to tail
    # without an intermediate process layer.
    if [ "$mode" = "full" ]; then
        exec tail -F -n +1 "$logfile"
    else
        exec tail -F -n 15 "$logfile"
    fi
}

# Sanity-check that tmux is on PATH. Without tmux ja literally cannot do
# anything — capture-pane, list-panes, send-keys all need it.
checkTmuxAvailable() {
    if ! command -v tmux &>/dev/null; then
        echo -e "${RED}Error: tmux is required but not found${RESET}" >&2
        exit 1
    fi
}

# Pin down which pane to monitor and which AI is in it. Two paths:
#   • -t not given: autoDetectTarget scans tmux for AI panes, picks one
#     (or prompts the user if multiple match).
#   • -t given:     validate the target exists, then sanity-check that
#     a recognised AI is running there. Daemon mode relaxes this: the
#     pane is allowed to currently be running anything (or nothing AI-y)
#     and ja boots into a paused state, waiting for an AI to appear.
resolveTarget() {
    if [ -z "$fTmuxTarget" ]; then
        # auto-detect requires at least one AI pane to bootstrap the target.
        # Even in daemon mode there's no way to "wait for an AI to come back"
        # without first knowing which pane to wait in, so this path stays
        # strict regardless of -D.
        autoDetectTarget
        return
    fi

    validateTarget "$fTmuxTarget"
    fAiName=$(detectAiNameForTarget "$fTmuxTarget")
    # Refuse to attach to a pane that isn't running an AI tool. Without
    # this, `ja -t <bash-pane>` happily starts monitoring and the
    # detector ends up matching stale prompt text in scrollback (e.g.
    # from a previous claude session) — leading to runaway `tmux
    # send-keys '1'` into a plain shell.
    #
    # Daemon mode relaxes this: the whole point of -D is "stay alive
    # while no AI is running", so we let ja boot into a paused state
    # when the target pane has no AI yet. mainLoop's pause/resume logic
    # then handles things naturally once an AI appears.
    if ! _isKnownAi "$fAiName"; then
        if [ -z "$fDaemon" ]; then
            echo -e "${RED}Error: target ${fTmuxTarget} is running '${fAiName}', not $(_aiNamesPretty)${RESET}" >&2
            echo -e "${GREY}Start an AI tool in that pane first, or run '${SCRIPT_NAME} -l' to find existing AI panes.${RESET}" >&2
            exit 1
        fi
        # Daemon: synthesise an fAiName so banner/log lines have something
        # readable. fAiFilter (if set) is a better label than the raw cmd
        # because it tells the user *which* AI ja will accept on resume.
        if [ -n "$fAiFilter" ]; then
            fAiName="$fAiFilter"
        else
            fAiName="$(_aiNamesPretty)"
        fi
    fi
    # If the user requested a specific AI via --claude/--codex, refuse to
    # attach to a target running anything else.  Catches misuse like
    # `ja -t M:5.1 --codex` when M:5.1 is actually claude.
    #
    # Daemon mode again relaxes: a mismatched-but-known AI is fine because
    # the pane might switch to the requested AI later. mainLoop's filter
    # check will keep us paused until that happens.
    if [ -n "$fAiFilter" ] && _isKnownAi "$fAiName" && [ "$fAiName" != "$fAiFilter" ]; then
        if [ -z "$fDaemon" ]; then
            echo -e "${RED}Error: target ${fTmuxTarget} is running '${fAiName}', not '${fAiFilter}'${RESET}" >&2
            exit 1
        fi
        # Re-label so banner reflects what we'll actually monitor.
        fAiName="$fAiFilter"
    fi
}

# Acquire the per-target lockfile so only one ja monitors a given pane.
# If a stale (dead-pid) lockfile exists, we silently overwrite it.
#
# Duplicate detection routes through _monitorPid, so it sees a live
# daemon even if the lockfile got deleted out from under it (the
# state file is consulted as a fallback). Without that, a second
# `ja -D` would happily start next to the already-running one and
# both would race on send-keys into the same pane.
acquireLockfile() {
    # Path computed via _lockFilePath so it stays in sync with everything
    # else (_monitorPid, --stop, --status, wrapper log redirection, etc.).
    fLockFile=$(_lockFilePath "$fTmuxTarget")

    local _liveMonitorPid
    if _liveMonitorPid=$(_monitorPid "$fTmuxTarget"); then
        local _monitor_pane
        _monitor_pane=$(_paneOfPid "$_liveMonitorPid")
        echo -e "${GREY}${SCRIPT_NAME} is already monitoring ${BLUE}$fTmuxTarget${GREY} (pid ${CYAN}$_liveMonitorPid${GREY}${_monitor_pane:+, in pane ${CYAN}$_monitor_pane${GREY}}).${RESET}"
        echo -e "${GREY}Kill it first:${RESET} kill $_liveMonitorPid"
        exit 1
    fi
    echo $$ > "$fLockFile"
}

# Define _cleanup and arm the trap. _cleanup runs on Ctrl+C (INT), kill
# (TERM), or natural script exit (EXIT) — covers every termination path.
setupCleanupTrap() {
    # Clear the trap before exiting to avoid re-entry: INT calls _cleanup
    # which exits, but exiting also fires EXIT — if the trap is still
    # armed, the "Stopped" message prints twice.
    _cleanup() {
        rm -f "$fLockFile"
        # Also remove the state file — --status should not list a daemon
        # that has clearly stopped. Use _stateFilePath so the rule stays
        # in sync with where mainLoop wrote it.
        [ -n "$fTmuxTarget" ] && rm -f "$(_stateFilePath "$fTmuxTarget")"
        echo
        _log "Stopped. Approved ${GREEN}$fApprovedCount${RESET} prompts."
        trap - INT TERM EXIT
        exit 0
    }
    trap '_cleanup' INT TERM EXIT
}

main() {
    parseOptions "$@"
    doEarlyExitJobs
    checkTmuxAvailable
    resolveTarget
    acquireLockfile
    setupCleanupTrap
    mainLoop
}

main "$@"
