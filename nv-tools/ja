#!/usr/bin/env bash
# shellcheck disable=SC2034,SC2155,SC2168
#
# ja — Auto-approve confirmation prompts for Claude Code and Codex CLI
#
# Monitors a tmux pane and sends the affirmative option whenever a known
# permission prompt is detected. Blacklists rm -rf (falls through to manual).
#
# Usage:
#   ja                        # auto-detect the pane running claude/codex
#   ja -t myses:0.1           # explicit tmux target (session:window.pane)

SCRIPT_NAME=$(basename "$0")

# Options
fTmuxTarget=      # tmux target pane in session[:window[.pane]] format
fListOnly=        # list detected AI panes and exit
fApproveDelay=0   # seconds to wait before approving
fPollInterval=0.3 # seconds to poll for new prompts
fAiName=          # AI running in the target pane (claude|codex|...)
fApprovedCount=0  # number of prompts approved
fLockFile=        # populated AFTER fTmuxTarget is finalised; see main flow

# Colors
RED='\033[31m'
GREEN='\033[32m'
MAGENTA='\033[35m'
CYAN='\033[36m'
LIGHTYELLOW='\033[93m'
GREY='\033[90m'
BLUE='\033[34m'
RESET='\033[0m'

usage() {
    cat << _EOF
Usage: $SCRIPT_NAME [-t session[:window[.pane]]] [OPTIONS]

Auto-approve confirmation prompts for Claude Code and Codex CLI running in a
tmux pane. Monitors the pane screen and sends the affirmative option when a
known permission prompt is detected.

Options:
    -h, --help       Show this help message
    -t TARGET        Tmux target pane in session[:window[.pane]] format
                     (default: auto-detect the pane running claude or codex)
    -w, --wait SEC   Wait before approving (default: 0, approve immediately)
    -l, --list       List detected AI panes and exit

Supports:
    Claude Code      Numbered options (1. Yes / 2. No) — sends the number
    Codex CLI        Numbered options (1. Yes, proceed) — sends the number

Blacklist:
    Commands containing 'rm -rf' are never auto-approved.

Examples:
    $SCRIPT_NAME                    # auto-detect, approve immediately
    $SCRIPT_NAME -t main:0.1       # target specific pane
    $SCRIPT_NAME -w 3              # wait 3s before each approval (Ctrl+C to abort)


Stop:
    Press Ctrl+C or run: pkill -f '$SCRIPT_NAME'

_EOF
    exit 0
}

parseOptions() {
    local GETOPT_BIN="getopt"
    if command -v /opt/homebrew/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/opt/homebrew/opt/gnu-getopt/bin/getopt"
    elif command -v /usr/local/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/usr/local/opt/gnu-getopt/bin/getopt"
    fi

    local SHORTOPTS="ht:w:l"
    local LONGOPTS="help,wait:,list"

    local PARSED
    if ! PARSED=$("$GETOPT_BIN" --options="$SHORTOPTS" --longoptions="$LONGOPTS" --name "$SCRIPT_NAME" -- "$@"); then
        echo -e "${RED}Failed to parse arguments.${RESET}" >&2
        echo -e "${CYAN}Tip: On macOS, install GNU getopt: ${GREY}brew install gnu-getopt${RESET}" >&2
        exit 1
    fi

    eval set -- "$PARSED"

    while true; do
        case "$1" in
            -h|--help)
                usage
                ;;
            -t)
                fTmuxTarget="$2"
                shift 2
                ;;
            -w|--wait)
                fApproveDelay="$2"
                shift 2
                ;;
            -l|--list)
                fListOnly=1
                shift
                ;;
            --)
                shift
                break
                ;;
            *)
                echo -e "${RED}Error: Unknown option: $1${RESET}" >&2
                echo "Use $SCRIPT_NAME -h for help." >&2
                exit 1
                ;;
        esac
    done
}

# Validate a tmux target exists
validateTarget() {
    local target="$1"
    if ! tmux has-session -t "${target%%.*}" 2>/dev/null && \
       ! tmux has-session -t "${target%%:*}" 2>/dev/null; then
        echo -e "${RED}Error: tmux target '$target' not found${RESET}" >&2
        exit 1
    fi
}

# Return the pid of a live monitor process currently watching `target`,
# or empty (with non-zero exit) if no live monitor exists. The lockfile
# path is built from $SCRIPT_NAME so it stays in sync with the main flow
# even if this script is renamed.
_monitorPid() {
    local target="$1"
    local lockfile="/tmp/${SCRIPT_NAME}-${target//[:.]/-}.lock"
    [ -f "$lockfile" ] || return 1
    local pid
    pid=$(cat "$lockfile" 2>/dev/null)
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    echo "$pid"
}

# Return the tty name of a pid (e.g. "pts/4"), or empty (with non-zero
# exit) if the pid has no controlling tty or doesn't exist. The "?"
# value in ps output means "no controlling tty" (daemons, detached
# processes); we treat that as no tty.
_ttyOfPid() {
    local pid="$1"
    [ -n "$pid" ] || return 1
    local tty
    tty=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d '[:space:]')
    [ -n "$tty" ] && [ "$tty" != "?" ] || return 1
    printf '%s' "$tty"
}

# Return the tmux target (session:window.pane) that a pid is running in,
# or empty if the pid isn't attached to a tmux pane (e.g. a plain shell
# without tmux, or the pid has died). Works by matching the pid's tty
# against tmux's pane_tty list.
_paneOfPid() {
    local pid="$1"
    local tty
    tty=$(_ttyOfPid "$pid") || return 1
    tmux list-panes -a -F '#{pane_tty} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null \
        | awk -v t="/dev/$tty" '$1==t{print $2; exit}'
}

# Build a horizontal rule of N `─` characters. printf's %s precision
# works on bytes (not characters) and `─` is multibyte UTF-8, so we
# build the rule by repeated concatenation instead.
_hr() {
    local n="$1" out=""
    while [ "$n" -gt 0 ]; do out+="─"; n=$((n - 1)); done
    printf '%s' "$out"
}

# Render the standard "AI sessions" table given a list of "pid|target|name"
# lines as positional args. Used by both the `-l` listing block and
# autoDetectTarget's multi-session picker so the two stay visually in sync.
#
# Output: header row, separator row, then one row per pane with a Status
# column reflecting whether a monitor process is already watching that target.
#
# Usage: _renderAiTable "${panes[@]}"
_renderAiTable() {
    local panes=("$@")
    local pid t c
    local tool_width=4    # min "Tool"
    local target_width=6  # min "Target"
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t c <<<"$p"
        [ ${#c} -gt "$tool_width" ] && tool_width=${#c}
        [ ${#t} -gt "$target_width" ] && target_width=${#t}
    done

    local _gap_str=""
    printf "${_gap_str}${GREY}%-3s %-${tool_width}s  %-${target_width}s  %s${RESET}\n" \
        "#" "Tool" "Target" "Status"
    printf "${_gap_str}${GREY}%s %s  %s  %s${RESET}\n" \
        "$(_hr 3)" "$(_hr "$tool_width")" "$(_hr "$target_width")" "$(_hr 22)"

    local i=1 mon_pid mon_pane mon_tty mon_loc status p
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t c <<<"$p"
        mon_pid=$(_monitorPid "$t")
        if [ -n "$mon_pid" ]; then
            # Two-tier location lookup:
            #   1. Try to map the monitor pid to a tmux target (best case;
            #      user can jump there with `tmux switch -t <addr>`).
            #   2. Fall back to the bare tty if the monitor is running
            #      outside tmux (still useful — tells the user which
            #      terminal owns the process).
            #   3. If neither resolves (detached / nohup'd), suppress the
            #      suffix entirely via ${var:+text}.
            mon_pane=$(_paneOfPid "$mon_pid")
            if [ -n "$mon_pane" ]; then
                mon_loc=", from $mon_pane"
            else
                mon_tty=$(_ttyOfPid "$mon_pid")
                mon_loc="${mon_tty:+, on tty $mon_tty}"
            fi
            status="${LIGHTYELLOW}●${RESET} ${SCRIPT_NAME} monitoring ${GREY}(pid $mon_pid$mon_loc)${RESET}"
        else
            status="${GREEN}○${RESET} idle"
        fi
        # %b on the status field: $status contains dynamic ANSI escapes
        # built via "${COLOR}..." which produce LITERAL backslash bytes
        # at variable expansion time. printf only re-interprets backslash
        # escapes in arguments under %b (not %s).
        printf "${_gap_str}${CYAN}%-3d${RESET} %-${tool_width}s  ${BLUE}%-${target_width}s${RESET}  %b\n" \
            "$i" "$c" "$t" "$status"
        i=$((i + 1))
    done
}

# Identify the AI running in a single, already-known tmux target.
# Mirrors findAiPanes's regex — see the design block above. Keep them in sync.
detectAiNameForTarget() {
    local target="$1"
    local info cmd pane_pid
    info=$(tmux display-message -t "$target" -p '#{pane_current_command}|#{pane_pid}' 2>/dev/null)
    [ -z "$info" ] && return
    cmd="${info%%|*}"
    pane_pid="${info##*|}"
    if [[ "$cmd" =~ ^claude([-.]|$) ]]; then
        echo "claude"
    elif [[ "$cmd" =~ ^codex([-.]|$) ]]; then
        echo "codex"
    elif [[ "$cmd" == "node" ]] && pgrep -P "$pane_pid" -f codex >/dev/null 2>&1; then
        echo "codex"
    else
        echo "$cmd"
    fi
}

# Scan all tmux panes and emit one "<pid>|<target>|<canonical>" line per AI pane.
# See the design block above for the full algorithm and gotchas.
findAiPanes() {
    local panes=()
    local pane_pid pane_target cmd
    while IFS='|' read -r pane_pid pane_target cmd; do
        [ -z "$pane_pid" ] && continue
        if [[ "$cmd" =~ ^claude([-.]|$) ]]; then
            panes+=("$pane_pid|$pane_target|claude")
        elif [[ "$cmd" =~ ^codex([-.]|$) ]]; then
            panes+=("$pane_pid|$pane_target|codex")
        elif [[ "$cmd" == "node" ]] && pgrep -P "$pane_pid" -f codex >/dev/null 2>&1; then
            panes+=("$pane_pid|$pane_target|codex")
        fi
    done < <(tmux list-panes -a -F '#{pane_pid}|#{session_name}:#{window_index}.#{pane_index}|#{pane_current_command}' 2>/dev/null)
    printf '%s\n' "${panes[@]}"
}

# Auto-detect or prompt user to pick a target pane
autoDetectTarget() {
    local panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && panes+=("$line")
    done < <(findAiPanes)

    local count=${#panes[@]}

    if [ "$count" -eq 0 ]; then
        echo -e "${RED}Error: No pane running claude or codex found${RESET}" >&2
        echo -e "${GREY}Start claude/codex in a tmux pane first, or use -t to specify a target.${RESET}" >&2
        echo -e "${GREY}If the tool runs inside another process (e.g. bash), use -t to specify the pane manually.${RESET}" >&2
        exit 1
    elif [ "$count" -eq 1 ]; then
        local pane_pid target cmd
        IFS='|' read -r pane_pid target cmd <<<"${panes[0]}"
        echo -e "${GREEN}Auto-detected:${RESET} ${CYAN}$cmd${RESET} at ${BLUE}$target${RESET}"
        echo -e "${GREY}\nIf a session is missing, use -t to specify it manually.${RESET}"
        fTmuxTarget="$target"
        fAiName="$cmd"
    else
        # echo ""
        # echo -e "${LIGHTYELLOW}Multiple AI sessions found ($count)${RESET}"
        echo ""
        _renderAiTable "${panes[@]}"
        echo ""
        echo -e "${GREY}(If a session is missing, use -t to specify it manually.)${RESET}"
        echo ""
        local _pid
        while true; do
            read -rp "Select target (1-$count): " choice || { echo ""; exit 0; }
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$count" ]; then
                IFS='|' read -r _pid fTmuxTarget fAiName <<<"${panes[$((choice - 1))]}"
                # echo -e "${GREEN}Selected:${RESET} ${BLUE}$fTmuxTarget${RESET}"
                break
            fi
            echo -e "${RED}Invalid choice. Enter a number between 1 and $count.${RESET}"
        done
    fi
}

timestamp() { date '+%H:%M:%S'; }

# Portable hash: Linux has md5sum; macOS has `md5 -r` (GNU-like output).
if command -v md5sum &>/dev/null; then
    _hash() { md5sum | cut -c1-12; }
else
    _hash() { md5 -r | cut -c1-12; }
fi

# Wait (silently) before approving so Ctrl+C still has a window to abort.
applyApproveDelay() {
    if [ "$fApproveDelay" != "0" ]; then
        sleep "$fApproveDelay"
    fi
}

# Poll the pane until its hash differs from oldFp, or maxWaitMs elapses.
# Prints the resulting hash (new on change, old on timeout) to stdout.
# Returns 0 on change, 1 on timeout.
#
# Using a poll instead of a fixed sleep matters because:
#   - Fast render (<200ms): don't waste the rest of a 1s sleep.
#   - Slow render (>1s): don't prematurely declare the keystroke lost
#     and re-send — double-pressing a number key in Claude Code can
#     jump to a different option and approve the wrong thing.
waitForScreenChange() {
    local oldFp="$1"
    local maxWaitMs="${2:-2000}"
    local intervalMs=100
    local elapsedMs=0
    local post postTail fp
    while [ "$elapsedMs" -lt "$maxWaitMs" ]; do
        # Must mirror the loop-start fingerprint computation:
        # capture -> variable (strips trailing blanks) -> echo | tail | hash.
        # A direct pipeline leaves trailing blank lines in and produces a
        # different hash, breaking the compare.
        post=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
        postTail=$(echo "$post" | tail -20)
        fp=$(echo "$postTail" | _hash)
        if [ "$fp" != "$oldFp" ]; then
            printf '%s' "$fp"
            return 0
        fi
        sleep 0.1
        elapsedMs=$((elapsedMs + intervalMs))
    done
    printf '%s' "$oldFp"
    return 1
}

# Check if the pane content contains a blacklisted command
isBlacklisted() {
    local content="$1"
    echo "$content" | grep -q "rm -rf"
}

# Detect a permission prompt in the captured pane tail and return which
# option number to press. Empty output + non-zero exit means "no prompt".
#
# The detector is deliberately STRUCTURAL, not phrase-based: question
# wording keeps changing across Claude Code / Codex CLI versions
# ("Do you want to proceed?", "Do you want to make this edit ...",
# "Allow the <X> MCP server to run tool ...", future variants we can't
# enumerate). Instead we rely on the one visual invariant shared by
# every interactive selection prompt in both tools: a block of numbered
# options with a cursor indicator (❯ or ›) pointing at one of them.
#
# Stage A — "is this a permission prompt at all?"
#   Require BOTH:
#     • at least one numbered line carrying a cursor glyph
#       (e.g. "❯ 1. Yes", "› 1. Allow")
#     • at least two numbered option lines in total (a real menu, not
#       a stray list item)
#   Free-form Claude/Codex response text almost never contains a cursor
#   glyph directly before a numbered line, so this yields ~zero false
#   positives while being wording-agnostic.
#
# Stage B — "which option should we press?"
#   Still filtered by an affirmative word list (Yes|Allow|Accept|
#   Approve|Proceed|Confirm|Continue). That's the safety net: if a
#   future prompt is structurally a menu but has no affirmative option
#   (e.g. a neutral "pick one of these files"), Stage B returns empty
#   and the monitor does nothing instead of blindly pressing "1".
#
# Adding a new affirmative word is the only maintenance knob; adding
# new question phrasings requires no change.
detectPromptOption() {
    local tail="$1"

    # Stage A: structural gate — cursor + 2+ numbered options.
    if ! echo "$tail" | grep -qE '^[[:space:]]*[❯›][[:space:]]*[0-9]+\.'; then
        return 1
    fi
    local numOpts
    numOpts=$(echo "$tail" | grep -cE '^[[:space:]]*[❯›]?[[:space:]]*[0-9]+\.[[:space:]]+[^[:space:]]')
    if [ "$numOpts" -lt 2 ]; then
        return 1
    fi

    # Stage B: pick the best affirmative option, preferring the most
    # persistent form of approval available. Three priority tiers:
    #
    #   Tier 1 — PERMANENT remember. Matches any option whose line
    #            contains both an affirmative word and a "never ask
    #            again" marker:
    #              * "Yes, and don't ask again ..."
    #              * "Yes, and don't ..."
    #              * "Always allow" (Codex)
    #              * "Permanently …", "Forever …"
    #
    #   Tier 2 — SESSION remember. An affirmative option that scopes
    #            itself to the current session:
    #              * "Yes, and allow ... for this session"
    #              * "Allow for this session"
    #
    #   Tier 3 — PLAIN affirmative. Just "Yes" / "Allow" / etc.
    #
    # We walk tiers top-down and stop at the first hit, so for the
    # Claude settings prompt ("1. Yes" / "2. Yes, and allow ... for this
    # session" / "3. No") we correctly pick #2 rather than #1.
    local affirmRe='(Yes|Allow|Accept|Approve|Proceed|Confirm|Continue)'
    local optLineRe='^[[:space:]]*[❯›]?[[:space:]]*[0-9]+\.[[:space:]]+'
    local permanentRe='(don.t ask again|and don|always|permanently|forever)'
    local sessionRe='(for this session|this session|for this)'

    local line
    # Tier 1 — permanent remember
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$permanentRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 2 — session scope
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$sessionRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 3 — plain affirmative
    line=$(echo "$tail" \
        | grep -oE "${optLineRe}${affirmRe}" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi
    return 1
}

# =============================================================================
# AUTO-APPROVE SIGNAL FLOW — high-level view of one mainLoop iteration
# =============================================================================
#
#   tmux pane content
#         │
#         │ capture-pane (every fPollInterval, default 0.3s)
#         ▼
#     last 20 lines
#         │
#         │ _hash
#         ▼
#     12-char fingerprint ─────→ compare against lastHandledFp
#         │                            │
#         │                            └→ equal = screen unchanged → skip
#         │
#         │ tail text
#         ▼
#     detectPromptOption
#         │
#         │ Stage A: structural gate (cursor + ≥2 numbered options)
#         ▼
#     is this a menu?
#         │
#         │ Stage B: 3-tier picker (permanent → session → plain)
#         ▼
#     option number N (1–9)
#         │
#         │ tmux send-keys "N"
#         ▼
#     pane receives key → prompt vanishes → new content appears
#         │
#         │ waitForScreenChange (poll the pane hash, capped at 2s)
#         ▼
#     post-send fingerprint _postFp
#         │
#         │ _postFp != _preSendFp ?  yes → success
#         │                          no  → re-run detector to verify;
#         │                                if prompt still on screen, retry
#         ▼
#     log "✔ Approved (option N)"
#         │
#         ▼
#     lastHandledFp = _preSendFp   (note: NOT _postFp — using post-send
#                                     would dedup-skip the very next
#                                     prompt if Claude/Codex emits one
#                                     during our 2s wait window)
#         │
#         ▼
#     back to capture-pane, next iteration
#
# =============================================================================
mainLoop() {
    # Fingerprint of the screen state we already took action on (approved,
    # blacklist-skipped, or gave up after retries). Top-of-loop dedup skips
    # iterations whose fingerprint matches this — meaning the screen hasn't
    # changed since we handled it, so there's nothing new to do.
    # Empty string at startup so the first iteration always proceeds.
    local lastHandledFp=""

    # Compact two-line banner: title + watch summary on the first line,
    # config + stop hint on the second, single horizontal rule below to
    # mark where the run-time log starts.
    echo ""
    if [ -n "$fAiName" ]; then
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${CYAN}${fAiName}${RESET} ${GREY}→${RESET} ${BLUE}${fTmuxTarget}${RESET}"
    else
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${BLUE}${fTmuxTarget}${RESET}"
    fi
    echo -e "  ${GREY}poll${RESET} ${fPollInterval}s ${GREY}·${RESET} ${GREY}delay${RESET} ${fApproveDelay}s ${GREY}·${RESET} ${GREY}blacklist${RESET} '${LIGHTYELLOW}rm -rf${RESET}' ${GREY}·${RESET} ${GREY}Ctrl+C to stop${RESET}"
    echo -e "${GREY}$(_hr 60)${RESET}"
    echo ""

    while true; do
        local content
        content=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
        if [ $? -ne 0 ]; then
            echo -e "${GREY}[$(timestamp)]${RESET} ${RED}Target pane gone. Exiting.${RESET}"
            break
        fi

        local tail
        tail=$(echo "$content" | tail -20)

        # Fingerprint to avoid double-pressing
        local fingerprint
        fingerprint=$(echo "$tail" | _hash)
        if [ "$fingerprint" = "$lastHandledFp" ]; then
            sleep "$fPollInterval"
            continue
        fi

        # Detect a permission prompt (Claude Code or Codex CLI — same
        # structural shape) and pick the option number to approve.
        local promptOption
        promptOption=$(detectPromptOption "$tail")
        if [ -n "$promptOption" ]; then
            if isBlacklisted "$content"; then
                echo -e "${GREY}[$(timestamp)]${RESET} ${RED}⚠ BLACKLISTED (rm -rf) — skipping${RESET}"
                lastHandledFp="$fingerprint"
                sleep "$fPollInterval"
                continue
            fi
            applyApproveDelay
            # Both Claude Code and Codex CLI (macOS + Linux) accept the
            # option number as a hotkey in the permission prompt. Sending
            # the number selects + submits in one shot, which avoids any
            # dependence on detecting the currently highlighted row.
            #
            # A single send-keys can be lost (pane mid-render, app not yet
            # accepting input, tmux race). Poll waitForScreenChange after
            # each send: react as soon as the pane updates, but wait a full
            # 2s before declaring the key lost. Only then retry, because
            # double-pressing a number key in Claude Code can silently jump
            # to a different option.
            #
            # KNOWN LIMITATION — multi-digit option numbers
            # ─────────────────────────────────────────────
            # detectPromptOption uses [0-9]+ in the regex, so an option
            # numbered "10" or higher would be returned as a multi-char
            # string. tmux send-keys treats each character as a separate
            # keystroke, so passing "10" sends "1" then "0":
            #     - "1" already selects + submits option 1
            #     - "0" lands on whatever state comes next (usually a no-op,
            #       but could land on an unintended target)
            # → wrong option approved.
            #
            # In practice neither Claude Code nor Codex CLI exposes more
            # than ~3 options today, so this hasn't bitten us. If a future
            # version surfaces 10+ options, two possible fixes:
            #   (a) Conservative — clamp the detector to [1-9] and let the
            #       user approve manually when there are more options.
            #   (b) Adaptive — send the digits one-by-one followed by Enter
            #       (`send-keys "$promptOption" Enter`); requires verifying
            #       that Claude/Codex's prompt UI actually accepts that
            #       form (single-digit hotkeys auto-submit, but multi-digit
            #       entry mode may not exist).
            # Until that version ships, this branch trusts that
            # $promptOption is a single ASCII digit.
            local _preSendFp="$fingerprint"
            local _maxRetries=3
            local _attempt=0
            local _postFp="$_preSendFp"
            while true; do
                tmux send-keys -t "$fTmuxTarget" "$promptOption"
                _postFp=$(waitForScreenChange "$_preSendFp" 2000)
                [ "$_postFp" != "$_preSendFp" ] && break

                # Timeout: before re-sending, confirm the prompt is
                # still on-screen. If detectPromptOption returns empty,
                # the keystroke took effect and we only missed the hash
                # change (stable header, tiny diff); treat as success.
                # Only retry when the prompt truly is still visible —
                # this is what prevents a second digit key from landing
                # in a different state and approving the wrong option.
                local _verifyContent _verifyTail
                _verifyContent=$(tmux capture-pane -t "$fTmuxTarget" -p 2>/dev/null)
                _verifyTail=$(echo "$_verifyContent" | tail -20)
                if [ -z "$(detectPromptOption "$_verifyTail")" ]; then
                    _postFp=$(echo "$_verifyTail" | _hash)
                    break
                fi

                _attempt=$((_attempt + 1))
                [ "$_attempt" -ge "$_maxRetries" ] && break
            done
            if [ "$_postFp" = "$_preSendFp" ]; then
                echo -e "${GREY}[$(timestamp)]${RESET} ${RED}⚠ Keystroke dropped (option $promptOption) after $_maxRetries attempts${RESET}"
            else
                fApprovedCount=$((fApprovedCount + 1))
                local _retryNote=""
                [ "$_attempt" -gt 0 ] && _retryNote=" (retry $_attempt)"
                echo -e "${GREY}[$(timestamp)]${RESET} ${GREEN}✔ Approved${RESET} (option $promptOption)${_retryNote} [#$fApprovedCount]"
            fi
            # Track the PRE-send fingerprint, not the post-send one.
            # Rationale: if Claude finishes the approved command quickly and
            # shows the next permission prompt during our wait window,
            # $_postFp captures that new prompt's hash — and the top-of-loop
            # dedup would then skip it forever. Using $_preSendFp ensures
            # dedup only fires when the EXACT prompt we just approved is
            # still on screen (i.e., the keystroke was dropped), while a
            # brand-new prompt has a different hash and is handled normally.
            lastHandledFp="$_preSendFp"
            continue
        fi

        sleep "$fPollInterval"
    done
}

# --- Main ---

parseOptions "$@"

if ! command -v tmux &>/dev/null; then
    echo -e "${RED}Error: tmux is required but not found${RESET}" >&2
    exit 1
fi

if [ -n "$fListOnly" ]; then
    _panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && _panes+=("$line")
    done < <(findAiPanes)

    if [ ${#_panes[@]} -eq 0 ]; then
        echo -e "${RED}No pane running claude or codex found${RESET}"
        exit 0
    fi

    echo ""
    echo -e "${LIGHTYELLOW}AI sessions on tmux server (${#_panes[@]})${RESET}"
    echo ""
    _renderAiTable "${_panes[@]}"
    echo ""
    exit 0
fi

if [ -z "$fTmuxTarget" ]; then
    autoDetectTarget
else
    validateTarget "$fTmuxTarget"
    fAiName=$(detectAiNameForTarget "$fTmuxTarget")
fi

# Build the lockfile path now that fTmuxTarget is finalised.
# Must stay in sync with _monitorPid, which derives the same path from
# the target arg passed in.  Eg: target=M:6.1 → /tmp/ja-M-6-1.lock
fLockFile="/tmp/${SCRIPT_NAME}-${fTmuxTarget//[:.]/-}.lock"

# Prevent two monitor instances from targeting the same pane
if [ -f "$fLockFile" ]; then
    local_pid=$(cat "$fLockFile" 2>/dev/null)
    if kill -0 "$local_pid" 2>/dev/null; then
        _monitor_pane=$(_paneOfPid "$local_pid")
        echo -e "${GREY}${SCRIPT_NAME} is already monitoring ${BLUE}$fTmuxTarget${GREY} (pid ${CYAN}$local_pid${GREY}${_monitor_pane:+, in pane ${CYAN}$_monitor_pane${GREY}}).${RESET}"
        echo -e "${GREY}Kill it first:${RESET} kill $local_pid"
        exit 1
    fi
fi
echo $$ > "$fLockFile"
# Clear the trap before exiting to avoid re-entry: INT calls _cleanup which
# exits, but exiting also fires EXIT — if the trap is still armed, the
# "Stopped" message prints twice.
_cleanup() {
    rm -f "$fLockFile"
    echo -e "\n${GREY}[$(timestamp)]${RESET} Stopped. Approved ${GREEN}$fApprovedCount${RESET} prompts."
    trap - INT TERM EXIT
    exit 0
}
trap '_cleanup' INT TERM EXIT

mainLoop
