#!/usr/bin/env bash
# shellcheck disable=SC2034,SC2155,SC2168
#
# ja — Auto-approve confirmation prompts for Claude Code and Codex CLI
#
# Monitors a tmux pane and sends the affirmative option whenever a known
# permission prompt is detected.
#
# Usage:
#   ja                        # auto-detect the pane running claude/codex
#   ja -t main:0.1            # explicit tmux target (session:window.pane)

SCRIPT_NAME=$(basename "$0")

# Options
fTmuxTarget=      # tmux target pane in session[:window[.pane]] format
fList=            # list detected AI panes and exit
fApproveDelay=0   # seconds to wait before approving
fPollInterval=0.3 # seconds to poll for new prompts
fAiName=          # AI running in the target pane (claude|codex|...)
fApprovedCount=0  # number of prompts approved
fLockFile=        # populated AFTER fTmuxTarget is finalised; see main flow
fVerbose=         # debug logging to stderr
fDaemon=          # 1 = run as a background daemon (--daemon/-D): ja
                  # self-detaches (setsid + own logfile) and returns the
                  # shell prompt. NOT about persistence — persistence
                  # (pause/resume across AI restarts) is always on now,
                  # for foreground and daemon alike.
fStartedTs=       # unix seconds when mainLoop started (for --status uptime)
fHost=            # where ja itself started: "<sess:win.pane>" if launched
                  # inside tmux, "<tty>" if outside tmux but attached to a
                  # terminal, empty string if fully detached (no ctty).
                  # Computed once at mainLoop start by _resolveHostLocation
                  # and frozen — does not track tty changes after launch.
fTargetPaneId=    # tmux pane_id (eg. "%47") — the STABLE identity ja binds
                  # to. Resolved once in resolveTarget from fTmuxTarget (the
                  # -t value or auto-detected pane), then used for every tmux
                  # op (capture-pane / send-keys / display-message), every
                  # runtime file name (lock/log/state), and all lookups.
                  # A pane_id never changes while the pane lives and is never
                  # reused after the pane is destroyed, so ja follows a pane
                  # that is moved/relinked (index changes, pane_id doesn't)
                  # and only exits when the pane is truly gone (capture-pane
                  # fails). fTmuxTarget is kept only as the startup string
                  # used to resolve this; display re-resolves a live index.
fPaused=          # 1 while daemon is paused (no AI in pane); empty otherwise
fStop=            # 1 = --stop:     stop the daemon for the resolved target
fRestart=         # 1 = --restart:  stop then relaunch a daemon for the target
fStatus=          # 1 = --status:   show daemon status (single or all)
fLog=             # 1 = --log:      tail -F the daemon's log file
fLogFull=         # 1 = --log-full: print full log then tail -F it

# =============================================================================
# AI CATALOG — single source of truth for which AIs ja recognises
# =============================================================================
#
# To add support for a new AI tool, append ONE line below:
#
#   "<canonical_name>;<cmd_regex>;<node_pattern>"
#
#   canonical_name  Name shown in output and used by --ai <name>.
#                   Lowercase, alphanumeric, no spaces.
#
#   cmd_regex       Bash extended regex matched against tmux's
#                   pane_current_command. Anchor with `^`. Use `([-.]|$)`
#                   to accept arch-suffixed (e.g. codex-aarch64-a) or
#                   .exe variants.
#
#   node_pattern    If this AI is sometimes distributed as a node script
#                   (so pane_current_command shows "node" instead of the
#                   AI's name), put a pgrep -f pattern here that matches
#                   one of its child process argvs. Empty = no node
#                   fallback. Used only for codex today.
#
# Delimiter is `;` (NOT `|`) because `|` is a regex alternation operator
# and would collide with patterns like `([-.]|$)`.
#
# All detection / filtering / error messages flow through this list via
# _classifyAi / _isKnownAi / _aiNamesPretty — no other place in the script
# hardcodes "claude" or "codex".
fAiCatalog=(
    "claude;^claude([-.]|$);"
    "codex;^codex([-.]|$);codex"
)

# Colors
RED='\033[31m'
GREEN='\033[32m'
MAGENTA='\033[35m'
CYAN='\033[36m'
LIGHTYELLOW='\033[93m'
LIGHTMAGENTA='\033[95m'
GREY='\033[90m'
BLUE='\033[34m'
RESET='\033[0m'

usage() {
    cat << _EOF
Usage: $SCRIPT_NAME [-t session[:window[.pane]]] [OPTIONS]

Auto-approve confirmation prompts for Claude Code and Codex CLI running in a
tmux pane. Monitors the pane screen and sends the affirmative option when a
known permission prompt is detected.

$SCRIPT_NAME binds to the target pane's tmux pane_id (e.g. %47), not its
index, so it keeps monitoring across pane moves/relinks and exits only when
the pane is destroyed (or on Ctrl+C / --stop). Persistence is always on:
when the AI in the pane exits, $SCRIPT_NAME pauses (so it won't spam keys at
the bare shell) and resumes automatically when an AI returns.

Options:
    -h, --help       Show this help message
    -t, --target TARGET
                     Tmux target pane: a pane id (%47) or session[:window
                     [.pane]] (default: auto-detect the pane running an AI)
    -w, --wait SEC   Wait before approving (default: 0, approve immediately)
    -l, --list       List detected AI panes and exit
    -v, --verbose    Print debug info to stderr (detector matches, send-keys
                     events, screen change outcomes)
    -D, --daemon     Run as a background daemon: $SCRIPT_NAME self-detaches
                     (new session, own log file) and returns the prompt.
                     Use '$SCRIPT_NAME -L' to follow its log, '$SCRIPT_NAME
                     --stop' to stop it. (Persistence across AI restarts is
                     the default in every mode, not specific to -D.)

Daemon control (operate on already-running daemons):
    -S, --stop       Stop the daemon monitoring the target pane (default: the
                     current pane; pass -t to stop a specific one). Cleans
                     up stale lockfiles automatically.
    -R, --restart    Stop the daemon for the target pane (if any) and launch
                     a fresh background daemon for it. Handy after upgrading
                     $SCRIPT_NAME. Carries over -w/-v if given; otherwise uses
                     defaults. (default target: current pane; pass -t for one)
    -s, --status     Show all running daemons (summary row + detail block
                     each). Inside tmux, the daemon for the current pane is
                     marked with '*' in the index column.
    -L, --log        Tail -F the daemon's log file (default: current pane;
                     pass -t for a specific one). Ctrl+C to exit.
    --log-full       Like --log, but print the full log first, then follow.
                     Useful for catching up on a long-running daemon.

Supports:
    Claude Code      Numbered options (1. Yes / 2. No) — sends the number
    Codex CLI        Numbered options (1. Yes, proceed) — sends the number

Examples:
    $SCRIPT_NAME                   # auto-detect, run in foreground
    $SCRIPT_NAME -t main:0.1       # target specific pane (by index)
    $SCRIPT_NAME -t %47            # target specific pane (by pane id)
    $SCRIPT_NAME -w 3              # wait 3s before each approval (Ctrl+C to abort)
    $SCRIPT_NAME -s                # see what daemons are running
    $SCRIPT_NAME -L                # follow current pane's daemon log

Stop:
    Press Ctrl+C, run $SCRIPT_NAME -S, or: pkill -f '$SCRIPT_NAME'

_EOF
    exit 0
}

parseOptions() {
    local GETOPT_BIN="getopt"
    if command -v /opt/homebrew/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/opt/homebrew/opt/gnu-getopt/bin/getopt"
    elif command -v /usr/local/opt/gnu-getopt/bin/getopt &> /dev/null; then
        GETOPT_BIN="/usr/local/opt/gnu-getopt/bin/getopt"
    fi

    local SHORTOPTS="ht:w:lvDsSLR"
    local LONGOPTS="help,target:,wait:,list,verbose,daemon,stop,restart,status,log,log-full"

    local PARSED
    if ! PARSED=$("$GETOPT_BIN" --options="$SHORTOPTS" --longoptions="$LONGOPTS" --name "$SCRIPT_NAME" -- "$@"); then
        echo -e "${RED}Failed to parse arguments.${RESET}" >&2
        echo -e "${CYAN}Tip: On macOS, install GNU getopt: ${GREY}brew install gnu-getopt${RESET}" >&2
        exit 1
    fi

    eval set -- "$PARSED"

    while true; do
        case "$1" in
            -h|--help)
                usage
                ;;
            -t|--target)
                fTmuxTarget="$2"
                shift 2
                ;;
            -w|--wait)
                fApproveDelay="$2"
                shift 2
                ;;
            -l|--list)
                fList=1
                shift
                ;;
            -v|--verbose)
                fVerbose=1
                shift
                ;;
            -D|--daemon)
                fDaemon=1
                shift
                ;;
            -S|--stop)
                fStop=1
                shift
                ;;
            -R|--restart)
                fRestart=1
                shift
                ;;
            -s|--status)
                fStatus=1
                shift
                ;;
            -L|--log)
                fLog=1
                shift
                ;;
            --log-full)
                fLogFull=1
                shift
                ;;
            --)
                shift
                break
                ;;
            *)
                echo -e "${RED}Error: Unknown option: $1${RESET}" >&2
                echo "Use $SCRIPT_NAME -h for help." >&2
                exit 1
                ;;
        esac
    done
}

# Path helpers — single source of truth for ja's runtime files.
# All three derive paths from _runtimeDir + a pane_id key (the rule is
# `_idSlug`: strip the leading `%` from the pane_id), so the layout stays
# consistent across lockfile acquisition, --stop, --log, --status, and the
# bashrc wrapper. Keying by pane_id (not the index string) is what lets a
# daemon survive a pane move/relink: the files don't get renamed when the
# index changes.
#
# Eg:  pane_id=%47 → ~/.local/ja/47.lock
#                  → ~/.local/ja/47.log
#                  → ~/.local/ja/47.state.json
#
# Why ~/.local/ja and not /tmp:
#   - macOS's periodic /tmp cleanup (and tmpwatch on some Linux distros)
#     reaps files whose mtime is older than ~3 days. The lockfile is
#     written once at daemon startup and never re-touched, so a
#     long-paused daemon's lockfile got silently reaped — leaving
#     --stop unable to find it while --status (state file, rewritten
#     on every event) still showed it running.
#   - $HOME storage is per-user, persistent, and not subject to any
#     systemwide reaper.
#
# Every site that needs one of these paths must call these helpers —
# never duplicate the path-build expression. Otherwise a future change
# to the directory or sanitisation rule would silently desync.
# Per-user runtime directory holding the lockfile, log file, and state
# JSON for every daemon. mkdir -p is a no-op if the directory already
# exists, so calling it on every path lookup is cheap (one stat).
# Doing it here rather than in writers means even a fresh install can
# `ja -D` without an explicit init step. Failures (rare: $HOME
# readonly, quota) silently fall through; the subsequent open/write
# will surface the real error.
_runtimeDir() {
    local d="${HOME}/.local/${SCRIPT_NAME}"
    mkdir -p "$d" 2>/dev/null
    echo "$d"
}
# Map a pane_id to its filename stem: strip the leading `%` (a pane_id is
# always `%<digits>`, so the result is digit-only — nothing else to
# escape). Keeping the `%` out of the name also sidesteps printf format
# specifiers if a path ever lands in a format string.
_idSlug()        { echo "${1#%}"; }
_lockFilePath()  { echo "$(_runtimeDir)/$(_idSlug "$1").lock"; }
_logFilePath()   { echo "$(_runtimeDir)/$(_idSlug "$1").log"; }
_stateFilePath() { echo "$(_runtimeDir)/$(_idSlug "$1").state.json"; }

# Display helpers — the pane_id is internal (tmux ops + file keys); every
# user-facing string shows the LIVE index location together with the
# pane_id, e.g. "M:1.2 (%47)". The index is re-resolved on each call so it
# reflects where the pane is right now (after a move it updates; the
# pane_id stays constant).
#
# _liveLocation: pane_id (defaults to fTargetPaneId) -> "session:window.pane",
#                empty if the pane is gone.
# _targetLabel:  "index (pane_id)" when resolvable, else the bare pane_id
#                (the only case a bare id shows: the pane no longer exists).
_liveLocation() { tmux display-message -t "${1:-$fTargetPaneId}" -p '#{session_name}:#{window_index}.#{pane_index}' 2>/dev/null; }
_targetLabel()  {
    local id="${1:-$fTargetPaneId}" loc
    loc=$(_liveLocation "$id")
    if [ -n "$loc" ]; then echo "$loc ($id)"; else echo "$id"; fi
}

# Pretty box rendering for the daemon startup banner.
#
# _boxRow LABEL VALUE_PLAIN VALUE_COLORED — emit one "plain<TAB>colored"
# entry for _drawBox: a 2-space indent, the label padded to a fixed column
# (grey), then the value. The plain half drives width/alignment; the
# colored half is what's displayed.
_boxRow() {
    local lp; printf -v lp '%-6s' "$1"
    printf '%s\t%s' "  ${lp} $2" "  ${GREY}${lp}${RESET} $3"
}

# _drawBox TITLE_PLAIN TITLE_COLORED ROW... — draw a rounded-corner box
# sized to the widest line. Rows are "plain<TAB>colored" (see _boxRow).
# Alignment is computed from the plain text only, so the embedded ANSI
# colour escapes never skew the right border. Rendered via echo -e (the
# colour vars carry literal \033 sequences, as elsewhere in the script).
_drawBox() {
    local titlePlain="$1" titleColored="$2"; shift 2
    local entries=("$@")
    local maxw=${#titlePlain} e p sp rule
    for e in "${entries[@]}"; do p="${e%%$'\t'*}"; [ ${#p} -gt "$maxw" ] && maxw=${#p}; done
    rule=$(_hr "$((maxw + 2))")
    echo -e "${GREY}╭${rule}╮${RESET}"
    printf -v sp '%*s' "$((maxw - ${#titlePlain}))" ''
    echo -e "${GREY}│${RESET} ${titleColored}${sp} ${GREY}│${RESET}"
    for e in "${entries[@]}"; do
        p="${e%%$'\t'*}"
        printf -v sp '%*s' "$((maxw - ${#p}))" ''
        echo -e "${GREY}│${RESET} ${e#*$'\t'}${sp} ${GREY}│${RESET}"
    done
    echo -e "${GREY}╰${rule}╯${RESET}"
}

# Write a state snapshot for --status to read. Called from mainLoop on
# every notable event (start, approve, paused, resumed, dropped).
#
# Schema:
#   {
#     "pid":              <int>,
#     "target":           "<session:window.pane>",   # live index at write time
#     "ai":               "<claude|codex|...>",
#     "daemon":           <0|1>,                  # 1 = launched as bg daemon
#     "started_ts":       <unix seconds>,
#     "approved_count":   <int>,
#     "paused":           <true|false>,
#     "last_event_ts":    <unix seconds>,
#     "last_event_type":  "<start|approve|paused|resumed|dropped|plan_review|moved>",
#     "log_file":         "<runtime_dir>/<sanitized>.log",
#     "host":             "<sess:win.pane>" | "<tty>" | "",  # see fHost
#     "target_pane_id":   "<%N>"                              # see fTargetPaneId
#   }
#
# Written via mv-from-tmp for atomic replacement; readers see either the
# old snapshot or the new one, never half-written content.
#
# Globals consumed: fTargetPaneId (the file key + live-location source),
#                   fTmuxTarget (startup-string fallback for target),
#                   fAiName, fDaemon,
#                   fStartedTs (set in mainLoop start), fApprovedCount,
#                   fPaused (toggled by mainLoop paused/resumed handling),
#                   fHost (frozen at mainLoop start by _resolveHostLocation),
#                   fTargetPaneId (resolved in resolveTarget).
#
# Arg 1 is the event type that triggered this write (one of the strings
# listed in the schema). It updates last_event_type/ts but doesn't
# otherwise gate the write.
_writeState() {
    local event="$1"
    [ -n "$fTargetPaneId" ] || return 0   # nothing to write before resolveTarget
    local sf=$(_stateFilePath "$fTargetPaneId")
    local lf=$(_logFilePath "$fTargetPaneId")
    local now=$(date +%s)
    # "target" records the pane's live index location at write time, so
    # --status shows where the pane is right now even after a move. Fall
    # back to the startup string if the pane can't be resolved (gone).
    local loc=$(_liveLocation "$fTargetPaneId")
    [ -z "$loc" ] && loc="$fTmuxTarget"
    local paused_str="false"
    [ -n "$fPaused" ] && paused_str="true"
    local daemon_int=0
    [ -n "$fDaemon" ] && daemon_int=1
    # Use a tmpfile + mv for atomic replacement. Suffix with $$ so two ja
    # processes can't collide on the same tmpname (paranoia — they'd be
    # blocked by the lockfile check anyway).
    local tmp="${sf}.tmp.$$"
    printf '{\n  "pid": %d,\n  "target": "%s",\n  "ai": "%s",\n  "daemon": %d,\n  "started_ts": %s,\n  "approved_count": %d,\n  "paused": %s,\n  "last_event_ts": %d,\n  "last_event_type": "%s",\n  "log_file": "%s",\n  "host": "%s",\n  "target_pane_id": "%s"\n}\n' \
        "$$" \
        "$loc" \
        "${fAiName//\"/\\\"}" \
        "$daemon_int" \
        "${fStartedTs:-$now}" \
        "${fApprovedCount:-0}" \
        "$paused_str" \
        "$now" \
        "$event" \
        "$lf" \
        "${fHost//\"/\\\"}" \
        "${fTargetPaneId//\"/\\\"}" \
        > "$tmp" 2>/dev/null \
        && mv -f "$tmp" "$sf" 2>/dev/null
    rm -f "$tmp" 2>/dev/null
    return 0   # never let state-write failure kill ja
}

# Validate a tmux target exists by resolving it to a pane_id. This accepts
# both the index form (`M:2.1`) and a literal pane_id (`%47`) passed to -t,
# and is more precise than the old has-session string-splitting (which
# couldn't handle a `%N` target and only checked the session, not the pane).
validateTarget() {
    local target="$1"
    if [ -z "$(tmux display-message -t "$target" -p '#{pane_id}' 2>/dev/null)" ]; then
        echo -e "${RED}Error: tmux target '$target' not found${RESET}" >&2
        exit 1
    fi
}

# Return the pid of a live monitor process currently watching `target`,
# or empty (with non-zero exit) if no live monitor exists.
#
# Tries two sources, in order:
#   1. Lockfile — fast path, written once at daemon startup with $$.
#   2. State file's "pid" field — defensive fallback. The state file
#      is rewritten on every event by _writeState, the lockfile is
#      written exactly once. If something deletes the lockfile out
#      from under a running daemon (manual `rm`, accidental cleanup
#      script, etc.), the state file still has the truth — falling
#      back here keeps --stop / --status / --list / acquireLockfile
#      honest instead of silently treating the daemon as gone.
_monitorPid() {
    local target="$1"
    local lockfile=$(_lockFilePath "$target")
    local statefile=$(_stateFilePath "$target")
    local pid=""
    if [ -f "$lockfile" ]; then
        pid=$(cat "$lockfile" 2>/dev/null)
    fi
    if [ -z "$pid" ] && [ -f "$statefile" ]; then
        pid=$(_readStateField "$statefile" pid)
    fi
    # Legacy fallback: no pane-id-keyed files, so look for a state file
    # recording this pane_id (index-keyed files from a pre-upgrade daemon)
    # and read its pid from the sibling lockfile / state pid field.
    if [ -z "$pid" ]; then
        local _sf _lf
        if _sf=$(_stateFileForPane "$target") && [ -n "$_sf" ]; then
            _lf="${_sf%.state.json}.lock"
            [ -f "$_lf" ] && pid=$(cat "$_lf" 2>/dev/null)
            [ -z "$pid" ] && pid=$(_readStateField "$_sf" pid)
        fi
    fi
    [ -n "$pid" ] || return 1
    kill -0 "$pid" 2>/dev/null || return 1
    echo "$pid"
}

# Return the tty name of a pid (e.g. "pts/4"), or empty (with non-zero
# exit) if the pid has no controlling tty or doesn't exist. The "?"
# value in ps output means "no controlling tty" (daemons, detached
# processes); we treat that as no tty.
_ttyOfPid() {
    local pid="$1"
    [ -n "$pid" ] || return 1
    local tty
    tty=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d '[:space:]')
    [ -n "$tty" ] && [ "$tty" != "?" ] || return 1
    printf '%s' "$tty"
}

# Return the tmux target (session:window.pane) that a pid is running in,
# or empty if the pid isn't attached to a tmux pane (e.g. a plain shell
# without tmux, or the pid has died). Works by matching the pid's tty
# against tmux's pane_tty list.
_paneOfPid() {
    local pid="$1"
    local tty
    tty=$(_ttyOfPid "$pid") || return 1
    tmux list-panes -a -F '#{pane_tty} #{session_name}:#{window_index}.#{pane_index}' 2>/dev/null \
        | awk -v t="/dev/$tty" '$1==t{print $2; exit}'
}

# Determine where THIS ja process was launched from. Returns:
#   • "<sess:win.pane>" — launched inside tmux and its tty maps to a pane
#   • "<tty>"           — launched outside tmux but attached to a terminal
#   • ""                — fully detached (no controlling tty)
#
# Called once at mainLoop start; the result is frozen into $fHost and
# written to the state file. We deliberately do NOT re-check at each
# event — host as recorded means "where ja was started", not "where it's
# attached right now". Runtime tty migration / re-parenting is rare and
# tracking it would bloat the schema for no real value.
_resolveHostLocation() {
    # Try pane mapping first (only meaningful inside tmux).
    if [ -n "$TMUX" ]; then
        local pane
        pane=$(_paneOfPid $$)
        if [ -n "$pane" ]; then
            printf '%s' "$pane"
            return 0
        fi
    fi
    # Fallback: bare tty (terminal outside tmux, or tmux pane lookup failed).
    local tty
    tty=$(_ttyOfPid $$)
    if [ -n "$tty" ]; then
        printf '%s' "$tty"
        return 0
    fi
    # Truly detached — no ctty. Return empty (caller will treat as "daemon").
    return 1
}

# Build a horizontal rule of N `─` characters. printf's %s precision
# works on bytes (not characters) and `─` is multibyte UTF-8, so we
# build the rule by repeated concatenation instead.
_hr() {
    local n="$1" out=""
    while [ "$n" -gt 0 ]; do out+="─"; n=$((n - 1)); done
    printf '%s' "$out"
}

# Render the standard "AI sessions" table given a list of
# "pid|target|pane_id|name" lines as positional args. Used by both the `-l`
# listing block and autoDetectTarget's multi-session picker so the two stay
# visually in sync.
#
# Output: header row, separator row, then one row per pane. Columns: index,
# Tool, Target (index location), Pane (pane_id — the stable identity ja
# binds to), and Status (whether a monitor is already watching that pane).
#
# Usage: _renderAiTable "${panes[@]}"
_renderAiTable() {
    local panes=("$@")
    local pid t paneid c
    local tool_width=4    # min "Tool"
    local target_width=6  # min "Target"
    local pane_width=4    # min "Pane"
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t paneid c <<<"$p"
        [ ${#c} -gt "$tool_width" ] && tool_width=${#c}
        [ ${#t} -gt "$target_width" ] && target_width=${#t}
        [ ${#paneid} -gt "$pane_width" ] && pane_width=${#paneid}
    done

    local _gap_str=""
    printf "${_gap_str}${GREY}%-3s %-${tool_width}s  %-${target_width}s  %-${pane_width}s  %s${RESET}\n" \
        "#" "Tool" "Target" "Pane" "Status"
    printf "${_gap_str}${GREY}%s %s  %s  %s  %s${RESET}\n" \
        "$(_hr 3)" "$(_hr "$tool_width")" "$(_hr "$target_width")" "$(_hr "$pane_width")" "$(_hr 22)"

    local i=1 mon_pid mon_pane mon_tty mon_loc status p
    for p in "${panes[@]}"; do
        IFS='|' read -r pid t paneid c <<<"$p"
        mon_pid=$(_monitorPid "$paneid")
        if [ -n "$mon_pid" ]; then
            # Two-tier location lookup:
            #   1. Try to map the monitor pid to a tmux target (best case;
            #      user can jump there with `tmux switch -t <addr>`).
            #   2. Fall back to the bare tty if the monitor is running
            #      outside tmux (still useful — tells the user which
            #      terminal owns the process).
            #   3. If neither resolves (detached / nohup'd), suppress the
            #      suffix entirely via ${var:+text}.
            mon_pane=$(_paneOfPid "$mon_pid")
            if [ -n "$mon_pane" ]; then
                mon_loc=", from $mon_pane"
            else
                mon_tty=$(_ttyOfPid "$mon_pid")
                mon_loc="${mon_tty:+, on tty $mon_tty}"
            fi
            status="${LIGHTYELLOW}●${RESET} ${SCRIPT_NAME} monitoring ${GREY}(pid $mon_pid$mon_loc)${RESET}"
        else
            status="${GREEN}○${RESET} idle"
        fi
        # %b on the status field: $status contains dynamic ANSI escapes
        # built via "${COLOR}..." which produce LITERAL backslash bytes
        # at variable expansion time. printf only re-interprets backslash
        # escapes in arguments under %b (not %s).
        printf "${_gap_str}${CYAN}%-3d${RESET} %-${tool_width}s  ${BLUE}%-${target_width}s${RESET}  ${CYAN}%-${pane_width}s${RESET}  %b\n" \
            "$i" "$c" "$t" "$paneid" "$status"
        i=$((i + 1))
    done
}

# Catalog accessors — every AI-detection / filtering / error path goes
# through these so adding a new AI only touches fAiCatalog.

# Classify a (cmd, pane_pid) pair against the catalog.
# Prints the canonical name on match, nothing on miss; returns 0/1 to match.
_classifyAi() {
    local cmd="$1" pane_pid="$2"
    local entry name regex node_pat
    # Direct match: cmd's name pattern
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name regex node_pat <<<"$entry"
        if [[ "$cmd" =~ $regex ]]; then
            echo "$name"
            return 0
        fi
    done
    # Indirect match: cmd is "node", but a child process matches an AI's
    # node_pattern (e.g. codex shipped as node script).
    if [ "$cmd" = "node" ]; then
        for entry in "${fAiCatalog[@]}"; do
            IFS=';' read -r name regex node_pat <<<"$entry"
            [ -z "$node_pat" ] && continue
            if pgrep -P "$pane_pid" -f "$node_pat" >/dev/null 2>&1; then
                echo "$name"
                return 0
            fi
        done
    fi
    return 1
}

# True if `name` is one of the canonical names in the catalog.
_isKnownAi() {
    local target="$1"
    local entry name rest
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name rest <<<"$entry"
        [ "$name" = "$target" ] && return 0
    done
    return 1
}

# Render the catalog's canonical names as a natural-language list:
#   1 entry  → "claude"
#   2 entries → "claude or codex"
#   3+       → "claude, codex, or gemini"
# Used in error messages to keep them in sync with the catalog.
_aiNamesPretty() {
    local entry name rest
    local names=()
    for entry in "${fAiCatalog[@]}"; do
        IFS=';' read -r name rest <<<"$entry"
        names+=("$name")
    done
    local n=${#names[@]}
    case "$n" in
        0) echo "(no AIs configured)" ;;
        1) echo "${names[0]}" ;;
        2) echo "${names[0]} or ${names[1]}" ;;
        *)
            local out="${names[0]}" i
            for ((i = 1; i < n - 1; i++)); do
                out="$out, ${names[i]}"
            done
            echo "$out, or ${names[n - 1]}"
            ;;
    esac
}

# Identify the AI running in a single, already-known tmux target.
# Returns the canonical AI name on match, the raw cmd otherwise (so the
# fallback path in autoDetectTarget's banner can still display something
# useful for non-AI panes the user manually targeted).
detectAiNameForTarget() {
    local target="$1"
    local info cmd pane_pid matched
    info=$(tmux display-message -t "$target" -p '#{pane_current_command}|#{pane_pid}' 2>/dev/null)
    [ -z "$info" ] && return
    cmd="${info%%|*}"
    pane_pid="${info##*|}"
    matched=$(_classifyAi "$cmd" "$pane_pid")
    if [ -n "$matched" ]; then
        echo "$matched"
    else
        echo "$cmd"
    fi
}

# Scan all tmux panes and emit one "<pid>|<target>|<pane_id>|<canonical>"
# line per AI pane. The pane_id field (added for pane-id binding) is what
# consumers key files / lookups on; the target index is kept for display.
findAiPanes() {
    local panes=()
    local pane_pid pane_target pane_id cmd matchedAi
    while IFS='|' read -r pane_pid pane_target pane_id cmd; do
        [ -z "$pane_pid" ] && continue
        matchedAi=$(_classifyAi "$cmd" "$pane_pid")
        [ -z "$matchedAi" ] && continue
        panes+=("$pane_pid|$pane_target|$pane_id|$matchedAi")
    done < <(tmux list-panes -a -F '#{pane_pid}|#{session_name}:#{window_index}.#{pane_index}|#{pane_id}|#{pane_current_command}' 2>/dev/null)
    printf '%s\n' "${panes[@]}"
}

# Auto-detect or prompt user to pick a target pane
autoDetectTarget() {
    local panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && panes+=("$line")
    done < <(findAiPanes)

    local count=${#panes[@]}

    if [ "$count" -eq 0 ]; then
        echo -e "${RED}Error: No pane running $(_aiNamesPretty) found${RESET}" >&2
        echo -e "${GREY}Start an AI tool in a tmux pane first, or use -t to specify a target.${RESET}" >&2
        echo -e "${GREY}If the tool runs inside another process (e.g. bash), use -t to specify the pane manually.${RESET}" >&2
        exit 1
    elif [ "$count" -eq 1 ]; then
        local pane_pid target paneid cmd
        IFS='|' read -r pane_pid target paneid cmd <<<"${panes[0]}"
        echo -e "${GREEN}Auto-detected:${RESET} ${CYAN}$cmd${RESET} at ${BLUE}$target${RESET} ${GREY}($paneid)${RESET}"
        echo -e "${GREY}\nIf a session is missing, use -t to specify it manually.${RESET}"
        fTmuxTarget="$target"
        fTargetPaneId="$paneid"
        fAiName="$cmd"
    else
        # echo ""
        # echo -e "${LIGHTYELLOW}Multiple AI sessions found ($count)${RESET}"
        echo ""
        _renderAiTable "${panes[@]}"
        echo ""
        echo -e "${GREY}(If a session is missing, use -t to specify it manually.)${RESET}"
        echo ""
        local _pid
        while true; do
            read -rp "Select target (1-$count): " choice || { echo ""; exit 0; }
            if [[ "$choice" =~ ^[0-9]+$ ]] && [ "$choice" -ge 1 ] && [ "$choice" -le "$count" ]; then
                IFS='|' read -r _pid fTmuxTarget fTargetPaneId fAiName <<<"${panes[$((choice - 1))]}"
                # echo -e "${GREEN}Selected:${RESET} ${BLUE}$fTmuxTarget${RESET}"
                break
            fi
            echo -e "${RED}Invalid choice. Enter a number between 1 and $count.${RESET}"
        done
    fi
}

timestamp() { date '+%Y-%m-%d %H:%M:%S'; }

# Single source of truth for log timestamp prefix. Full date because
# long-running daemons cross day boundaries (bare HH:MM:SS would be
# ambiguous in `ja --log-full`). _log / _dbg / _dbgBlock all route
# through here, so one timestamp() change updates every log surface.
# Body is echo -e'd verbatim — callers can embed ${COLOR} freely.
_log() {
    echo -e "${GREY}[$(timestamp)]${RESET} $*"
}

# Portable hash: Linux has md5sum; macOS has `md5 -r` (GNU-like output).
if command -v md5sum &>/dev/null; then
    _hash() { md5sum | cut -c1-12; }
else
    _hash() { md5 -r | cut -c1-12; }
fi

# Debug logging — only emits when -v/--verbose was passed. Output goes to
# stderr so it doesn't get tangled with the script's normal stdout (the
# approval log lines, banner, etc.).
_dbg() {
    [ -n "$fVerbose" ] || return 0
    echo -e "${GREY}[$(timestamp)] [DBG]${RESET} $*" >&2
}

# Multi-line dbg: dump a labelled block of content with `│ ` prefix so it's
# visually distinct from normal log lines. Read content from stdin so the
# caller can pipe / heredoc / `<<<` it.
_dbgBlock() {
    [ -n "$fVerbose" ] || return 0
    local label="$1"
    echo -e "${GREY}[$(timestamp)] [DBG]${RESET} $label" >&2
    while IFS= read -r _line; do
        echo "    │ $_line" >&2
    done
}

# Wait (silently) before approving so Ctrl+C still has a window to abort.
applyApproveDelay() {
    if [ "$fApproveDelay" != "0" ]; then
        sleep "$fApproveDelay"
    fi
}

# Poll the pane until its hash differs from oldFp, or maxWaitMs elapses.
# Prints the resulting hash (new on change, old on timeout) to stdout.
# Returns 0 on change, 1 on timeout.
#
# Using a poll instead of a fixed sleep matters because:
#   - Fast render (<200ms): don't waste the rest of a 1s sleep.
#   - Slow render (>1s): don't prematurely declare the keystroke lost
#     and re-send — double-pressing a number key in Claude Code can
#     jump to a different option and approve the wrong thing.
waitForScreenChange() {
    local oldFp="$1"
    local maxWaitMs="${2:-2000}"
    local intervalMs=100
    local elapsedMs=0
    local post postTail fp
    while [ "$elapsedMs" -lt "$maxWaitMs" ]; do
        # Must mirror the loop-start fingerprint computation:
        # capture -> variable (strips trailing blanks) -> echo | tail | hash.
        # A direct pipeline leaves trailing blank lines in and produces a
        # different hash, breaking the compare.
        post=$(tmux capture-pane -t "$fTargetPaneId" -p 2>/dev/null)
        postTail=$(echo "$post" | tail -20)
        fp=$(echo "$postTail" | _hash)
        if [ "$fp" != "$oldFp" ]; then
            printf '%s' "$fp"
            return 0
        fi
        sleep 0.1
        elapsedMs=$((elapsedMs + intervalMs))
    done
    printf '%s' "$oldFp"
    return 1
}

# Detect a permission prompt in the captured pane tail and return which
# option number to press. Empty output + non-zero exit means "no prompt".
#
# The detector is deliberately STRUCTURAL, not phrase-based: question
# wording keeps changing across Claude Code / Codex CLI versions
# ("Do you want to proceed?", "Do you want to make this edit ...",
# "Allow the <X> MCP server to run tool ...", future variants we can't
# enumerate). Instead we rely on the one visual invariant shared by
# every interactive selection prompt in both tools: a block of numbered
# options with a cursor indicator (❯ or ›) pointing at one of them.
#
# Stage A — "is this a permission prompt at all?"
#   Require BOTH:
#     • at least one numbered line carrying a cursor glyph
#       (e.g. "❯ 1. Yes", "› 1. Allow")
#     • at least two numbered option lines in total (a real menu, not
#       a stray list item)
#   Free-form Claude/Codex response text almost never contains a cursor
#   glyph directly before a numbered line, so this yields ~zero false
#   positives while being wording-agnostic.
#
# Stage B — "which option should we press?"
#   Still filtered by an affirmative word list (Yes|Allow|Accept|
#   Approve|Proceed|Confirm|Continue). That's the safety net: if a
#   future prompt is structurally a menu but has no affirmative option
#   (e.g. a neutral "pick one of these files"), Stage B returns empty
#   and the monitor does nothing instead of blindly pressing "1".
#
# Adding a new affirmative word is the only maintenance knob; adding
# new question phrasings requires no change.
#
# PLAN-REVIEW GUARD
# ─────────────────
# Claude Code's "exit plan mode" prompt is structurally a normal
# numbered menu whose option 1 is "Yes, auto-accept edits". Without
# special handling, Tier 3 would happily press 1 and Claude would
# leave plan mode and start executing — defeating the whole point of
# plan mode (user review before action).
#
# isPlanReviewPrompt() is the dedicated detector. It looks for the
# distinctive sentence "Claude has written up a plan and is ready to
# execute", which appears verbatim in this prompt and nowhere else.
# Called from mainLoop BEFORE detectPromptOption so the auto-approve
# path is bypassed entirely; mainLoop then logs a WARN and waits for
# the user to choose manually.
isPlanReviewPrompt() {
    local tail="$1"
    # Precise marker — the full lead sentence of Claude Code's exit-
    # plan-mode prompt. Matched verbatim on exact punctuation but
    # case-insensitive (so a banner-cased or lowercased rendering
    # still triggers). The whole sentence (not just a fragment) is
    # required, so casual mentions of "plan" elsewhere won't trip
    # this. If Claude Code ever rewords the sentence, the WARN will
    # silently stop firing and ja will fall back to its normal
    # auto-approve behaviour — update this string when that happens.
    if echo "$tail" | grep -qiF 'Claude has written up a plan and is ready to execute. Would you like to proceed?'; then
        return 0
    fi
    return 1
}

detectPromptOption() {
    local tail="$1"

    # Glyphs that may prefix an option line:
    #   • cursor selectors  ❯ ›   — mark the currently highlighted row
    #   • scroll indicators ↑ ↓   — shown by Claude's newer prompt UI when
    #                               the option list is scrollable (e.g.
    #                               "↓ 2. Yes, and don't ask again …")
    # The structural gate still REQUIRES a real cursor (❯/›) so random
    # numbered text isn't mistaken for a menu, but the option count and the
    # Stage-B picker must also accept the scroll arrows — otherwise a
    # scrolled option isn't counted (menu looks like it has <2 options) and
    # ja silently does nothing. This was a real miss: WebFetch's
    # "› 1. Yes / ↓ 2. Yes, and don't ask again" went unapproved.

    # Stage A: structural gate — a real cursor on a numbered line.
    if ! echo "$tail" | grep -qE '^[[:space:]]*[❯›][[:space:]]*[0-9]+\.'; then
        return 1
    fi
    # …plus 2+ numbered options total (cursor OR scroll-arrow prefixes ok).
    local numOpts
    numOpts=$(echo "$tail" | grep -cE '^[[:space:]]*[❯›↑↓]?[[:space:]]*[0-9]+\.[[:space:]]+[^[:space:]]')
    if [ "$numOpts" -lt 2 ]; then
        return 1
    fi

    # Stage B: pick the best affirmative option, preferring the most
    # persistent form of approval available. Three priority tiers:
    #
    #   Tier 1 — PERMANENT remember. Matches any option whose line
    #            contains both an affirmative word and a "never ask
    #            again" marker:
    #              * "Yes, and don't ask again ..."
    #              * "Yes, and don't ..."
    #              * "Always allow" (Codex)
    #              * "Permanently …", "Forever …"
    #
    #   Tier 2 — SESSION remember. An affirmative option that scopes
    #            itself to the current session:
    #              * "Yes, and allow ... for this session"
    #              * "Allow for this session"
    #
    #   Tier 3 — PLAIN affirmative. Just "Yes" / "Allow" / etc.
    #
    # We walk tiers top-down and stop at the first hit, so for the
    # Claude settings prompt ("1. Yes" / "2. Yes, and allow ... for this
    # session" / "3. No") we correctly pick #2 rather than #1.
    local affirmRe='(Yes|Allow|Accept|Approve|Proceed|Confirm|Continue)'
    # Option-line prefix: optional cursor (❯ ›) or scroll arrow (↑ ↓), so a
    # scrolled affirmative line is still matched by the tier picker.
    local optLineRe='^[[:space:]]*[❯›↑↓]?[[:space:]]*[0-9]+\.[[:space:]]+'
    local permanentRe='(don.t ask again|and don|always|permanently|forever)'
    local sessionRe='(for this session|this session|for this)'

    local line
    # Tier 1 — permanent remember
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$permanentRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 2 — session scope
    line=$(echo "$tail" \
        | grep -E "$optLineRe" \
        | grep -iE "$sessionRe" \
        | grep -iE "$affirmRe" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi

    # Tier 3 — plain affirmative
    line=$(echo "$tail" \
        | grep -oE "${optLineRe}${affirmRe}" \
        | head -1)
    if [ -n "$line" ] && [[ "$line" =~ [0-9]+ ]]; then
        echo "${BASH_REMATCH[0]}"
        return 0
    fi
    return 1
}

# =============================================================================
# AUTO-APPROVE SIGNAL FLOW — high-level view of one mainLoop iteration
# =============================================================================
#
#   tmux pane content
#         │
#         │ capture-pane (every fPollInterval, default 0.3s)
#         ▼
#     last 20 lines
#         │
#         │ _hash
#         ▼
#     12-char fingerprint ─────→ compare against lastHandledFp
#         │                            │
#         │                            └→ equal = screen unchanged → skip
#         │
#         │ tail text
#         ▼
#     isPlanReviewPrompt ──► yes → log WARN, mark fp handled, skip
#         │ no
#         ▼
#     detectPromptOption
#         │
#         │ Stage A: structural gate (cursor + ≥2 numbered options)
#         ▼
#     is this a menu?
#         │
#         │ Stage B: 3-tier picker (permanent → session → plain)
#         ▼
#     option number N (1–9)
#         │
#         │ tmux send-keys "N"
#         ▼
#     pane receives key → prompt vanishes → new content appears
#         │
#         │ waitForScreenChange (poll the pane hash, capped at 2s)
#         ▼
#     post-send fingerprint _postFp
#         │
#         │ _postFp != _preSendFp ?  yes → success
#         │                          no  → re-run detector to verify;
#         │                                if prompt still on screen, retry
#         ▼
#     log "✔ Approved (option N)"
#         │
#         ▼
#     lastHandledFp = _preSendFp   (note: NOT _postFp — using post-send
#                                     would dedup-skip the very next
#                                     prompt if Claude/Codex emits one
#                                     during our 2s wait window)
#         │
#         ▼
#     back to capture-pane, next iteration
#
# =============================================================================
mainLoop() {
    # Fingerprint of the screen state we already took action on (approved,
    # or gave up after retries). Top-of-loop dedup skips iterations whose
    # fingerprint matches this — meaning the screen hasn't changed since
    # we handled it, so there's nothing new to do.
    # Empty string at startup so the first iteration always proceeds.
    local lastHandledFp=""

    # Plan-review "already warned" latch. Fingerprint dedup alone isn't
    # enough here: when the user picks option 4 ("Tell Claude what to
    # change"), Claude Code opens an inline text box. Every keystroke
    # changes the captured tail → new fingerprint → dedup fails → the
    # WARN line fires on every keypress, even though the trigger
    # sentence is still sitting above the input box. This latch trips
    # on the first plan-review hit, suppresses subsequent ones, and is
    # cleared the moment isPlanReviewPrompt stops matching (i.e. the
    # prompt is gone from the screen). Reset on daemon resume so a
    # plan-review that was on screen when we paused gets re-announced.
    local lastPlanReviewLogged=""

    # Daemon-mode pause flag (global so --status / _writeState can read it).
    # Set when the pane is currently running something we don't monitor
    # (bash, filtered-out AI). Cleared the next iteration we see a known
    # AI again — the transition from set → unset is what triggers the
    # "Resumed" log line, regardless of whether the AI that came back has
    # the same name as the original ($fAiName unchanged) or a different
    # one ($fAiName updated).
    fPaused=""

    # Record start time for --status uptime calculation, freeze where ja
    # was launched (host pane / tty / detached), and write an initial state
    # snapshot so --status can answer "is daemon up?" the very next
    # moment after we launch (don't wait for first event). fTargetPaneId is
    # already resolved by resolveTarget — the stable pane_id we bind to.
    fStartedTs=$(date +%s)
    fHost=$(_resolveHostLocation || true)
    # Track the pane's live index location so we can log relink/move events
    # (the pane_id is constant; only the session:window.pane index changes).
    local lastLoc=$(_liveLocation "$fTargetPaneId")
    _writeState start

    # Compact two-line banner: title + watch summary on the first line,
    # config + stop hint on the second, single horizontal rule below to
    # mark where the run-time log starts. Rule width tracks the wider of
    # the two banner lines plus a small overshoot so the underline always
    # extends a few cells past the last visible glyph — gives the banner
    # an obvious "this is the bottom edge" feel instead of butting flush
    # against text (which can read as accidental wrap). The overshoot
    # also absorbs minor variation: a long $fTmuxTarget or the optional
    # "· daemon" suffix can push lines past the old hardcoded 60 cols
    # without truncating the rule. bash's ${#var} counts UTF-8 code
    # points correctly under a UTF-8 locale, so the multi-byte glyphs
    # (▶ → · ─) measure as 1 column each — matching their rendered width.
    local _line1Plain _line2Plain _daemonNotePlain=""
    local _targetLabel=$(_targetLabel)
    echo
    if [ -n "$fAiName" ]; then
        _line1Plain="▶ ${SCRIPT_NAME} AUTO-APPROVE · ${fAiName} → ${_targetLabel}"
    else
        _line1Plain="▶ ${SCRIPT_NAME} AUTO-APPROVE · ${_targetLabel}"
    fi
    [ -n "$fDaemon" ] && _daemonNotePlain=" · daemon"
    _line2Plain="  poll ${fPollInterval}s · delay ${fApproveDelay}s${_daemonNotePlain} · Ctrl+C to stop"
    local _ruleW=${#_line1Plain}
    [ ${#_line2Plain} -gt "$_ruleW" ] && _ruleW=${#_line2Plain}
    # Overshoot: 4 cells past the widest visible content. Small enough
    # that the rule still reads as "tight" framing for the banner, large
    # enough that the underline is clearly separated from the trailing
    # word at the eye-flick scale. Matches the visual rhythm jc/jmake
    # use for similar two-line banners.
    _ruleW=$((_ruleW + 4))

    # No leading blank line — the banner is the very first thing in the
    # log file and a leading blank reads as "ja --log silently ate a
    # line" when the user runs it. Trailing blank below stays (it
    # visually separates the banner from the run-time events).
    if [ -n "$fAiName" ]; then
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${CYAN}${fAiName}${RESET} ${GREY}→${RESET} ${BLUE}${_targetLabel}${RESET}"
    else
        echo -e "${MAGENTA}▶ ${SCRIPT_NAME} AUTO-APPROVE${RESET} ${GREY}·${RESET} ${BLUE}${_targetLabel}${RESET}"
    fi
    local _daemonNote=""
    [ -n "$fDaemon" ] && _daemonNote=" ${GREY}·${RESET} ${MAGENTA}daemon${RESET}"
    echo -e "  ${GREY}poll${RESET} ${fPollInterval}s ${GREY}·${RESET} ${GREY}delay${RESET} ${fApproveDelay}s${_daemonNote} ${GREY}·${RESET} ${GREY}Ctrl+C to stop${RESET}"
    echo -e "${GREY}$(_hr "$_ruleW")${RESET}"
    echo ""

    while true; do
        local content
        content=$(tmux capture-pane -t "$fTargetPaneId" -p 2>/dev/null)
        if [ $? -ne 0 ]; then
            # capture-pane fails only when the pane_id no longer exists,
            # i.e. the pane was destroyed (closed / killed / its window
            # closed). A move or relink keeps the pane_id valid, so this
            # does NOT fire then — that's how ja persists across moves and
            # exits only on real destruction (requirement 1). Runs at the
            # very top of the loop, before any pause/resume logic, so it
            # stops ja in every mode (foreground or background daemon).
            _log "${RED}Target pane ${fTargetPaneId} destroyed. Exiting.${RESET}"
            break
        fi

        # Relink/move detection: the pane_id is stable, but its index
        # (session:window.pane) changes when the pane is moved to another
        # window/session or its siblings are re-indexed. Log such a move so
        # the daemon's history shows where the pane has been, and refresh
        # the state file so --status reflects the new index immediately.
        # Runs every iteration (even while paused) since a pane can be moved
        # while no AI is running. Cheap: one display-message per poll.
        local curLoc
        curLoc=$(_liveLocation "$fTargetPaneId")
        if [ -n "$curLoc" ] && [ "$curLoc" != "$lastLoc" ]; then
            _log "${CYAN}↪ Pane moved${RESET} ${BLUE}${lastLoc}${RESET} ${GREY}→${RESET} ${BLUE}${curLoc}${RESET} ${GREY}(${fTargetPaneId})${RESET}"
            lastLoc="$curLoc"
            _writeState moved
        fi

        # Sanity check: AI process still running in the pane?
        # If claude/codex exits while ja keeps running, the pane returns to
        # bash but the AI's prompt text often stays in scrollback. The
        # detector then matches that stale text on every iteration and ja
        # spams `tmux send-keys '1'` into the now-bash pane (each "1" is
        # echoed by bash, the screen changes, dedup fails to fire — tight
        # loop). Guard against this by re-checking the AI on every iter.
        #
        # Persistence is always on: when the pane is running a known (and
        # filter-allowed) AI we monitor it — adopting a new name if needed.
        # Otherwise (bash / filtered-out AI) we PAUSE: skip detection this
        # iter and keep polling, never feeding bash output to the detector.
        # ja resumes automatically when an AI comes back. The only things
        # that stop ja are pane destruction (handled above), Ctrl+C, and
        # --stop.
        local currentAi
        currentAi=$(detectAiNameForTarget "$fTargetPaneId")

        # Decide if the current pane content is something we should
        # actively monitor: _isKnownAi filters out plain shells / unknown
        # commands (so we never feed bash output to the detector).
        local _shouldMonitor=""
        if [ -n "$currentAi" ] && _isKnownAi "$currentAi"; then
            _shouldMonitor=1
        fi

        if [ -z "$_shouldMonitor" ]; then
            # Pane is on bash / a non-AI command. Skip detection this
            # iter — DO NOT fall through to detectPromptOption, which
            # would happily match stale menu text in scrollback and
            # start spamming digits at the bare shell.
            if [ -z "$fPaused" ]; then
                _log "${LIGHTYELLOW}⏸ Paused${RESET} — pane currently '${currentAi:-?}', not an AI we monitor. Waiting for ${fAiName}…"
                fPaused=1
                _writeState paused
            fi
            sleep "$fPollInterval"
            continue
        fi

        # An AI is in the pane and we're allowed to monitor it. If we
        # were paused, or the AI's identity changed mid-run, announce
        # the resume + reset dedup so a fresh prompt isn't skipped by
        # a stale fingerprint match.
        if [ -n "$fPaused" ] || [ "$currentAi" != "$fAiName" ]; then
            _log "${GREEN}▶ Resumed${RESET} — monitoring '${CYAN}${currentAi}${RESET}' in ${BLUE}$(_targetLabel)${RESET}"
            fAiName="$currentAi"
            lastHandledFp=""
            lastPlanReviewLogged=""
            fPaused=""
            _writeState resumed
        fi

        local tail
        tail=$(echo "$content" | tail -20)

        # Fingerprint to avoid double-pressing
        local fingerprint
        fingerprint=$(echo "$tail" | _hash)
        if [ "$fingerprint" = "$lastHandledFp" ]; then
            sleep "$fPollInterval"
            continue
        fi

        # Plan-review guard — Claude Code's "exit plan mode" prompt is
        # structurally a normal numbered menu, so detectPromptOption
        # would happily press "1. Yes, auto-accept edits" and let
        # Claude start executing. Catch it BEFORE detectPromptOption
        # and leave it on screen for the user to handle manually.
        #
        # Dedup uses a dedicated latch ($lastPlanReviewLogged), NOT
        # the fingerprint: when the user picks option 4 the tail
        # changes on every keystroke (new fingerprint each time) but
        # the trigger sentence stays on screen, so a fingerprint-based
        # dedup would re-fire the WARN per character. The latch trips
        # on the first hit and only clears when the prompt is no
        # longer on screen (see the else branch below).
        if isPlanReviewPrompt "$tail"; then
            if [ -z "$lastPlanReviewLogged" ]; then
                _log "${LIGHTYELLOW}⚠ Plan-review prompt detected${RESET} — ${LIGHTYELLOW}NOT auto-approving${RESET}. Review the plan and choose manually."
                _dbgBlock "tail content (plan-review prompt fed to isPlanReviewPrompt):" <<<"$tail"
                _writeState plan_review
                lastPlanReviewLogged=1
            fi
            sleep "$fPollInterval"
            continue
        else
            # Prompt is no longer on screen → arm the latch for the
            # next plan-review event. Cheap unconditional assignment;
            # most iterations this is already empty.
            lastPlanReviewLogged=""
        fi

        # Detect a permission prompt (Claude Code or Codex CLI — same
        # structural shape) and pick the option number to approve.
        local promptOption
        promptOption=$(detectPromptOption "$tail")
        if [ -n "$promptOption" ]; then
            _dbg "detector matched: option=$promptOption fp=$fingerprint"
            _dbgBlock "tail content (the 20 lines fed to detectPromptOption):" <<<"$tail"
            applyApproveDelay
            # Both Claude Code and Codex CLI (macOS + Linux) accept the
            # option number as a hotkey in the permission prompt. Sending
            # the number selects + submits in one shot, which avoids any
            # dependence on detecting the currently highlighted row.
            #
            # A single send-keys can be lost (pane mid-render, app not yet
            # accepting input, tmux race). Poll waitForScreenChange after
            # each send: react as soon as the pane updates, but wait a full
            # 2s before declaring the key lost. Only then retry, because
            # double-pressing a number key in Claude Code can silently jump
            # to a different option.
            #
            # KNOWN LIMITATION — multi-digit option numbers
            # ─────────────────────────────────────────────
            # detectPromptOption uses [0-9]+ in the regex, so an option
            # numbered "10" or higher would be returned as a multi-char
            # string. tmux send-keys treats each character as a separate
            # keystroke, so passing "10" sends "1" then "0":
            #     - "1" already selects + submits option 1
            #     - "0" lands on whatever state comes next (usually a no-op,
            #       but could land on an unintended target)
            # → wrong option approved.
            #
            # In practice neither Claude Code nor Codex CLI exposes more
            # than ~3 options today, so this hasn't bitten us. If a future
            # version surfaces 10+ options, two possible fixes:
            #   (a) Conservative — clamp the detector to [1-9] and let the
            #       user approve manually when there are more options.
            #   (b) Adaptive — send the digits one-by-one followed by Enter
            #       (`send-keys "$promptOption" Enter`); requires verifying
            #       that Claude/Codex's prompt UI actually accepts that
            #       form (single-digit hotkeys auto-submit, but multi-digit
            #       entry mode may not exist).
            # Until that version ships, this branch trusts that
            # $promptOption is a single ASCII digit.
            #
            # KNOWN LIMITATION — slow-transition prompts (trust prompt)
            # ──────────────────────────────────────────────────────────
            # The trust prompt is the one prompt where pressing the
            # option number is correctly accepted but the visible UI
            # takes 10+ seconds to transition (codex/claude do config
            # loading, MCP startup, etc. before the menu is replaced).
            # All other prompts transition in well under 1 second.
            #
            # Real wording (so future regex detection has examples):
            #
            #   Codex CLI:
            #     "Do you trust the contents of this directory? ..."
            #     "› 1. Yes, continue / 2. No, quit"
            #     "Press enter to continue"
            #
            #   Claude Code:
            #     "Quick safety check: Is this a project you created
            #      or one you trust? ..."
            #     "❯ 1. Yes, I trust this folder / 2. No, exit"
            #     "Enter to confirm · Esc to cancel"
            #
            # Common markers across both: word "trust" near the question,
            # and a footer hint mentioning "Enter to (confirm|continue)".
            #
            # Effect: waitForScreenChange's 2s budget expires while the
            # menu is still on screen; verify-and-retry then misclassifies
            # this as "key dropped" and resends. The second keystroke
            # leaks into whatever input context comes next (typically the
            # main UI's text input → a stray "1" appears in the prompt
            # box).
            #
            # Why it's not fixed:
            #   - Bumping the global timeout to 15-30s slows down EVERY
            #     dropped-key recovery for the 99% of fast prompts.
            #   - Detecting the trust prompt by phrase ("do you trust")
            #     and bypassing retry would work but adds a maintenance
            #     knob and a regex that has to track future wording.
            #   - The damage is small: one extra digit in the input box,
            #     trivially deleted with backspace. Trust prompts only
            #     appear once per untrusted directory, so this is
            #     low-frequency.
            # Tracked here so future regressions (more frequent or more
            # damaging variants) can find the rationale and the proposed
            # fixes (see brainstorm in commit history).
            local _preSendFp="$fingerprint"
            local _maxRetries=5
            local _attempt=0
            local _postFp="$_preSendFp"
            while true; do
                _dbg "send-keys '$promptOption' (attempt $((_attempt + 1))/$_maxRetries)"
                tmux send-keys -t "$fTargetPaneId" "$promptOption"
                _postFp=$(waitForScreenChange "$_preSendFp" 2000)
                if [ "$_postFp" != "$_preSendFp" ]; then
                    _dbg "screen changed: $_preSendFp → $_postFp"
                    break
                fi
                _dbg "screen unchanged after 2s, verifying prompt is still visible..."

                # Timeout: before re-sending, confirm the prompt is
                # still on-screen. If detectPromptOption returns empty,
                # the keystroke took effect and we only missed the hash
                # change (stable header, tiny diff); treat as success.
                # Only retry when the prompt truly is still visible —
                # this is what prevents a second digit key from landing
                # in a different state and approving the wrong option.
                local _verifyContent _verifyTail
                _verifyContent=$(tmux capture-pane -t "$fTargetPaneId" -p 2>/dev/null)
                _verifyTail=$(echo "$_verifyContent" | tail -20)
                if [ -z "$(detectPromptOption "$_verifyTail")" ]; then
                    _dbg "prompt vanished from screen → treating as success (key likely took effect, hash diff was missed)"
                    _postFp=$(echo "$_verifyTail" | _hash)
                    break
                fi

                _dbg "prompt still on screen → key likely dropped, will retry"
                _attempt=$((_attempt + 1))
                [ "$_attempt" -ge "$_maxRetries" ] && break
            done
            if [ "$_postFp" = "$_preSendFp" ]; then
                _log "${RED}⚠ Keystroke dropped (option $promptOption) after $_maxRetries attempts${RESET}"
                _writeState dropped
            else
                fApprovedCount=$((fApprovedCount + 1))
                local _retryNote=""
                [ "$_attempt" -gt 0 ] && _retryNote=" (${LIGHTMAGENTA}retry $_attempt${RESET})"
                _log "${GREEN}✔ Approved${RESET} (option $promptOption)${_retryNote} [#$fApprovedCount]"
                _writeState approve
            fi
            # Track the PRE-send fingerprint, not the post-send one.
            # Rationale: if Claude finishes the approved command quickly and
            # shows the next permission prompt during our wait window,
            # $_postFp captures that new prompt's hash — and the top-of-loop
            # dedup would then skip it forever. Using $_preSendFp ensures
            # dedup only fires when the EXACT prompt we just approved is
            # still on screen (i.e., the keystroke was dropped), while a
            # brand-new prompt has a different hash and is handled normally.
            lastHandledFp="$_preSendFp"
            _dbg "lastHandledFp ← $_preSendFp (pre-send fp)"
            continue
        fi

        # Screen changed but detector didn't match — useful signal when
        # diagnosing why a stale-but-visible prompt stops triggering on
        # later iterations.
        _dbg "no prompt detected (fp=$fingerprint, but screen changed since fp=$lastHandledFp)"

        sleep "$fPollInterval"
    done
}

# =============================================================================
# MAIN FLOW — modeled on jc's structure
# =============================================================================
#
#   main()
#     ├── parseOptions       (fills fXxx globals)
#     ├── doEarlyExitJobs    (handles task-mode flags like -l; never returns)
#     ├── checkTmuxAvailable (sanity check)
#     ├── resolveTarget      (autoDetect or validate -t; sets fTmuxTarget/
#     │                       fTargetPaneId/fAiName)
#     ├── daemonize          (if -D: re-exec detached + exit parent; the
#     │                       detached child continues past here)
#     ├── acquireLockfile    (single-instance guard; sets fLockFile)
#     ├── setupCleanupTrap   (defines _cleanup; arms trap)
#     └── mainLoop           (the watch-and-approve loop)
#
# Adding a new task-mode flag (e.g. --status, --stop, --log) means:
#   1. parseOptions registers it
#   2. doEarlyExitJobs dispatches it to a handler
#   3. write the handler
# The handler runs and exits, never reaching the monitor flow below.
# =============================================================================

# Dispatch task-mode flags. Each handler runs to completion and exits;
# control never returns to main(). Mirrors jc's doEarlyExitJobs pattern.
#
# Order matters when multiple flags collide — the first one that fires
# wins. We pick the order that makes accidental combinations harmless:
# --stop wins over --restart / --status / --log (a bare stop is the safe
# choice if both stop and restart are passed), --list stays first as the
# historical default.
doEarlyExitJobs() {
    [ -n "$fList" ]    && { handleListMode;            exit 0;  }
    [ -n "$fStop" ]    && { handleStopRequest;         exit $?; }
    [ -n "$fRestart" ] && { handleRestartRequest;      exit $?; }
    [ -n "$fStatus" ]  && { handleStatusRequest;       exit $?; }
    [ -n "$fLogFull" ] && { handleLogRequest full;     exit $?; }
    [ -n "$fLog" ]     && { handleLogRequest tail;     exit $?; }
}

# `-l` / `--list` handler — list every tmux pane currently running an AI,
# annotated with whether ja is already monitoring it.
handleListMode() {
    local _panes=()
    while IFS= read -r line; do
        [ -n "$line" ] && _panes+=("$line")
    done < <(findAiPanes)

    if [ ${#_panes[@]} -eq 0 ]; then
        echo -e "${RED}No pane running $(_aiNamesPretty) found${RESET}"
        return 0
    fi

    echo ""
    echo -e "${LIGHTYELLOW}AI sessions on tmux server (${#_panes[@]})${RESET}"
    echo ""
    _renderAiTable "${_panes[@]}"
    echo ""
}

# Shared target resolution for --stop / --status / --log. Returns a
# pane_id (eg. "%47") — the key everything else (file paths, _monitorPid)
# uses. Three sources:
#   1. -t was passed → resolve it to a pane_id. Accepts both the index
#      form (`M:2.1`) and a literal pane_id (`%47`). If the pane no longer
#      exists this echoes nothing (returns 1) — callers that tolerate a
#      dead target (--stop/--status) treat empty as "nothing to do".
#   2. inside tmux, -t not passed → the current pane's pane_id.
#   3. outside tmux, -t not passed → return empty (caller decides
#      whether that's an error or a "list-all" fallback).
#
# Echoes the resolved pane_id on stdout. Returns 0 if one was found,
# 1 otherwise (outside tmux without -t, or -t names a dead pane).
_resolveTargetForTaskMode() {
    if [ -n "$fTmuxTarget" ]; then
        local pid
        pid=$(tmux display-message -t "$fTmuxTarget" -p '#{pane_id}' 2>/dev/null)
        [ -n "$pid" ] || return 1
        printf '%s' "$pid"
        return 0
    fi
    if [ -n "$TMUX" ]; then
        local cur
        cur=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
        if [ -n "$cur" ]; then
            printf '%s' "$cur"
            return 0
        fi
    fi
    return 1
}

# Find the state file for the daemon watching <pane_id>, tolerant of the
# file's naming scheme. Tries the current pane-id-keyed name first; if
# that's absent, scans every state file for one recording this
# target_pane_id — which covers legacy index-keyed files written by a
# pre-upgrade daemon (e.g. 0-4-2.state.json for pane %5). Matching by the
# recorded pane_id (content, not filename) means --stop / --log keep
# working across the one-time transition. Echoes the path on stdout
# (empty + non-zero exit if none found).
_stateFileForPane() {
    local pane_id="$1"
    local primary=$(_stateFilePath "$pane_id")
    if [ -f "$primary" ]; then printf '%s' "$primary"; return 0; fi
    local f
    for f in "$(_runtimeDir)"/*.state.json; do
        [ -e "$f" ] || continue
        if [ "$(_readStateField "$f" target_pane_id)" = "$pane_id" ]; then
            printf '%s' "$f"
            return 0
        fi
    done
    return 1
}

# Stop the daemon monitoring a target pane. Idempotent — "already not
# running" is reported but exits 0. Cleans up stale lockfile/state if
# the recorded pid is dead. Locates the daemon by recorded pane_id so it
# can stop legacy index-keyed daemons too (see _stateFileForPane).
handleStopRequest() {
    local target
    if ! target=$(_resolveTargetForTaskMode) || [ -z "$target" ]; then
        if [ -n "$fTmuxTarget" ]; then
            _drawBox \
                "○ ${SCRIPT_NAME} target not found" \
                "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME} ${GREY}target not found${RESET}" \
                "$(_boxRow target "$fTmuxTarget" "${BLUE}${fTmuxTarget}${RESET}")" \
                "$(_boxRow note "pane gone — its daemon already exited" "${GREY}pane gone — its daemon already exited${RESET}")"
            return 0
        fi
        echo -e "${RED}Error: ${SCRIPT_NAME} --stop without -t requires running inside tmux${RESET}" >&2
        echo -e "${GREY}Pass an explicit target: ${SCRIPT_NAME} --stop -t <pane-id|session:window.pane>${RESET}" >&2
        return 1
    fi
    local label=$(_targetLabel "$target")
    # Locate the daemon's state file by recorded pane_id (tolerant of
    # legacy index-keyed names), then derive the matching lockfile from the
    # SAME basename so we read/clean the files that actually exist on disk.
    local statefile lockfile _base _dir
    if statefile=$(_stateFileForPane "$target") && [ -n "$statefile" ]; then
        _dir=$(dirname "$statefile")
        _base="${statefile##*/}"; _base="${_base%.state.json}"
        lockfile="$_dir/${_base}.lock"
    else
        # No state file found — fall back to the pane-id-keyed names (covers
        # a daemon that wrote a lock but not yet a state file).
        lockfile=$(_lockFilePath "$target")
        statefile=$(_stateFilePath "$target")
    fi
    # Recover the daemon's pid from whichever file is still around.
    # Lockfile is canonical; state file is the defensive fallback if
    # the lockfile was deleted out from under a running daemon (see
    # _monitorPid for the rationale).
    local pid=""
    if [ -f "$lockfile" ]; then
        pid=$(cat "$lockfile" 2>/dev/null)
    fi
    if [ -z "$pid" ] && [ -f "$statefile" ]; then
        pid=$(_readStateField "$statefile" pid)
    fi
    if [ -z "$pid" ]; then
        # ○ idle (yellow open circle) — no daemon, nothing to stop.
        _drawBox \
            "○ ${SCRIPT_NAME} no daemon" \
            "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME} ${GREY}no daemon${RESET}" \
            "$(_boxRow pane "$label" "${BLUE}${label}${RESET}")"
        return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
        # Stale state — daemon died without cleaning up. Remove the
        # detritus so next launch isn't blocked.
        rm -f "$lockfile" "$statefile"
        _drawBox \
            "⚠ ${SCRIPT_NAME} stale state cleaned" \
            "${LIGHTYELLOW}⚠${RESET} ${SCRIPT_NAME} ${GREY}stale state cleaned${RESET}" \
            "$(_boxRow pane "$label" "${BLUE}${label}${RESET}")" \
            "$(_boxRow note "no live daemon was attached" "${GREY}no live daemon was attached${RESET}")"
        return 0
    fi
    if kill "$pid" 2>/dev/null; then
        # Wait briefly for the daemon's TERM trap to clean up its own
        # lockfile/state. If it's slow or stuck, force-clean ourselves.
        local i
        for i in 1 2 3 4 5; do
            kill -0 "$pid" 2>/dev/null || break
            sleep 0.1
        done
        rm -f "$lockfile" "$statefile" 2>/dev/null
        # ▶ magenta + green "stopped" — same banner vocabulary as the
        # started/restarted boxes so all daemon life-cycle output matches.
        _drawBox \
            "▶ ${SCRIPT_NAME} stopped" \
            "${MAGENTA}▶${RESET} ${SCRIPT_NAME} ${GREEN}stopped${RESET}" \
            "$(_boxRow pane "$label" "${BLUE}${label}${RESET}")" \
            "$(_boxRow pid  "$pid"   "${CYAN}${pid}${RESET}")"
        return 0
    fi
    echo -e "${RED}✗${RESET} ${SCRIPT_NAME}: ${RED}failed to kill pid ${pid}${RESET} ${GREY}(permission denied?)${RESET}" >&2
    return 1
}

# Restart the daemon for a target pane: stop the existing one (if any),
# then launch a fresh background daemon for the same pane. Sugar for
# `${SCRIPT_NAME} --stop -t X && ${SCRIPT_NAME} -D -t X` — handy after
# upgrading ${SCRIPT_NAME} (so a long-running daemon picks up new code).
# Carries over -w/-v if they were passed; otherwise uses defaults.
handleRestartRequest() {
    local target
    if ! target=$(_resolveTargetForTaskMode) || [ -z "$target" ]; then
        if [ -n "$fTmuxTarget" ]; then
            echo -e "${RED}Error: ${SCRIPT_NAME} --restart: target '${fTmuxTarget}' not found${RESET}" >&2
        else
            echo -e "${RED}Error: ${SCRIPT_NAME} --restart without -t requires running inside tmux${RESET}" >&2
            echo -e "${GREY}Pass an explicit target: ${SCRIPT_NAME} --restart -t <pane-id|session:window.pane>${RESET}" >&2
        fi
        return 1
    fi

    # Capture the current daemon's pid (if any) BEFORE stopping, so the
    # relaunch banner can show "(was <oldpid>)".
    local oldpid
    oldpid=$(_monitorPid "$target" 2>/dev/null) || oldpid=""

    # Stop any existing daemon for this pane (idempotent), silently — the
    # single "daemon restarted" box printed by the relaunch is the whole
    # story, so we suppress handleStopRequest's own line. Point it at the
    # resolved pane_id so it acts on exactly this pane (and cleans
    # legacy-named files too, via _stateFileForPane).
    fTmuxTarget="$target"
    handleStopRequest >/dev/null 2>&1

    # Relaunch as a fresh background daemon, keyed by pane_id. exec replaces
    # this process with `ja --daemon`, which self-detaches and prints a
    # single startup box. JA_RESTARTED_FROM makes that box read as a restart
    # (title "daemon restarted" + the prior pid). Carry over -w/-v when set.
    local self
    self=$(command -v "$0" 2>/dev/null) || self="$0"
    local args=(--daemon -t "$target")
    [ "$fApproveDelay" != "0" ] && args+=(-w "$fApproveDelay")
    [ -n "$fVerbose" ] && args+=(-v)
    export JA_RESTARTED_FROM="${oldpid:-none}"
    exec "$self" "${args[@]}"
}

# Pretty-format a duration in seconds as "Xm Ys" or "Xh Ym Zs".
_fmtDuration() {
    local s="$1" h m
    if [ "$s" -lt 60 ]; then echo "${s}s"; return; fi
    if [ "$s" -lt 3600 ]; then m=$((s / 60)); echo "${m}m $((s % 60))s"; return; fi
    h=$((s / 3600)); m=$(((s % 3600) / 60))
    echo "${h}h ${m}m $((s % 3600 % 60))s"
}

# Format unix-seconds as "YYYY-MM-DD HH:MM:SS" for --status. GNU date
# uses `-d "@ts"`, BSD/macOS uses `-r ts` — try GNU first, fall back.
# Echo raw ts on total failure so the cell stays readable.
_fmtEventTime() {
    local ts="$1"
    [[ "$ts" =~ ^[0-9]+$ ]] || { echo "?"; return; }
    date -d "@$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || date -r "$ts" '+%Y-%m-%d %H:%M:%S' 2>/dev/null \
        || echo "$ts"
}

# Read a single field from a state JSON file. Crude but adequate — our
# schema is flat and we control the writer (_writeState), so we don't
# need a real JSON parser. Strips wrapping quotes and trailing comma.
_readStateField() {
    local file="$1" field="$2"
    grep -E "\"${field}\":" "$file" 2>/dev/null \
        | sed -E "s/.*\"${field}\":[[:space:]]*//; s/,[[:space:]]*$//; s/^\"//; s/\"$//" \
        | head -1
}

# Single status renderer — one entry per daemon, formatted as a summary
# row plus an indented detail block. Always shows every daemon, no -t /
# --all / tmux-aware branching. If the caller is currently inside tmux,
# the row corresponding to the caller's pane is marked with `*` in the
# `#` column (decorative only — doesn't change layout or behavior).
handleStatusRequest() {
    local files=( "$(_runtimeDir)"/*.state.json )
    # Glob with no match expands to a literal that doesn't exist — guard.
    if [ ! -e "${files[0]}" ]; then
        # Empty-state box — ○ (open circle) + yellow mirrors the `-l`
        # listing's "● monitoring / ○ idle" convention and the other
        # daemon-control banners, with a hint on how to start one.
        _drawBox \
            "○ ${SCRIPT_NAME} no daemons running" \
            "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME} ${GREY}no daemons running${RESET}" \
            "$(_boxRow start "claude -y   (or: ${SCRIPT_NAME} -D)" "${CYAN}claude -y${RESET}   ${GREY}(or: ${SCRIPT_NAME} -D)${RESET}")"
        return 0
    fi

    # Best-effort: identify the caller's current pane_id so we can mark its
    # row. Compared against each state's target_pane_id (the stable key),
    # not the index string — so the mark follows the pane across moves.
    # Failure is silent — outside tmux we just don't mark anything.
    local current_pane_id=""
    if [ -n "$TMUX" ]; then
        current_pane_id=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
    fi

    echo -e "${LIGHTYELLOW}${SCRIPT_NAME} daemons running (${#files[@]})${RESET}"
    echo

    # Layout: every line is `Label: value` in a two-column grid. First
    # line starts with "[N] " (or "[N*] ") as index marker; subsequent
    # lines indent with 5 spaces. Per-line:
    #   indent/marker(5) + label1(_labW) + " " + value1(_valW)
    #                    + " " + label2(_lab2W) + " " + value2
    # _labW/_lab2W=12 fit longest labels ("Last Event:", "Event Time:").
    # _valW=19 fits state_pad, PID, target label, event type.
    # Hoisted to loop top because state_pad's padding reuses _valW.
    local _labW=12 _valW=19 _lab2W=12

    local i=1 f target target_pane_id pid ai daemon_int started approved paused
    local last_ts last_type host state_plain state_colored state_pad last_when
    local target_label live_loc
    local now=$(date +%s)
    local uptime index_label
    for f in "${files[@]}"; do
        target=$(_readStateField "$f" target)
        target_pane_id=$(_readStateField "$f" target_pane_id)
        pid=$(_readStateField "$f" pid)
        ai=$(_readStateField "$f" ai)
        daemon_int=$(_readStateField "$f" daemon)
        started=$(_readStateField "$f" started_ts)
        approved=$(_readStateField "$f" approved_count)
        paused=$(_readStateField "$f" paused)
        last_ts=$(_readStateField "$f" last_event_ts)
        last_type=$(_readStateField "$f" last_event_type)
        host=$(_readStateField "$f" host)

        # Target label: re-resolve the pane's live index from its pane_id so
        # the row reflects where the pane is right now (after a move). If the
        # pane is gone, fall back to the last-known index recorded in the
        # state file, still suffixed with the pane_id. Always shows both.
        live_loc=$(_liveLocation "$target_pane_id")
        [ -z "$live_loc" ] && live_loc="$target"
        if [ -n "$target_pane_id" ]; then
            target_label="$live_loc ($target_pane_id)"
        else
            target_label="$live_loc"
        fi

        # State: pad-then-color (ANSI escapes throw off %-Ns downstream).
        if ! kill -0 "$pid" 2>/dev/null; then
            state_plain="dead";    state_colored="${RED}dead${RESET}"
        elif [ "$paused" = "true" ]; then
            state_plain="paused";  state_colored="${LIGHTYELLOW}paused${RESET}"
        else
            state_plain="active";  state_colored="${GREEN}active${RESET}"
        fi
        state_pad=$(printf "%-${_valW}s" "$state_plain")
        state_pad="${state_colored}${state_pad#$state_plain}"

        last_when=$(_fmtEventTime "$last_ts")
        uptime="?"
        [[ "$started" =~ ^[0-9]+$ ]] && uptime=$(_fmtDuration $((now - started)))

        # Index marker — "[N]" or "[N*]" if this is the caller's current
        # pane (matched by pane_id). Fits 5 chars for N=1..99; overflows
        # gracefully for 100+.
        if [ -n "$current_pane_id" ] && [ "$target_pane_id" = "$current_pane_id" ]; then
            index_label="[${i}*]"
        else
            index_label="[${i}]"
        fi

        # Daemon label — reflects the startup-time `-D/--daemon` flag the ja
        # was launched with, i.e. whether it self-daemonized (backgrounded +
        # detached). Persistence (pause/resume across AI restarts) is always
        # on now, so it's no longer a per-daemon variable worth showing; the
        # useful fact is whether this instance is a background daemon. The
        # actual ctty binding is shown separately as Mode below.
        local daemon_label="no"
        [ "$daemon_int" = "1" ] && daemon_label="yes"

        # Mode label — describes the daemon's controlling-tty binding,
        # which determines whether closing the host pane / terminal will
        # send the daemon SIGHUP. Two states:
        #
        #   • "attached to <X>" — daemon has a controlling tty inheriting
        #     from the shell where it was launched. Closing that pane (or
        #     terminal) will send SIGHUP and kill the daemon. This is the
        #     case for `claude -y` launches today, because bash's
        #     `& disown` only detaches from the job table — it does NOT
        #     release the ctty, which requires setsid(2).
        #
        #   • "detached" — no ctty. The daemon survives pane / terminal
        #     close. This is what `ja -D` (self-daemonize) produces, and is
        #     the normal state for any background daemon.
        #
        # Mode (ctty binding) and Daemon (was `-D` passed) usually agree
        # now — a `-D` launch self-detaches, so it reads "detached" here —
        # but they answer different questions, so both are shown.
        local mode_label
        if [ -z "$host" ]; then
            mode_label="${MAGENTA}detached${RESET}"
        else
            mode_label="attached to ${GREY}${host}${RESET}"
        fi

        # Derive lock/log from THIS state file's own name (not recomputed
        # from target_pane_id), so the displayed paths always pair with the
        # state file we actually read. For current daemons the basename is
        # the pane_id slug, so the result is identical; for a legacy
        # index-keyed file written by a pre-upgrade daemon (e.g.
        # 0-4-2.state.json) it correctly shows 0-4-2.lock/.log — the files
        # that really exist — instead of a phantom pane_id-keyed path.
        local _dir=$(dirname "$f")
        local _base="${f##*/}"; _base="${_base%.state.json}"
        local logf="$_dir/${_base}.log"
        local lockf="$_dir/${_base}.lock"

        # printf (not echo -e): color vars are already-expanded ANSI bytes
        # by the time printf sees them. %b on state_pad / mode_label since
        # they carry pre-baked ANSI (width pre-applied for state_pad).

        # [N] + Target / AI. Target shows "index (%pane_id)".
        printf "${CYAN}%-5s${RESET}${GREY}%-${_labW}s${RESET} ${BLUE}%-${_valW}s${RESET} ${GREY}%-${_lab2W}s${RESET} ${CYAN}%s${RESET}\n" \
            "$index_label" "Target:" "$target_label" "AI:" "$ai"

        # State / Approved
        printf "     ${GREY}%-${_labW}s${RESET} %b ${GREY}%-${_lab2W}s${RESET} ${GREEN}%s${RESET}\n" \
            "State:" "$state_pad" "Approved:" "$approved"

        # Last Event / Event Time
        printf "     ${GREY}%-${_labW}s${RESET} %-${_valW}s ${GREY}%-${_lab2W}s${RESET} %s\n" \
            "Last Event:" "$last_type" "Event Time:" "$last_when"

        # PID / Uptime
        printf "     ${GREY}%-${_labW}s${RESET} ${CYAN}%-${_valW}s${RESET} ${GREY}%-${_lab2W}s${RESET} %s\n" \
            "PID:" "$pid" "Uptime:" "$uptime"

        # Daemon / Mode
        printf "     ${GREY}%-${_labW}s${RESET} %-${_valW}s ${GREY}%-${_lab2W}s${RESET} %b\n" \
            "Daemon:" "$daemon_label" "Mode:" "$mode_label"

        # Paths — full-width. `Statefile:` (renamed from `State:`)
        # disambiguates the path label from the daemon-state field above.
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Lockfile:"  "$lockf"
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Logfile:"   "$logf"
        printf "     ${GREY}%-${_labW}s %s${RESET}\n" "Statefile:" "$f"
        echo

        i=$((i + 1))
    done
}

# Tail the daemon's log file. `-F` (capital) follows by name not fd, so
# log rotation (or daemon restart writing a new file) is handled.
#
# Mode arg controls the starting point:
#   • "tail" (default) — last 15 lines, then follow. Maps to --log / -L.
#                        15 (vs tail's default of 10) gives enough context
#                        to see the most recent ✔ Approved / ⚠ events
#                        without scrolling.
#   • "full"           — every line from line 1, then follow. Maps to
#                        --log-full. Implemented as `tail -F -n +1` (single
#                        process) rather than `cat … && tail -F …` so no
#                        appends written between the cat finishing and tail
#                        starting can be missed.
handleLogRequest() {
    local mode="${1:-tail}"
    local target
    local _flag="--log"
    [ "$mode" = "full" ] && _flag="--log-full"
    if ! target=$(_resolveTargetForTaskMode) || [ -z "$target" ]; then
        if [ -n "$fTmuxTarget" ]; then
            echo -e "${RED}Error: ${SCRIPT_NAME} ${_flag}: target '${fTmuxTarget}' not found${RESET}" >&2
            return 1
        fi
        echo -e "${RED}Error: ${SCRIPT_NAME} ${_flag} without -t requires running inside tmux${RESET}" >&2
        echo -e "${GREY}Pass an explicit target: ${SCRIPT_NAME} ${_flag} -t <pane-id|session:window.pane>${RESET}" >&2
        return 1
    fi
    local label=$(_targetLabel "$target")
    # Locate the daemon's files by recorded pane_id (tolerant of legacy
    # index-keyed names), deriving log/lock from the state file's basename.
    local statefile logfile lockfile _base _dir
    if statefile=$(_stateFileForPane "$target") && [ -n "$statefile" ]; then
        _dir=$(dirname "$statefile")
        _base="${statefile##*/}"; _base="${_base%.state.json}"
        logfile="$_dir/${_base}.log"
        lockfile="$_dir/${_base}.lock"
    else
        logfile=$(_logFilePath "$target")
        lockfile=$(_lockFilePath "$target")
        statefile=$(_stateFilePath "$target")
    fi
    if [ ! -f "$logfile" ]; then
        if [ -f "$lockfile" ]; then
            _drawBox \
                "⚠ ${SCRIPT_NAME} log file missing" \
                "${LIGHTYELLOW}⚠${RESET} ${SCRIPT_NAME} ${LIGHTYELLOW}log file missing${RESET}" \
                "$(_boxRow pane "$label"    "${BLUE}${label}${RESET}")" \
                "$(_boxRow log  "$logfile"  "${GREY}${logfile}${RESET}")" \
                "$(_boxRow note "daemon started without log redirection" "${GREY}daemon started without log redirection${RESET}")" >&2
            return 1
        fi
        _drawBox \
            "○ ${SCRIPT_NAME} no daemon" \
            "${LIGHTYELLOW}○${RESET} ${SCRIPT_NAME} ${GREY}no daemon${RESET}" \
            "$(_boxRow pane  "$label"               "${BLUE}${label}${RESET}")" \
            "$(_boxRow start "${SCRIPT_NAME} -D -t ${target}" "${LIGHTYELLOW}${SCRIPT_NAME} -D -t ${target}${RESET}")"
        return 1
    fi

    # Staleness check — the log file may have outlived its writer.
    # _cleanup removes the lockfile and state file on daemon shutdown
    # but intentionally preserves the log. A present log file therefore
    # doesn't prove there's a live daemon. Without this check,
    # `ja -L -t <stale>` silently tails a frozen file, which reads as a
    # hang.
    #
    # Behavior: warn loudly to stderr (so it doesn't pollute the tailed
    # log stream on stdout), then STILL tail. The user explicitly asked
    # for the log; refusing would force them to `less` the file by hand.
    # Worst case they Ctrl+C after reading the warning.
    local mon_pid
    if ! mon_pid=$(_monitorPid "$target"); then
        local last_ts last_type last_when="?"
        if [ -f "$statefile" ]; then
            last_ts=$(_readStateField "$statefile" last_event_ts)
            last_type=$(_readStateField "$statefile" last_event_type)
            [ -n "$last_ts" ] && last_when=$(_fmtEventTime "$last_ts")
        fi
        echo -e "${LIGHTYELLOW}⚠${RESET} ${SCRIPT_NAME}: ${LIGHTYELLOW}no live daemon for ${BLUE}${label}${RESET} ${GREY}—${RESET} tailing stale log" >&2
        if [ -n "$last_ts" ]; then
            echo -e "  ${GREY}last event:${RESET} ${last_type:-?} ${GREY}at${RESET} ${last_when}" >&2
        else
            echo -e "  ${GREY}(state file gone — no last-event info)${RESET}" >&2
        fi
        echo -e "  ${GREY}log:${RESET} ${logfile}" >&2
        echo -e "  ${GREY}restart with:${RESET} ${CYAN}${SCRIPT_NAME} -D -t ${target}${RESET}" >&2
        echo >&2
    fi

    # exec replaces our shell with tail so Ctrl+C goes straight to tail
    # without an intermediate process layer.
    if [ "$mode" = "full" ]; then
        exec tail -F -n +1 "$logfile"
    else
        exec tail -F -n 15 "$logfile"
    fi
}

# Sanity-check that tmux is on PATH. Without tmux ja literally cannot do
# anything — capture-pane, list-panes, send-keys all need it.
checkTmuxAvailable() {
    if ! command -v tmux &>/dev/null; then
        echo -e "${RED}Error: tmux is required but not found${RESET}" >&2
        exit 1
    fi
}

# Pin down which pane to monitor and which AI is in it, then freeze the
# pane's pane_id ($fTargetPaneId) as the stable identity ja binds to.
# Two paths:
#   • -t not given: autoDetectTarget scans tmux for AI panes, picks one
#     (or prompts the user if multiple match) and sets fTargetPaneId.
#   • -t given:     validate the target exists and resolve its pane_id.
#
# Persistence is always on, so a -t target need NOT be running an AI right
# now: if it isn't (bash), ja boots into the paused state and waits for an
# AI to appear (mainLoop's pause/resume handles it). The only hard
# requirement is that the target pane exists.
resolveTarget() {
    if [ -z "$fTmuxTarget" ]; then
        # auto-detect requires at least one AI pane to bootstrap the target:
        # there's no way to "wait for an AI to come back" without first
        # knowing which pane to wait in. (autoDetectTarget sets fTargetPaneId.)
        autoDetectTarget
        return
    fi

    validateTarget "$fTmuxTarget"
    # Freeze the stable identity. validateTarget already proved it resolves.
    fTargetPaneId=$(tmux display-message -t "$fTmuxTarget" -p '#{pane_id}' 2>/dev/null)
    fAiName=$(detectAiNameForTarget "$fTmuxTarget")

    # Target isn't (yet) running a known AI: boot paused. We synthesise a
    # readable fAiName (the recognised AI names) so banner/log lines have
    # something to show. mainLoop never feeds non-AI pane content to the
    # detector, so this is safe (no runaway send-keys).
    if ! _isKnownAi "$fAiName"; then
        fAiName="$(_aiNamesPretty)"
    fi
}

# Acquire the per-target lockfile so only one ja monitors a given pane.
# If a stale (dead-pid) lockfile exists, we silently overwrite it.
#
# Duplicate detection routes through _monitorPid, so it sees a live
# daemon even if the lockfile got deleted out from under it (the
# state file is consulted as a fallback). Without that, a second
# `ja -D` would happily start next to the already-running one and
# both would race on send-keys into the same pane.
acquireLockfile() {
    # Path computed via _lockFilePath (keyed by pane_id) so it stays in sync
    # with everything else (_monitorPid, --stop, --status, the wrapper, etc.).
    fLockFile=$(_lockFilePath "$fTargetPaneId")

    local _liveMonitorPid
    if _liveMonitorPid=$(_monitorPid "$fTargetPaneId"); then
        local _lbl=$(_targetLabel)
        _drawBox \
            "● ${SCRIPT_NAME} already monitoring" \
            "${LIGHTYELLOW}●${RESET} ${SCRIPT_NAME} ${LIGHTYELLOW}already monitoring${RESET}" \
            "$(_boxRow pane "$_lbl"              "${BLUE}${_lbl}${RESET}")" \
            "$(_boxRow pid  "$_liveMonitorPid"   "${CYAN}${_liveMonitorPid}${RESET}")" \
            "$(_boxRow stop "${SCRIPT_NAME} --stop" "${LIGHTYELLOW}${SCRIPT_NAME} --stop${RESET}")"
        exit 1
    fi
    echo $$ > "$fLockFile"
}

# Define _cleanup and arm the trap. _cleanup runs on Ctrl+C (INT), kill
# (TERM), or natural script exit (EXIT) — covers every termination path.
setupCleanupTrap() {
    # Clear the trap before exiting to avoid re-entry: INT calls _cleanup
    # which exits, but exiting also fires EXIT — if the trap is still
    # armed, the "Stopped" message prints twice.
    _cleanup() {
        rm -f "$fLockFile"
        # Also remove the state file — --status should not list a daemon
        # that has clearly stopped. Keyed by pane_id via _stateFilePath so
        # the rule stays in sync with where mainLoop wrote it.
        [ -n "$fTargetPaneId" ] && rm -f "$(_stateFilePath "$fTargetPaneId")"
        echo
        _log "Stopped. Approved ${GREEN}$fApprovedCount${RESET} prompts."
        trap - INT TERM EXIT
        exit 0
    }
    trap '_cleanup' INT TERM EXIT
}

# Self-daemonize when --daemon/-D is given. Re-exec ourselves as a detached
# background process: a new session (setsid, which releases the controlling
# tty so closing the launching pane/terminal won't SIGHUP us), stdio
# redirected to our own logfile (so `ja -L` finds it with no external
# redirection), and disowned. The foreground parent prints a one-line
# status and returns the shell prompt.
#
# A re-exec guard ($JA_DAEMONIZED) stops the detached child from
# daemonizing again — the child sees fDaemon=1 too (it inherits -D) but
# carries straight on to acquireLockfile + mainLoop.
#
# Called from main() AFTER resolveTarget (so the interactive auto-detect
# picker runs in the foreground parent, attached to the user's terminal)
# and BEFORE acquireLockfile (the detached child acquires the lock). The
# parent has no cleanup trap armed yet, so its exit won't disturb the
# child's lockfile/state.
daemonize() {
    [ -n "$fDaemon" ]       || return 0  # not a daemon launch — run in foreground
    [ -z "$JA_DAEMONIZED" ] || return 0  # we ARE the detached child — carry on

    # Restart context: handleRestartRequest sets JA_RESTARTED_FROM to the
    # prior daemon's pid (or "none") before exec'ing us, so the startup
    # banner can read as a single "daemon restarted" box instead of a
    # separate stop line + started box. Capture it locally and unset so the
    # detached child we launch below doesn't inherit a stray var.
    local _restartedFrom="${JA_RESTARTED_FROM:-}"
    unset JA_RESTARTED_FROM

    # Best-effort duplicate pre-check for a friendly message. The child's
    # acquireLockfile remains the authoritative single-instance guard.
    local _pid
    if _pid=$(_monitorPid "$fTargetPaneId"); then
        local _lbl=$(_targetLabel)
        _drawBox \
            "▶ ${SCRIPT_NAME} already running" \
            "${MAGENTA}▶${RESET} ${SCRIPT_NAME} ${LIGHTYELLOW}already running${RESET}" \
            "$(_boxRow pane "$_lbl"  "${BLUE}${_lbl}${RESET}")" \
            "$(_boxRow pid  "$_pid"  "${CYAN}${_pid}${RESET}")" \
            "$(_boxRow stop "${SCRIPT_NAME} --stop" "${LIGHTYELLOW}${SCRIPT_NAME} --stop${RESET}")"
        exit 0
    fi

    local logfile=$(_logFilePath "$fTargetPaneId")
    local self
    self=$(command -v "$0" 2>/dev/null) || self="$0"

    # Launch detached. Append `-t "$fTargetPaneId"` so the child binds the
    # already-resolved pane_id and never re-runs the interactive picker
    # (the last -t on the line wins if the user also passed one).
    if command -v setsid &>/dev/null; then
        ( JA_DAEMONIZED=1 setsid "$self" "$@" -t "$fTargetPaneId" </dev/null >"$logfile" 2>&1 & disown ) &>/dev/null
    else
        # No setsid (rare): still background + disown. ja works, but it
        # keeps the launching pane's ctty, so `--status` shows "attached".
        ( JA_DAEMONIZED=1 "$self" "$@" -t "$fTargetPaneId" </dev/null >"$logfile" 2>&1 & disown ) &>/dev/null
    fi

    # Wait briefly for the child to claim its lockfile so we can report its
    # pid and avoid racing a follow-up invocation.
    local lockfile=$(_lockFilePath "$fTargetPaneId")
    local i cpid=""
    for i in 1 2 3 4 5 6 7 8; do
        if [ -f "$lockfile" ]; then
            cpid=$(cat "$lockfile" 2>/dev/null)
            [ -n "$cpid" ] && break
        fi
        sleep 0.1
    done
    local _lbl=$(_targetLabel)
    # Title + pid row vary by whether this is a fresh start or a restart.
    # On restart (a prior pid was recorded), title reads "daemon restarted"
    # and the pid row appends "(was <oldpid>)" so the whole action is one box.
    local _action="daemon started"
    local _pidPlain="$cpid" _pidColored="${CYAN}${cpid}${RESET}"
    if [ -n "$_restartedFrom" ] && [ "$_restartedFrom" != "none" ]; then
        _action="daemon restarted"
        _pidPlain="$cpid (was $_restartedFrom)"
        _pidColored="${CYAN}${cpid}${RESET} ${GREY}(was ${_restartedFrom})${RESET}"
    fi
    local _titlePlain="▶ ${SCRIPT_NAME} ${_action}"
    local _titleColored="${MAGENTA}▶${RESET} ${SCRIPT_NAME} ${GREEN}${_action}${RESET}"
    if [ -n "$cpid" ]; then
        _drawBox "$_titlePlain" "$_titleColored" \
            "$(_boxRow pane "$_lbl"      "${BLUE}${_lbl}${RESET}")" \
            "$(_boxRow pid  "$_pidPlain" "$_pidColored")" \
            "$(_boxRow log  "$logfile"   "${GREY}${logfile}${RESET}")" \
            "$(_boxRow stop "${SCRIPT_NAME} --stop" "${LIGHTYELLOW}${SCRIPT_NAME} --stop${RESET}")"
    else
        _drawBox "$_titlePlain" "$_titleColored" \
            "$(_boxRow pane "$_lbl"    "${BLUE}${_lbl}${RESET}")" \
            "$(_boxRow log  "$logfile" "${GREY}${logfile}${RESET}")"
    fi
    exit 0
}

main() {
    parseOptions "$@"
    doEarlyExitJobs
    checkTmuxAvailable
    resolveTarget
    daemonize "$@"
    acquireLockfile
    setupCleanupTrap
    mainLoop
}

main "$@"
