}

# Deep clean using git clean -fdx; caller must cd to repo and call requireGitRepo first
runGitClean() {
    echo -e "$NOTATION ${CYAN}Deep cleaning with git clean -fdx...${RESET}"
    local excludeOpts="--exclude=*.code-workspace --exclude=$STATE_FILE"
    if [ -z "$fRMCompileCommandsJson" ]; then
        if [ -L "$fCompileCommandsJson" ]; then
            local realFile
            realFile=$(readlink -f "$fCompileCommandsJson")
            excludeOpts="$excludeOpts --exclude=$(basename "$realFile")"
        else
            excludeOpts="$excludeOpts --exclude=$fCompileCommandsJson"
        fi
    fi
    local cleanCmd="git clean -fdx $excludeOpts"
    echo -e "$NOTATION Running: ${BLUE}$cleanCmd${RESET}"
    echo $SEPARATOR
    eval "$cleanCmd"
    echo -e "$NOTATION ${CYAN}Cleaning submodules...${RESET}"
    git submodule foreach --recursive git clean -fdx "$excludeOpts"
    echo -e "$NOTATION ${MAGENTA}Git deep clean completed.${RESET}"
}

runGitOptions() {
    [[ ${#fGitCmds[@]} -eq 0 && -z "$fGitClean" ]] && return 0
    fWorkingDir=$(realpath "$fWorkingDir")
    cd "$fWorkingDir" || exit 1
    requireGitRepo

    # Append git-clean to the cascade queue if requested
    [[ -n "$fGitClean" ]] && fGitCmds+=("git-clean")

    local gitCmdCount=${#fGitCmds[@]}
    local isCascade=$(( gitCmdCount > 1 ? 1 : 0 ))
    local gitStep=0

    # Execute git commands in the exact order specified on the command line
    for cmd in "${fGitCmds[@]}"; do
        ((gitStep++))
        [[ $isCascade -eq 1 ]] && echo -e "$NOTATION ${BOLD}[Git $gitStep/$gitCmdCount]${RESET}"
        case "$cmd" in
            fetch)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git fetch origin master_rc${RESET}"
                git fetch origin master_rc
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git fetch origin --tags${RESET}"
                git fetch origin --tags
                ;;
            rebase)
                local stashed=0
                if ! git diff --quiet 2>/dev/null; then
                    echo -e "$NOTATION ${CYAN}Unstaged changes detected, stashing...${RESET}"
                    git stash push -m "jmake-rebase-autostash" && stashed=1
                fi
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git rebase origin/master_rc${RESET}"
                if git rebase origin/master_rc; then
                    if [[ $stashed -eq 1 ]]; then
                        echo -e "$NOTATION ${CYAN}Rebase succeeded, restoring stashed changes...${RESET}"
                        git stash pop
                    fi
                else
                    echo -e "$NOTATION ${RED}Rebase failed.${RESET}"
                    if [[ $stashed -eq 1 ]]; then
                        echo -e "$NOTATION ${YELLOW}Stashed changes preserved. Run 'git stash pop' after resolving conflicts.${RESET}"
                    fi
                fi
                ;;
            add)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git add -u && git reset HEAD -- $GIT_RESET_PATHS${RESET}"
                git add -u && git reset HEAD -- "$GIT_RESET_PATHS"
                ;;
            commit)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git commit --amend --no-edit${RESET}"
                git commit --amend --no-edit
                ;;
            amend)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git commit --amend${RESET}"
                git commit --amend
                ;;
            push)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git push origin HEAD:refs/for/master_rc${RESET}"
                git push origin HEAD:refs/for/master_rc
                ;;
            stat)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git diff --stat${RESET}"
                git diff --stat
                ;;
            diff)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git diff include/ src/${RESET}"
                git diff include/ src/
                ;;
            show)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git show HEAD${RESET}"
                git show HEAD
                ;;
            git-clean)
                runGitClean
                ;;
            clean-submodule)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git submodule deinit --all -f${RESET}"
                git submodule deinit --all -f
                ;;
        esac
        if [[ $? -ne 0 ]]; then
            echo -e "$NOTATION ${RED}$cmd failed, aborting.${RESET}"
            exit 1
        fi
    done

    [[ $isCascade -eq 1 ]] && echo -e "$NOTATION ${GREEN}Congratulations! All $gitCmdCount git commands completed successfully.${RESET}"
    # If only git options were given (no build), exit after completing them
    [[ -z "$fNeedBuild"    &&
       -z "$fClean"        &&
       -z "$fLinkWorkspace" &&
       -z "$fBurn"         &&
       -z "$fBurnOfficial" &&
       -z "$fFwReset"      &&
       -z "$fMftInstall"   &&
       -z "$fOfedStart"    &&
       -z "$fOfedStop"     &&
       -z "$fPowerCycle"   &&
       -z "$fPowerOn"      &&
       -z "$fPowerOff"     &&
       -z "$fDockerGroup"  ]] && exit 0
}

