formatElapsed() {
    local elapsed=$1
    local h=$((elapsed / 3600))
    local m=$((elapsed % 3600 / 60))
    local s=$((elapsed % 60))
    local fmt="${s}s"
    [[ $m -gt 0 ]] && fmt="${m}m${fmt}"
    [[ $h -gt 0 ]] && fmt="${h}h${fmt}"
    echo "$fmt"
}

resolveReleasePath() {
    local version="$1"
    local major minor patch

    if [[ "$version" == *.* ]]; then
        IFS='.' read -r major minor patch <<< "$version"
    elif [[ "$version" == *_* ]]; then
        IFS='_' read -r major minor patch <<< "$version"
    else
        echo -e "$NOTATION ${RED}Error: Invalid version format: ${YELLOW}$version${RESET}"
        echo -e "$NOTATION Expected format: XX.YY.ZZZZ (e.g., 82.49.0052)"
        exit 1
    fi

    local devId="${FW_MAJOR_TO_DEVID[$major]}"
    if [[ -z "$devId" ]]; then
        echo -e "$NOTATION ${RED}Error: Unknown major version ${YELLOW}$major${RESET}"
        echo -e "$NOTATION Supported: ${CYAN}${!FW_MAJOR_TO_DEVID[*]}${RESET}"
        exit 1
    fi

    patch=$(printf "%04d" "$((10#$patch))")
    fResolvedFwDir="${RELEASE_BASE}/fw-${devId}/fw-${devId}-rel-${major}_${minor}_${patch}"

    if [[ ! -d "$fResolvedFwDir" ]]; then
        echo -e "$NOTATION ${RED}Error: Release directory not found: ${YELLOW}$fResolvedFwDir${RESET}"
        exit 1
    fi
}

runBurn() {
    [[ -z "$fBurn" ]] && return
    cd "$fWorkingDir" || exit 1

    local burnStartTime=$(date +%s)

    echo "$SEPARATOR"
    echo -e "$NOTATION ${BOLD}Burn Workflow${RESET}"
    echo "$SEPARATOR"

    # Preflight: verify required tools are available
    local missingTools=()
    for tool in mst flint mlxburn; do
        command -v "$tool" &>/dev/null || missingTools+=("$tool")
    done
    if [[ ${#missingTools[@]} -gt 0 ]]; then
        echo -e "$NOTATION ${RED}Error: Required tool(s) not found: ${YELLOW}${missingTools[*]}${RESET}"
        exit 1
    fi

    # Step 1: Verify MST device via mst status
    local mstCmd="sudo mst status -v"
    echo -e "$NOTATION ${CYAN}Verifying MST device...${RESET}"
    echo -e "$NOTATION Running: ${YELLOW}$mstCmd${RESET}"
    local mstOutput
    mstOutput=$($mstCmd 2>&1)
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: '$mstCmd' failed${RESET}"
        echo "$mstOutput"
        exit 1
    fi
    if ! echo "$mstOutput" | grep -q "$fDevice"; then
        echo -e "$NOTATION ${RED}Error: Device ${YELLOW}$fDevice${RED} not found in mst status output${RESET}"
        echo "$mstOutput"
        exit 1
    fi
    echo -e "$NOTATION ${GREEN}✓ Device $fDevice found${RESET}"

    # Step 2: Resolve model and .mlx file
    # Use first model from --models if specified, otherwise fBuildModel (set by preConfigure)
    if [[ ${#fModels[@]} -eq 1 ]]; then
        fBuildModel="${fModels[0]}"
    fi
    local mlxFile
    if [[ -n "$fFirmware" ]]; then
        mlxFile="$fFirmware"
    else
        mlxFile="${MODEL_MLX_FILE[$fBuildModel]}"
        if [[ -z "$mlxFile" ]]; then
            echo -e "$NOTATION ${RED}Error: No .mlx mapping for model ${YELLOW}$fBuildModel${RESET}"
            echo -e "$NOTATION Tip: use --firmware <path> to specify a custom .mlx file"
            exit 1
        fi
    fi
    if [[ ! -f "$mlxFile" ]]; then
        echo -e "$NOTATION ${RED}Error: .mlx file not found: ${YELLOW}$mlxFile${RESET}"
        if [[ -z "$fFirmware" ]]; then
            echo -e "$NOTATION Have you built the model first? (jk -o -m $fBuildModel)"
        fi
        exit 1
    fi
    echo -e "$NOTATION ${GREEN}✓ Using .mlx: ${CYAN}$mlxFile${RESET}"

    # Step 3: Query PSID from device
    echo -e "$NOTATION ${CYAN}Querying PSID from device...${RESET}"
    echo -e "$NOTATION Running: ${YELLOW}sudo flint -d $fDevice q${RESET}"
    local flintOutput
    flintOutput=$(sudo flint -d "$fDevice" q 2>&1)
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: flint query failed${RESET}"
        echo "$flintOutput"
        exit 1
    fi
    echo "$flintOutput"
    local psid
    psid=$(echo "$flintOutput" | grep "PSID:" | grep -v Orig | awk '{print $2}')
    if [[ -z "$psid" ]]; then
        echo -e "$NOTATION ${RED}Error: Could not extract PSID from flint output${RESET}"
        exit 1
    fi
    echo -e "$NOTATION ${GREEN}✓ PSID: ${CYAN}$psid${RESET}"

    # Step 4: Resolve INI file (--ini overrides PSID-based prs/ lookup)
    local iniFile
    if [[ -n "$fIniFile" ]]; then
        iniFile="$fIniFile"
    else
        echo -e "$NOTATION ${CYAN}Looking up INI file for PSID $psid...${RESET}"
        iniFile=$(grep -rn "$psid" prs/ 2>/dev/null | grep '\.ini:' | head -1 | awk -F: '{print $1}')
        if [[ -z "$iniFile" ]]; then
            echo -e "$NOTATION ${RED}Error: No INI file found for PSID ${YELLOW}$psid${RED} under prs/${RESET}"
            echo -e "$NOTATION Tip: use --ini <path> to specify a custom INI file"
            exit 1
        fi
    fi
    if [[ ! -f "$iniFile" ]]; then
        echo -e "$NOTATION ${RED}Error: INI file not found: ${YELLOW}$iniFile${RESET}"
        exit 1
    fi
    if [[ -n "$fIniFile" ]]; then
        echo -e "$NOTATION ${GREEN}✓ Using specified INI (--ini): ${CYAN}$iniFile${RESET}"
    else
        echo -e "$NOTATION ${GREEN}✓ Using INI: ${CYAN}$iniFile${RESET}"
    fi

    # Step 5: Generate flash image via mlxburn
    local imageBin="image.bin"
    echo -e "$NOTATION ${CYAN}Generating flash image...${RESET}"
    local mlxburnCmd="mlxburn image -f $mlxFile -c $iniFile -o $imageBin"
    echo -e "$NOTATION Running: ${YELLOW}$mlxburnCmd${RESET}"
    eval "$mlxburnCmd"
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: mlxburn image generation failed${RESET}"
        exit 1
    fi
    if [[ ! -f "$imageBin" ]]; then
        echo -e "$NOTATION ${RED}Error: $imageBin was not created${RESET}"
        exit 1
    fi
    echo -e "$NOTATION ${GREEN}✓ Flash image generated: ${CYAN}$imageBin${RESET}"

    # Step 6: Burn image to device
    echo -e "$NOTATION ${CYAN}Burning $imageBin to $fDevice...${RESET}"
    local flintBurnCmd="sudo flint -d $fDevice -i $imageBin -y burn"
    echo -e "$NOTATION Running: ${YELLOW}$flintBurnCmd${RESET}"
    eval "$flintBurnCmd"
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: flint burn failed${RESET}"
        exit 1
    fi
    local burnEndTime=$(date +%s)
    echo -e "$NOTATION ${GREEN}✓ Burn completed successfully${RESET} at $(getCurrentTime) in $(formatElapsed $((burnEndTime - burnStartTime)))"
    echo "$SEPARATOR"
}

runBurnOfficial() {
    [[ -z "$fBurnOfficial" ]] && return

    if [[ -z "$fDevice" ]]; then
        echo -e "$NOTATION ${RED}Error: --burn-official requires --device <mst_device>${RESET}"
        exit 1
    fi

    local burnStartTime=$(date +%s)

    echo "$SEPARATOR"
    echo -e "$NOTATION ${BOLD}Burn Official Release${RESET}"
    echo "$SEPARATOR"

    if ! command -v mlxburn &>/dev/null; then
        echo -e "$NOTATION ${RED}Error: Required tool not found: ${YELLOW}mlxburn${RESET}"
        exit 1
    fi

    resolveReleasePath "$fBurnOfficial"
    echo -e "$NOTATION ${GREEN}✓ Release dir: ${CYAN}$fResolvedFwDir${RESET}"

    local burnCmd="sudo mlxburn -d $fDevice -fw_dir $fResolvedFwDir/ -y"
    echo -e "$NOTATION ${CYAN}Burning official FW to $fDevice...${RESET}"
    echo -e "$NOTATION Running: ${YELLOW}$burnCmd${RESET}"
    eval "$burnCmd"
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: mlxburn failed${RESET}"
        echo -e "$NOTATION ${YELLOW}Hint: If MFE_NO_FLASH_DETECTED, try: sudo mst restart${RESET}"
        exit 1
