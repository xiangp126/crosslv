runRegMalloc() {
    [[ -z "$fRegMalloc" ]] && return
    local server="$fRegMalloc"
    local hours=8
    echo "$SEPARATOR"
    echo -e "$NOTATION ${CYAN}Allocating regression server $server for ${hours}h...${RESET}"
    local cmd="malloc $server -t $hours"
    echo -e "$NOTATION Running: ${YELLOW}$cmd${RESET}"

    # Tee so the user sees malloc's live output AND we can parse:
    #   - the actual allocated hours (server may cap the request), and
    #   - the "Resource locked by <holder> until <date> (IST)" error so we can
    #     show the unlock time in the local machine's timezone. noga reports
    #     Israel local time, so we just hand the timestamp to `date` as
    #     Asia/Jerusalem and let tzdata do the DST math and the conversion to
    #     local time -- no manual offset/DST handling here.
    local tmpFile
    tmpFile=$(mktemp)
    eval "$cmd" 2>&1 | tee "$tmpFile"
    local status=${PIPESTATUS[0]}

    local actualHours lockedLine
    actualHours=$(grep -E '^Going to lock' "$tmpFile" | head -1 \
                  | sed -nE 's/.*for ([0-9]+) hours.*/\1/p')
    lockedLine=$(grep -E 'Resource locked by' "$tmpFile" | head -1)
    rm -f "$tmpFile"

    if [[ $status -ne 0 ]]; then
        echo "$SEPARATOR"
        if [[ -n "$lockedLine" ]]; then
            local holder until_dt
            holder=$(echo "$lockedLine"   | sed -nE 's/.*locked by ([^ ]+) until.*/\1/p')
            # noga prints "DD-MON-YY HH.MI.SS (IST)" in Israel local time. Strip
            # the trailing "(...)" label and turn the dots into colons so `date`
            # can parse the time part.
            until_dt=$(echo "$lockedLine" | sed -nE 's/.*until[[:space:]]+(.+)[[:space:]]+\([A-Za-z]+\).*/\1/p' | tr '.' ':')

            # Interpret it as Asia/Jerusalem and let the local machine convert to
            # its own timezone -- tzdata handles Israel's DST for us.
            local localTime=""
            [[ -n "$until_dt" ]] && \
                localTime=$(date -d "TZ=\"Asia/Jerusalem\" $until_dt" '+%Y-%m-%d %H:%M:%S %Z' 2>/dev/null)

            echo -e "$NOTATION ${RED}✗ $server is locked by ${YELLOW}${holder:-?}${RESET}"
            if [[ -n "$until_dt" ]]; then
                echo -e "$NOTATION until ${CYAN}$until_dt${RESET} ${GREY}(Israel)${RESET}"
                [[ -n "$localTime" ]] && \
                    echo -e "$NOTATION ====> ${CYAN}$localTime${RESET} ${GREY}(local)${RESET}"
            fi
        else
            echo -e "$NOTATION ${RED}Error: malloc failed for $server${RESET}"
        fi
        exit 1
    fi
    if [[ -n "$actualHours" && "$actualHours" != "$hours" ]]; then
        echo -e "$NOTATION ${GREEN}✓ Allocated $server for ${actualHours}h${RESET}" \
                "${GREY}(requested ${hours}h, capped by server max)${RESET}"
    elif [[ -n "$actualHours" ]]; then
        echo -e "$NOTATION ${GREEN}✓ Allocated $server for ${actualHours}h${RESET}"
    else
        echo -e "$NOTATION ${GREEN}✓ Allocated $server for ${hours}h${RESET}"
    fi
    echo "$SEPARATOR"
}

