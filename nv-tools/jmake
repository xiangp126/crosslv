    local burnEndTime=$(date +%s)
    echo -e "$NOTATION ${GREEN}✓ Official FW burned successfully${RESET} at $(getCurrentTime) in $(formatElapsed $((burnEndTime - burnStartTime)))"

    echo -e "$NOTATION ${CYAN}Verifying burned version...${RESET}"
    sudo flint -d "$fDevice" q | grep "FW Version"
    echo "$SEPARATOR"
}

runFWReset() {
    [[ -z "$fFwReset" ]] && return

    # Resolve the fwreset<chipKey> suffix from both -m model and --device path
    # (when set) so we can cross-check that the user-specified pair is
    # internally consistent (e.g. reject -m carmel + --device /dev/mst/mt41692_*).
    #
    # NOTE: do NOT name any local here `key` -- /mswg/.../.fwvalias runs
    # `for key in ...` at source time and bash's dynamic scoping would let
    # that for-loop clobber a `local key` declared in this function.
    local model="" devId="" keyFromModel="" keyFromDevice="" chipKey=""
    # fModels[0] reflects the user's explicit -m/--models choice; fBuildModel
    # is the build-side default (may be "mustang" even when user picked
    # something else via -m). Strip known variant suffixes (_ethlt/_codecov/cov)
    # so e.g. "arava_ethlt" still maps to arava -> 'a'.
    if [[ ${#fModels[@]} -gt 0 ]]; then
        model="${fModels[0]}"
        model="${model%_ethlt}"
        model="${model%_codecov}"
        model="${model%cov}"
    elif [[ -n "$fBuildModel" ]]; then
        model="$fBuildModel"
    fi
    if [[ -n "$model" ]]; then
        keyFromModel="${MODEL_FWRESET_KEY[$model]}"
    fi
    if [[ -n "$fDevice" ]]; then
        devId=$(echo "$fDevice" | sed -nE 's|.*mt([0-9]+)_pciconf.*|\1|p')
        [[ -n "$devId" ]] && keyFromDevice="${DEVID_FWRESET_KEY[$devId]}"
    fi

    # Consistency check: if both sides resolved AND they disagree, hard-error.
    # One side resolving and the other being empty is fine (empty = "no opinion").
    if [[ -n "$keyFromModel" && -n "$keyFromDevice" && "$keyFromModel" != "$keyFromDevice" ]]; then
        echo -e "$NOTATION ${RED}Error: -m and --device refer to different chips${RESET}"
        echo -e "$NOTATION   -m ${YELLOW}$model${RESET} -> fwreset${keyFromModel}"
        echo -e "$NOTATION   --device ${YELLOW}$fDevice${RESET} (devid $devId) -> fwreset${keyFromDevice}"
        echo -e "$NOTATION Drop one or fix the mismatch."
        exit 1
    fi

    # Prefer the model-derived key (explicit user intent) when both agree
    # or only the model side resolved.
    chipKey="${keyFromModel:-$keyFromDevice}"

    if [[ -z "$chipKey" ]]; then
        echo -e "$NOTATION ${RED}Error: --fw-reset could not resolve chip key${RESET}"
        if [[ -n "$model" ]]; then
            echo -e "$NOTATION Model ${YELLOW}$model${RESET} has no fwreset<key> alias (alpine/CX10 not yet supported)"
        elif [[ -n "$fDevice" ]]; then
            if [[ -z "$devId" ]]; then
                echo -e "$NOTATION Device ${YELLOW}$fDevice${RESET} did not match mt<devid>_pciconf<N>"
            else
                echo -e "$NOTATION Device ${YELLOW}$fDevice${RESET} devid ${YELLOW}$devId${RESET} has no fwreset<key> mapping"
            fi
        else
            echo -e "$NOTATION Tip: pass ${YELLOW}-m <model>${RESET} or ${YELLOW}--device <mst_device>${RESET}"
        fi
        exit 1
    fi

    local resetStartTime=$(date +%s)
    echo "$SEPARATOR"
    echo -e "$NOTATION ${CYAN}Resetting FW via fwreset${chipKey}...${RESET}"
    # When the user explicitly passes --device, honor it: bypass the
    # interactive MST device chooser baked into the fwreset<key> alias
    # (func_alias_reset -> func_get_device_by_type prompts on multi-device
    # hosts). We replicate what func_alias_reset does -- clear the flint
    # semaphore then call fwresetfunc directly with -d <device> -- so the
    # chosen device is passed straight through to the wrapper. Without
    # --device we keep the alias path so auto-detection still works.
    local cmd
    if [[ -n "$fDevice" ]]; then
        local flintDev="${fDevice%%,*}"
        sudo flint -d "$flintDev" --clear_semaphore
        cmd="fwresetfunc ${project_full_names[$chipKey]} -d $fDevice"
    else
        cmd="fwreset${chipKey}"
    fi
    # Newer chips (BF-3 'm', CX-8 'gl', CX-9 'ar') require --run_new_fwreset:
    # the old wrapper (fw_reset_wrapper_shared.sh) dispatches to per-chip
    # <chip>_fw_reset.sh scripts that don't exist / work for these. The new
    # wrapper (fw_reset_wrapper.sh) goes through unified fwreset.py.
    case "$chipKey" in
        m|gl|ar) cmd="$cmd --run_new_fwreset" ;;
    esac
    echo -e "$NOTATION Running: ${YELLOW}$cmd${RESET}"
    eval "$cmd"
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: $cmd failed${RESET}"
        exit 1
    fi
    local resetEndTime=$(date +%s)
    echo -e "$NOTATION FW reset completed at $(getCurrentTime) in $(formatElapsed $((resetEndTime - resetStartTime)))"
    echo "$SEPARATOR"
}

runFwQuery() {
    [[ -z "$fFwQuery" ]] && return
    if [[ -z "$fDevice" ]]; then
        echo -e "$NOTATION ${RED}Error: --fw-query requires --device <mst_device>${RESET}"
        exit 1
