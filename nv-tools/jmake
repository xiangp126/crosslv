doEarlyExitJobs() {
    [ -n "$fDockerGroup" ]   && { runDockerGroup; exit 0; }
    [ -n "$fLinkWorkspace" ] && [ -z "$fGenerateCompileCmds" ] && { linkWorkspaceFiles; exit 0; }
    [ -n "$fPatch" ] && [ -z "$fNeedBuild" ] && { patchUtopxProjBuild; exit 0; }
    [ -n "$fMftInstall" ]    && { runMftInstall; fMftRestart=true; runMftRestart; exit 0; }
    [ -n "$fMftRestart" ]    && { runMftRestart; exit 0; }
    [ -n "$fMftStop" ]       && { runMftStop; [ -n "$fMftStart" ] && runMftStart; exit 0; }
    [ -n "$fMftStart" ]      && { runMftStart; exit 0; }
    [ -n "$fOfedRestart" ]   && { runOfedRestart; exit 0; }
    [ -n "$fOfedStop" ]      && { runOfedStop; [ -n "$fOfedStart" ] && runOfedStart; exit 0; }
    [ -n "$fOfedStart" ]     && { runOfedStart; exit 0; }
    [ -n "$fFwQuery" ]       && { runFwQuery; exit 0; }
    [ -n "$fBurnOfficial" ]  && { runBurnOfficial; [ -n "$fFwReset" ] && runFWReset; exit 0; }
    [ -n "$fFwReset" ] && [ -z "$fBurn" ] && { runFWReset; exit 0; }
    [ -n "$fPowerCycle" ]    && { runPowerCycle; exit 0; }
    [ -n "$fPowerOn" ]       && { runPowerOn; exit 0; }
    [ -n "$fPowerOff" ]      && { runPowerOff; exit 0; }
    [ -n "$fRegInfo" ]       && { runRegInfo; exit 0; }
    [ -n "$fRegMalloc" ]     && { runRegMalloc; exit 0; }
    [ -n "$fRegMine" ]       && { runRegMine; exit 0; }
    [ -n "$fRegIdle" ]       && { runRegIdle; exit 0; }
    [ -n "$fRegExtend" ]     && { runRegExtend; exit 0; }
    [ -n "$fRegCancel" ]     && { runRegCancel; exit 0; }
}

main() {
    runGitOptions
    preConfigure "$@"
    # Auto-resume from saved state if available (use --scratch to override)
    [[ ${#fModels[@]} -gt 0 ]] && loadLoopState
    # Source .fwvalias inline here (in main()'s scope) for the commands that
    # actually need it. MUST be inline — not in a helper function — because
    # top-level `declare -A project_full_names=(...)` etc. in .fwvalias
    # become LOCAL when source runs inside a function and vanish on return.
    # Sourcing in main()'s scope keeps the arrays visible via bash dynamic
    # scoping to every function called from main (doEarlyExitJobs, runFWReset,
    # runRegInfo, ...). Aliases are always global so they're unaffected.
    if [[ -n "$fFwReset" || -n "$fRegInfo" || -n "$fRegMalloc" \
       || -n "$fRegMine"  || -n "$fRegIdle"  || -n "$fRegExtend" \
       || -n "$fRegCancel" ]]; then
        if [[ ! -f "$FWV_ALIAS_FILE" ]]; then
            echo -e "$NOTATION ${RED}Error: required alias file not found: ${YELLOW}$FWV_ALIAS_FILE${RESET}" >&2
            exit 1
        fi
        shopt -s expand_aliases
        # shellcheck disable=SC1090
        source "$FWV_ALIAS_FILE"
    fi
    doEarlyExitJobs
    validateArguments
    showLogo
    printBuildFlags
    cleanTheRepo
    updateSubmodules
    patchUtopxProjBuild
    # Handle models mode (--models) or regular build.
    # utopx has no model concept, so it always takes the single-build path
    # regardless of any -m/-a flags the user may have passed.
    if [[ "$fRepoType" != "utopx" && ${#fModels[@]} -gt 0 ]]; then
        runLoopModels
    else
        runBuildCommands
    fi
    runPostBuildHousekeeping
    runBurn
    runFWReset
}

main "$@"
