requireGitRepo() {
    if ! git rev-parse --is-inside-work-tree &>/dev/null; then
        echo -e "$NOTATION ${RED}Error: Not in a git repository.${RESET}" >&2
        exit 1
    fi
}

# Detect repo type by matching $fWorkingDir against known repo names.
# jmake only knows how to drive golan, nicx, and utopx trees; anything else
# is rejected so the user is not silently fed a wrong build command.
detectRepoType() {
    case "${fWorkingDir,,}" in
        */utopx*) fRepoType="utopx" ;;
        */nicx*)  fRepoType="nicx" ;;
        */golan*) fRepoType="golan" ;;
        *)
            echo -e "$NOTATION ${RED}Error: Unknown repo type for ${YELLOW}$fWorkingDir${RESET}" >&2
            echo -e "$NOTATION ${RED}Path must contain one of: ${CYAN}golan${RED}, ${CYAN}nicx${RED}, ${CYAN}utopx${RESET}" >&2
            echo -e "$NOTATION Tip: use ${YELLOW}-w <dir>${RESET} to point at a supported tree" >&2
            exit 1
            ;;
    esac
}

# $1: available models, $2: target model
searchBuildModel() {
    matchedModels=()
    local availModels="$1"
    local targetModel="$2"

    for model in $availModels; do
        if [[ "$model" == *"$targetModel"* ]]; then
            matchedModels+=("$model")
            if [[ "$model" == "$targetModel" ]]; then
                fBuildModel="$model"
            fi
        fi
    done

    COLOR="$RED"
    case ${#matchedModels[@]} in
        0)
            echo -e "$NOTATION No matched model found for ${COLOR}$targetModel${RESET}"
            echo -e "$NOTATION Available models: ${CYAN}$GOLAN_MODELS${RESET}"
            exit 1
            ;;
        1)
            fBuildModel="${matchedModels[0]}"
            ;;
        *)
            echo "$NOTATION Multiple matched models found for $targetModel"
            echo "$NOTATION Please specify the model from the following list:"
            for model in "${matchedModels[@]}"; do
                echo -e "${COLOR}$model${RESET}"
            done
            exit 1
            ;;
    esac
}

preConfigure() {
    # Only flags whose downstream code touches the source tree gate
    # repo-type detection. Early-exit jobs (MFT/OFED/Power/Docker/BurnOfficial/
    # FwReset-alone/--reg-*) are self-contained and must work from any cwd.
    if [[ -n "$fClean"                 ]] ||
       [[ -n "$fNeedBuild"             ]] ||
       [[ -n "$fGenerateCompileCmds"   ]] ||
       [[ -n "$fRMCompileCommandsJson" ]] ||
       [[ -n "$fLinkWorkspace"         ]] ||
       [[ -n "$fPatch"                 ]] ||
       [[ -n "$fBurn"                  ]] ||
       [[ -n "$fFwReset"               ]]; then
        fPrintBuildFlags=true
    fi
    [[ -z "$fPrintBuildFlags" ]] && return

    fWorkingDir=$(realpath "$fWorkingDir")
    cd "$fWorkingDir" || exit 1

    # Early-exit jobs (e.g. `--fw-reset -m carmel`) only use -m to pick a chip
    # key for fwreset<key>; they don't touch the source tree. Skip repo-type
    # detection AND the build.sh check, but still normalize fBuildModel so
    # the alias dispatcher in runFWReset can map it.
    if [[ -n "$fFwReset" && -z "$fBurn" && -z "$fBurnOfficial" && \
          -z "$fClean"  && -z "$fGenerateCompileCmds" && \
          -z "$fLinkWorkspace" ]]; then
        fBuildModel=$(echo "$fBuildModel" | tr '[:upper:]' '[:lower:]')
        [[ -z "$fBuildModel" && -z "$fDevice" ]] && fBuildModel="$DEFAULT_MODEL"
        return
    fi
    detectRepoType

    # Device-only operations don't need a golan_fw source tree
    if [[ -z "$fNeedBuild" && -z "$fBurn" && -z "$fClean" && -z "$fGenerateCompileCmds" && -z "$fLinkWorkspace" ]]; then
        return
    fi

    # Verify this is a golan_fw project
    if [[ ! -x "$BUILD_SCRIPT" ]]; then
        echo -e "$NOTATION ${RED}Error: $BUILD_SCRIPT not found in ${YELLOW}$fWorkingDir${RESET}"
        echo -e "$NOTATION Tip: use ${YELLOW}-w <golan_fw_dir>${RESET} to specify the working directory"
        exit 1
    fi

    # utopx has no model concept: ./build.sh takes no -d argument and no variants.
    # Silently drop any model/variant flags the user may have passed so a stray
    # `jk -o -m carmel` in utopx still runs a bare ./build.sh.
    if [[ "$fRepoType" == "utopx" ]]; then
        fBuildModel=""
        fModels=()
        fModelsSkip=()
        fEthlt=
        fCodecov=
        fCov=
        if [[ -n "$fGenerateCompileCmds" ]]; then
            fPatch=true
            [ -z "$fCleanExplicit" ] && fClean=
            [ -z "$fRMExplicit" ] && fRMCompileCommandsJson=
        fi
        return
    fi

    # Lower case the build model
    fBuildModel=$(echo "$fBuildModel" | tr '[:upper:]' '[:lower:]')
    if [ -z "$fBuildModel" ]; then
        fBuildModel="$DEFAULT_MODEL"
    else
        searchBuildModel "$GOLAN_MODELS" "$fBuildModel"
    fi

    # Variant flags append all available models of that variant type
    if [[ -n "$fEthlt" ]]; then
        for model in $ETHLT_MODELS; do fModels+=("${model}_ethlt"); done
        fNeedBuild=true
    fi
    if [[ -n "$fCodecov" ]]; then
        for model in $CODECOV_MODELS; do fModels+=("${model}_codecov"); done
        fNeedBuild=true
    fi
    if [[ -n "$fCov" ]]; then
        for model in $COV_MODELS; do fModels+=("${model}cov"); done
        fNeedBuild=true
    fi
}

validateArguments() {
    if [[ ${#fModelsSkip[@]} -gt 0 && ${#fModels[@]} -eq 0 ]]; then
        echo -e "$NOTATION ${RED}Error: --skip requires --models or --all${RESET}"
        exit 1
    fi

    if [[ -n "$fBurn" && -z "$fDevice" ]]; then
        echo -e "$NOTATION ${RED}Error: --burn requires --device <mst_device>${RESET}"
        exit 1
    fi

    # --fw-reset now dispatches to fwreset<key> aliases (see runFWReset).
    # It accepts either -m <model> or --device <mst_device>; if neither is
    # supplied, the build's default model is used. Consistency between -m
    # and --device is enforced inside runFWReset.

    if [[ -n "$fBurn" && ${#fModels[@]} -gt 1 ]]; then
        echo -e "$NOTATION ${RED}Error: --burn does not support multiple models (loop mode)${RESET}"
        exit 1
    fi

    if [[ -n "$fBurnOfficial" && -z "$fDevice" ]]; then
        echo -e "$NOTATION ${RED}Error: --burn-official requires --device <mst_device>${RESET}"
        exit 1
    fi

    if [[ -n "$fBurnOfficial" && -n "$fBurn" ]]; then
        echo -e "$NOTATION ${RED}Error: --burn-official and --burn are mutually exclusive${RESET}"
        exit 1
    fi

    # Auto-set attempt to 2 when building multiple models (unless explicitly set)
    if [[ ${#fModels[@]} -gt 1 && $fMaxBuildAttempt -eq 1 ]]; then
        fMaxBuildAttempt=2
    fi
}

printBuildFlags() {
    echo $SEPARATOR
    if [ -n "$fPrintBuildFlags" ]; then
        COLOR="$GREEN"
        echo -e "${BOLD}Build Flags:${RESET}"
        [ -n "$fClean" ]                 && echo -e "[C] ${COLOR}Clean${RESET} the build"
        [ -n "$fGitClean" ]              && echo -e "[G] ${COLOR}Git deep clean${RESET} (git clean -fdx)"
        [ -n "$fNeedBuild" ]             && echo -e "[o] ${COLOR}Build${RESET} the project"
        [ -n "$fNoVerbose" ]             && echo -e "[V] ${COLOR}No Verbose${RESET} mode"
        [ -n "$fRMCompileCommandsJson" ] && echo -e "[/] ${COLOR}Remove${RESET} existing $fCompileCommandsJson"
        [ -n "$fGenerateCompileCmds" ]   && echo -e "[g] ${COLOR}Generate${RESET} $fCompileCommandsJson"
        [ -n "$fTrackIncludes" ]         && echo -e "[T] ${COLOR}Track Includes${RESET} (-D TRACK_INCLUDES=1)"
        [ -n "$fPatch" ]                 && echo -e "[P] ${COLOR}Patch${RESET} proj_build.sh (guard compile_commands.json relink)"
        [ -n "$fEthlt" ]                 && echo -e "[E] ${COLOR}Ethlt${RESET} variant (_ethlt)"
        [ -n "$fCodecov" ]               && echo -e "[K] ${COLOR}Codecov${RESET} variant (_codecov)"
        [ -n "$fCov" ]                   && echo -e "[O] ${COLOR}Cov${RESET} variant (cov)"
        [ -n "$fLinkWorkspace" ]         && echo -e "[L] ${COLOR}Link${RESET} workspace files ($fCompileCommandsJson, .clangd, ~/.claude/$CLAUDE_MD)"
        [ -n "$fBurn" ]                  && echo -e "[B] ${COLOR}Burn${RESET} FW image to device"
        [ -n "$fBurnOfficial" ]          && echo -e "[B] ${COLOR}Burn Official:${RESET} $fBurnOfficial"
        [ -n "$fFwReset" ]               && echo -e "[R] ${COLOR}Reset${RESET} FW on device (fwreset<key>)"
        [ -n "$fDevice" ]                && echo -e "[d] ${COLOR}Device:${RESET} $fDevice"
        [ -n "$fFirmware" ]              && echo -e "[F] ${COLOR}Firmware:${RESET} $fFirmware"
        [ -n "$fIniFile" ]               && echo -e "[i] ${COLOR}Ini:${RESET}      $fIniFile"
        [ -n "$fMftInstall" ]            && echo -e "[M] ${COLOR}MFT Install${RESET}"
        [ -n "$fMftStart" ]              && echo -e "[M] ${COLOR}MST Start${RESET}"
        [ -n "$fMftStop" ]               && echo -e "[M] ${COLOR}MST Stop${RESET}"
        [ -n "$fMftRestart" ]            && echo -e "[M] ${COLOR}MST Restart${RESET} (stop → start)"
        [ -n "$fOfedRestart" ]           && echo -e "[↻] ${COLOR}OFED Restart${RESET} (stop → start)"
        [ -n "$fOfedStart" ]             && echo -e "[^] ${COLOR}OFED Start${RESET}"
        [ -n "$fOfedStop" ]              && echo -e "[v] ${COLOR}OFED Stop${RESET}"
        [ -n "$fPowerCycle" ]            && echo -e "[⏻] ${COLOR}Power Cycle:${RESET} $fPowerCycle"
        [ -n "$fPowerOn" ]               && echo -e "[⏻] ${COLOR}Power On:${RESET} $fPowerOn"
        [ -n "$fPowerOff" ]              && echo -e "[⏻] ${COLOR}Power Off:${RESET} $fPowerOff"
        [ -n "$fDockerGroup" ]           && echo -e "[🐳] ${COLOR}Docker Group${RESET} (add $USER to docker group)"
    fi

    if [ -n "$fNeedBuild" ]; then
        echo -e "${BOLD}Build Options:${RESET}"
        COLOR="$RED"
        [ -n "$fRepoType" ] && echo -e "[r] Repo:         ${COLOR}$fRepoType${RESET}"
        if [[ "$fRepoType" == "utopx" ]]; then
            : # utopx has no model concept; skip the model row entirely
        elif [[ ${#fModels[@]} -gt 1 || ${#fModelsSkip[@]} -gt 0 ]]; then
            echo -e "[L] Build Mode:   ${COLOR}Loop Mode${RESET} (models one by one)"
            if [[ ${#fModels[@]} -gt 0 ]]; then
                echo -e "[I] Include Only: ${GREEN}${fModels[*]}${RESET}"
            fi
            if [[ ${#fModelsSkip[@]} -gt 0 ]]; then
                echo -e "[S] Skip Models:  ${YELLOW}${fModelsSkip[*]}${RESET}"
            fi
        elif [[ ${#fModels[@]} -eq 1 ]]; then
            echo -e "[m] Build Model:  ${COLOR}$(getModelDisplayName "${fModels[0]}")${RESET}"
        else
            echo -e "[m] Build Model:  ${COLOR}$(getModelDisplayName "$fBuildModel")${RESET}"
        fi
        COLOR="$CYAN"
        echo -e "[w] Build Directory: ${COLOR}$fWorkingDir${RESET}"
        echo -e "[T] Maximum Build Attempts: ${COLOR}$fMaxBuildAttempt${RESET}"
        echo -e "[j] Parallel Jobs: ${COLOR}$fNumOfJobs${RESET}"
    fi
    echo "$SEPARATOR"
    echo -en "${BOLD}Input Command: ${RESET}" >&2
    echo -e "${LIGHTYELLOW}$fInputCmd${RESET}" >&2
}

cleanTheRepo() {
    [ -z "$fClean" ] && return
    cd "$fWorkingDir" || exit
    echo -e "$NOTATION ${CYAN}Cleaning the build${RESET}"

    # Preserve .mlx firmware images across clean (make clean removes *.mlx)
    local mlxBackup
    mlxBackup=$(mktemp -d)
    local mlxCount=0
    for f in *.mlx; do
        [[ -f "$f" ]] || continue
        cp "$f" "$mlxBackup/"
        ((mlxCount++))
    done

    # Clean via the repo's own build script for all repo types ($BUILD_SCRIPT == ./build.sh):
    #   golan/nicx -> build.sh runs 'make clean' inside the container
    #   utopx      -> build.sh forwards -C to proj_build.sh, which rm -rf's the CMake/Ninja build tree
    local cleanCmd="$BUILD_SCRIPT -C"
    echo -e "$NOTATION Running: ${BLUE}$cleanCmd${RESET}"
    echo $SEPARATOR
    COLOR=$MAGENTA
    eval "$cleanCmd"
    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${COLOR}There seems to be some errors during the clean process${RESET}"
        echo -e "$NOTATION ${RESET}But going on anyway${RESET}"
    else
        echo -e "$NOTATION ${COLOR}Cleaned the build successfully.${RESET}"
    fi

    # Restore preserved .mlx files
    if [[ $mlxCount -gt 0 ]]; then
        cp "$mlxBackup"/*.mlx .
        echo -e "$NOTATION ${GREEN}✓ Restored $mlxCount .mlx file(s)${RESET}"
    fi
    rm -rf "$mlxBackup"

    # Remove $fCompileCommandsJson if requested
    if [ -n "$fRMCompileCommandsJson" ]; then
        if [ -L "$fCompileCommandsJson" ]; then
            # It's a symlink - remove both the symlink and the real file it points to
            local realFile
            realFile=$(readlink -f "$fCompileCommandsJson")
            echo -e "$NOTATION Removing symlink ${CYAN}$fCompileCommandsJson${RESET}"
            rm -f "$fCompileCommandsJson"
            if [ -f "$realFile" ]; then
                echo -e "$NOTATION Removing real file ${CYAN}$realFile${RESET}"
                rm -f "$realFile"
            fi
        elif [ -f "$fCompileCommandsJson" ]; then
            # It's a regular file - just remove it
            echo -e "$NOTATION Removing ${CYAN}$fCompileCommandsJson${RESET}"
            rm -f "$fCompileCommandsJson"
        fi
    fi
}

updateSubmodules() {
    # Only update submodules when building
    [ -z "$fNeedBuild" ] && return
    cd "$fWorkingDir" || exit

    # Check if submodules are initialized by looking for a key file
    if [[ ! -f "shared/glib/glib.mak" ]]; then
        echo -e "$NOTATION ${CYAN}Initializing submodules with: ${YELLOW}git submodule update --init --recursive${RESET}"
        eval "git submodule update --init --recursive"
    else
        echo -e "$NOTATION ${CYAN}Updating submodules with: ${YELLOW}git submodule update --recursive${RESET}"
        eval "git submodule update --recursive"
    fi

    if [[ $? -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: Submodule update failed${RESET}"
        exit 1
    else
        echo -e "$NOTATION ${GREEN}Submodules updated successfully.${RESET}"
    fi
}

patchUtopxProjBuild() {
    [ -z "$fPatch" ] && return
    if [[ "$fRepoType" != "utopx" ]]; then
        echo -e "$NOTATION ${GREY}--patch only applies to utopx; nothing to do for ${fRepoType:-this repo}${RESET}"
        return
    fi
    cd "$fWorkingDir" || exit
    local pf="proj_build.sh"

    echo "$SEPARATOR"
    echo -e "$NOTATION ${BOLD}Patch: clangd database persistence${RESET}"
    echo -e "$NOTATION ${CYAN}→${RESET} Target: ${YELLOW}$fWorkingDir/$pf${RESET}"

    if [[ ! -f "$pf" ]]; then
        echo -e "$NOTATION ${RED}✗ Patch target not found: $pf${RESET}"
        echo "$SEPARATOR"
        exit 1
    fi
    local guard='[ ! -e "${UTOPX_PROJECT_ROOT}/compile_commands.json" ]'
    if grep -qF "$guard" "$pf"; then
        echo -e "$NOTATION ${GREEN}✓ Already patched${RESET} — plain builds won't overwrite the clangd database"
        echo "$SEPARATOR"
        return
    fi
    if ! grep -q '^if \[ -f compile_commands.json \]; then' "$pf"; then
        echo -e "$NOTATION ${YELLOW}✗ Skipped${RESET} — relink anchor not found in $pf"
        echo "$SEPARATOR"
        return
    fi
    echo -e "$NOTATION ${CYAN}→${RESET} Guarding the compile_commands.json relink..."
    if awk '
        /^if \[ -f compile_commands\.json \]; then/ && !done1 {
            print "if [ -f compile_commands.json ] && [ ! -e \"${UTOPX_PROJECT_ROOT}/compile_commands.json\" ]; then"
            done1 = 1
            next
        }
        { print }
    ' "$pf" > "$pf.jmake.tmp"; then
        cat "$pf.jmake.tmp" > "$pf"
        rm -f "$pf.jmake.tmp"
        echo -e "$NOTATION ${GREEN}✓ Done${RESET} — plain builds will no longer overwrite the clangd database"
        echo -e "$NOTATION   ${GREY}run ${YELLOW}jk --db${GREY} to (re)generate it${RESET}"
    else
        rm -f "$pf.jmake.tmp"
        echo -e "$NOTATION ${RED}✗ Failed to patch $pf${RESET}"
    fi
    echo "$SEPARATOR"
}

# Print one summary row: "▸   <coloredLabel>   (N) item, item, ..." with wrapping.
# Args: $1 coloredLabel  $2 plainLabel (for width)  $3 count  $4..  items
printSummaryRow() {
    local coloredLabel="$1" plainLabel="$2" count="$3"
    shift 3
    local -a items=("$@")
    local countStr="($count)"
    # Visible header: 3sp + label[8] + 3sp + count[4] + 1sp = 19 chars; continuation = 19 spaces
    local pad="" i
    for ((i=0; i<8-${#plainLabel}; i++)); do pad+=" "; done
    local paddedCount
    paddedCount=$(printf '%-4s' "$countStr")
    local hdrPrefix="   ${coloredLabel}${pad}   ${paddedCount}"
    local indent="                   "
    local maxWidth=60

    if [[ ${#items[@]} -eq 0 ]]; then
        echo -e "$NOTATION$hdrPrefix ${GREY}(none)${RESET}"
        return
    fi

    local line="" lastIdx=$(( ${#items[@]} - 1 ))
    local -a wrappedLines=()
    for i in "${!items[@]}"; do
        local sep=""
        [[ $i -lt $lastIdx ]] && sep=","
        local addition
        if [[ -z "$line" ]]; then
            addition="${items[$i]}$sep"
        else
            addition=" ${items[$i]}$sep"
        fi
        if [[ -n "$line" && $(( ${#line} + ${#addition} )) -gt $maxWidth ]]; then
            wrappedLines+=("$line")
            line="${items[$i]}$sep"
        else
            line+="$addition"
        fi
    done
    [[ -n "$line" ]] && wrappedLines+=("$line")

    local first=1 ln
    for ln in "${wrappedLines[@]}"; do
        if [[ $first -eq 1 ]]; then
            echo -e "$NOTATION$hdrPrefix $ln"
            first=0
        else
            echo -e "$NOTATION$indent$ln"
        fi
    done
}

# Print the aligned Loop Build Summary block (used by both success and failure paths).
# $1 = "success" | "failed"
# $2 = optional stateNote rendered as a "State" row before the closing separator
printLoopBuildSummary() {
    local variant="$1"
    local stateNote="${2:-}"
    local totalTimeFormatted="-"
    if [[ -n "$fLoopStartTime" ]]; then
        local totalTime=$(( $(date +%s) - fLoopStartTime ))
        totalTimeFormatted=$(formatElapsed $totalTime)
    fi

    echo "$SEPARATOR"
    if [[ "$variant" == "failed" ]]; then
        echo -e "$NOTATION ${BOLD}${RED}Loop Build Summary (failed)${RESET}"
    else
        echo -e "$NOTATION ${BOLD}Loop Build Summary${RESET}"
    fi
    echo -e "$NOTATION   Finished   $(getCurrentTime)"
    echo -e "$NOTATION   Total      ${CYAN}$totalTimeFormatted${RESET}"

    printSummaryRow "${GREEN}Verified${RESET}" "Verified" "${#fModelsVerified[@]}" "${fModelsVerified[@]}"

    if [[ ${#fModelsSkipped[@]} -gt 0 ]]; then
        printSummaryRow "${CYAN}Skipped${RESET}" "Skipped" "${#fModelsSkipped[@]}" "${fModelsSkipped[@]}"
    fi

    if [[ "$variant" == "failed" ]]; then
        printSummaryRow "${RED}Failed${RESET}" "Failed" 1 "$fModelsCurrent"
        if [[ ${#fModelsPending[@]} -gt 0 ]]; then
            printSummaryRow "${YELLOW}Pending${RESET}" "Pending" "${#fModelsPending[@]}" "${fModelsPending[@]}"
        fi
    fi

    [[ -n "$stateNote" ]] && echo -e "$NOTATION   State      $stateNote"

    echo "$SEPARATOR"
}

makeBuildCommand() {
    fBuildCommand="$BUILD_SCRIPT"
    if [[ "$fRepoType" == "utopx" ]]; then
        return
    fi
    fBuildCommand+=" -d $fBuildModel"
    fBuildCommand+=" -c $fNumOfJobs"
    [ -z "$fNoVerbose" ] && fBuildCommand+=" --verbose"
    [ -n "$fGenerateCompileCmds" ] && fBuildCommand+=" --bear"
    [ -n "$fNicx" ] && fBuildCommand+=" -D NICX=1"
    [ -n "$fTrackIncludes" ] && fBuildCommand+=" -D TRACK_INCLUDES=1"
}

runBuildCommands() {
    [ -z "$fNeedBuild" ] && return
    cd "$fWorkingDir" || exit

    makeBuildCommand # set fBuildCommand

    local currAttempt=1
    local maxAttempt=$fMaxBuildAttempt
    local buildStartTime buildEndTime
    local eval_status=1
    # Loop mode = building multiple models or filtering with --skip; runLoopModels
    # owns the per-iteration success line and final summary in that case.
    local isLoopMode=$([[ ${#fModels[@]} -gt 1 || ${#fModelsSkip[@]} -gt 0 ]] && echo 1 || echo 0)

    while [[ $currAttempt -le $maxAttempt ]]; do
        buildStartTime=$(date +%s)
        COLOR="$GREEN"
        echo -e "$NOTATION Running: ${LIGHTYELLOW}$fBuildCommand${RESET}"
        echo -e "$NOTATION ${COLOR}Build attempt $currAttempt/$maxAttempt${RESET}"
        echo "$SEPARATOR"
        sleep 1

        eval "$fBuildCommand"
        eval_status=$?

        if [[ $eval_status -eq 0 ]]; then
            break
        else
            currAttempt=$((currAttempt + 1))
        fi
    done
    buildEndTime=$(date +%s)

    if [[ $eval_status -ne 0 ]]; then
        echo -e "$NOTATION ${RED}✗ $(getModelDisplayName "$fBuildModel") build failed${RESET}"
        if [[ $isLoopMode -eq 1 ]]; then
            printLoopBuildSummary "failed"
            saveLoopState
        fi
        exit 1
    fi

    local buildTime=$((buildEndTime - buildStartTime))
    fBuildTimeFormatted=$(formatElapsed $buildTime)

    # In loop mode, runLoopModels prints the per-model success line and summary,
    # so skip the per-build banner here to avoid duplicated time/messages.
    if [[ $isLoopMode -eq 0 ]]; then
        echo $SEPARATOR
        echo -e "$NOTATION Build completed successfully at $(getCurrentTime) in $fBuildTimeFormatted"

        local mlxFile=""
        [[ -n "$fBuildModel" ]] && mlxFile="${MODEL_MLX_FILE[$fBuildModel]}"
        if [[ -n "$mlxFile" && -f "$mlxFile" ]]; then
            local mlxSize
            mlxSize=$(du -h "$mlxFile" | cut -f1)
            echo -e "$NOTATION ${GREEN}✓ .mlx:${RESET} ${CYAN}$mlxFile${RESET} ${GREY}($mlxSize)${RESET}"
        fi
        echo $SEPARATOR
    fi
}

isModelSkipped() {
    local model="$1"
    for skip in "${fModelsSkip[@]}"; do
        [[ "$model" == "$skip" ]] && return 0
    done
    return 1
}

isModelInList() {
    local model="$1"
    for item in "${fModels[@]}"; do
        [[ "$model" == "$item" ]] && return 0
    done
    return 1
}

runLoopModels() {
    # Handle --scratch: delete saved state
    if [[ -n "$fScratch" ]]; then
        deleteLoopState
    fi

    # Only run if --models or --all is specified
    [[ ${#fModels[@]} -eq 0 ]] && return 1

    fLoopStartTime=$(date +%s)
    local isLoopMode=$([[ ${#fModels[@]} -gt 1 || ${#fModelsSkip[@]} -gt 0 ]] && echo 1 || echo 0)
    fModelsSkipped=()

    # Apply --skip filter to fModels (ignore skip models not in the list)
    if [[ ${#fModelsSkip[@]} -gt 0 ]]; then
        local filteredModels=()
        for model in "${fModels[@]}"; do
            if ! isModelSkipped "$model"; then
                filteredModels+=("$model")
            else
                fModelsSkipped+=("$model")
            fi
        done
        fModels=("${filteredModels[@]}")
    fi

    # Check if all models were skipped
    if [[ ${#fModels[@]} -eq 0 ]]; then
        echo -e "$NOTATION ${YELLOW}All models were skipped. Nothing to build.${RESET}"
        return 0
    fi

    # Total = previously verified (from resume) + models to build now
    local totalModels=$(( ${#fModelsVerified[@]} + ${#fModels[@]} ))
    echo "$SEPARATOR"

    for i in "${!fModels[@]}"; do
        local model="${fModels[$i]}"

        # Set current model and calculate pending models
        fModelsCurrent="$model"
        fModelsPending=("${fModels[@]:$((i+1))}")
        fBuildModel="$model"

        echo -e "$NOTATION ${BOLD}Current Building: ${GREEN}$(getModelDisplayName "$model")${RESET}"
        runBuildCommands  # exits on failure with summary

        # If we get here, build succeeded
        fModelsVerified+=("$model")

        if [[ $isLoopMode -eq 1 ]]; then
            # Frame the per-iteration summary with a leading separator (replaces
            # the leading === that the suppressed "Build completed..." banner used to provide).
            echo "$SEPARATOR"
            echo -e "$NOTATION ${GREEN}✓ $(getModelDisplayName "$model") built in ${fBuildTimeFormatted}${RESET}"
            if [[ ${#fModelsPending[@]} -gt 0 ]]; then
                local doneCount=${#fModelsVerified[@]}
                echo -e "$NOTATION Progress ${CYAN}[$doneCount/$totalModels]${RESET} next: ${YELLOW}$(getModelDisplayName "${fModelsPending[0]}")${RESET}"
                echo "$SEPARATOR"
            fi
            saveLoopState "progress"
        else
            local mlxFile="${MODEL_MLX_FILE[$model]}"
            echo -e "$NOTATION ${GREEN}✓ $(getModelDisplayName "$model") build succeeded${RESET}" \
                "$( [[ -n "$mlxFile" ]] && echo -e "${GREY}→${RESET} ${CYAN}$mlxFile${RESET}" )"
        fi
    done

    if [[ $isLoopMode -eq 1 ]]; then
        local stateFilePath="$fWorkingDir/$STATE_FILE"
        local stateNote
        if [[ ${#fModelsSkipped[@]} -eq 0 ]]; then
            stateNote="${LIGHTYELLOW}$stateFilePath${RESET} ${GREY}(cleared)${RESET}"
        else
            stateNote="${LIGHTYELLOW}$stateFilePath${RESET} ${GREY}(kept; skipped models will resume next run)${RESET}"
        fi
        printLoopBuildSummary "success" "$stateNote"
        [[ ${#fModelsSkipped[@]} -eq 0 ]] && deleteLoopState quiet
    else
        local totalTime=$(( $(date +%s) - fLoopStartTime ))
        local totalTimeFormatted=$(formatElapsed $totalTime)
        echo "$SEPARATOR"
        echo -e "$NOTATION ${BOLD}Build Summary:${RESET}"
        echo -e "$NOTATION Total time: ${CYAN}$totalTimeFormatted${RESET}"
        echo -e "$NOTATION ${GREEN}✓ Verified (${#fModelsVerified[@]}):${RESET} $(IFS=','; echo "${fModelsVerified[*]}")"
        echo "$SEPARATOR"
    fi
    return 0
}

# linkFile: Create or verify a symlink (same API as jc's linkFile, lightweight)
# $1=source_path $2=dest_dir $3=link_name (optional, defaults to basename of source)
linkFile() {
    local src="$1"
    local destDir="$2"
    local linkName="${3:-$(basename "$src")}"
    local dst="$destDir/$linkName"

    if [[ -L "$dst" && "$(readlink "$dst")" == "$src" ]]; then
        echo -e "$NOTATION ${GREEN}Link already exists:${RESET} $linkName -> $src"
        return 1
    elif [[ -f "$src" ]]; then
        mkdir -p "$destDir"
        ln -sf "$src" "$dst"
        echo -e "$NOTATION Created: ${GREEN}$linkName${RESET} -> ${BLUE}$src${RESET}"
        return 0
    else
        echo -e "$NOTATION ${RED}Warning: Source not found: $src${RESET}"
        return 2
    fi
}

linkWorkspaceFiles() {
    [ -z "$fGenerateCompileCmds" ] && [ -z "$fLinkWorkspace" ] && return
    # utopx has no per-model compile_db; CMake emits a single compile_commands.json
    # under cmakeBuild. Link the most recently generated one at the repo root for clangd.
    if [[ "$fRepoType" == "utopx" ]]; then
        cd "$fWorkingDir" || exit
        local utopxExpander="$SCRIPT_DIR/template/gen_clangd_compile_commands.py"
        if [[ -f "$utopxExpander" ]]; then
            echo -e "$NOTATION ${CYAN}Generating per-file clangd compile database (expanding Unity units)...${RESET}"
            python3 "$utopxExpander" --root "$fWorkingDir"
        else
            local utopxDb
            utopxDb=$(ls -t "$fWorkingDir"/cmakeBuild/ninja/*/*/*/*/ABI_0/*/compile_commands.json 2>/dev/null | head -1)
            if [[ -n "$utopxDb" && -f "$utopxDb" ]]; then
                echo -e "$NOTATION ${CYAN}Linking compile database for clangd...${RESET}"
                linkFile "$utopxDb" "$fWorkingDir" "$fCompileCommandsJson"
            else
                echo -e "$NOTATION ${GREY}Skipping compile database link (no compile_commands.json under cmakeBuild yet — build utopx first)${RESET}"
            fi
        fi
        return
    fi
    # Skip linking when in loop mode (multiple models)
    if [[ ${#fModels[@]} -gt 1 ]]; then
        echo -e "$NOTATION ${GREY}Skipping compile database link (loop mode with multiple models)${RESET}"
        return
    fi

    # Use first model from --models if specified, otherwise use fBuildModel (defaults to mustang)
    if [[ ${#fModels[@]} -gt 0 ]]; then
        fBuildModel="${fModels[0]}"
    fi

    cd "$fWorkingDir" || exit

    echo -e "$NOTATION ${CYAN}Linking compile database for clangd...${RESET}"
    linkFile "bin/build_tools/compile_db/compile_commands_${fBuildModel}_irisc.json" \
             "$fWorkingDir" "$fCompileCommandsJson"
    linkFile "$SCRIPT_DIR/assets/clangd/clangd" \
             "$fWorkingDir" ".clangd"
    linkFile "$SCRIPT_DIR/assets/claude/CLAUDE.md" \
             "$HOME/.claude" "$CLAUDE_MD"
}

removeWriteFromJson() {
    [ -z "$fNeedBuild" ] && return
    # Skip when in loop mode (multiple models)
    [[ ${#fModels[@]} -gt 1 ]] && return
    cd "$fWorkingDir" || exit

    # Operate on the actual target file, not the symlink
    local dbFile="bin/build_tools/compile_db/compile_commands_${fBuildModel}_irisc.json"
    if [[ -f "$dbFile" ]]; then
        if [[ -w "$dbFile" ]]; then
            echo -e "$NOTATION ${CYAN}Removing write privilege from ${YELLOW}$dbFile${RESET}"
            chmod u-w "$dbFile"
        else
            echo -e "$NOTATION ${GREY}$dbFile is already read-only${RESET}"
        fi
    fi
}

# Frame linkWorkspaceFiles + removeWriteFromJson as a single labeled
# block so their output isn't an unframed tail dangling after the
# Build Summary's closing === rule. The Build Summary above always
# closes with === (printLoopBuildSummary in loop mode, the else branch
# of runLoopModels in single-model mode, or runBuildCommands' own
# banner when called outside runLoopModels), so we only need to emit
# the header, run the children, and close with another === rule.
#
# Silent when nothing would print: both children early-return under
# various flags, and an empty "Post-build housekeeping:" header
# followed immediately by another === would be uglier than today.
# The pre-check replicates each child's own "will I print?" guard:
#   • linkWorkspaceFiles prints whenever (fGenerateCompileCmds OR
#     fLinkWorkspace) is set — either the real link work, or the
#     "Skipping..." line in multi-model loop mode.
#   • removeWriteFromJson prints when fNeedBuild is set, we're not in
#     multi-model loop mode, and the per-model compile-db file exists.
runPostBuildHousekeeping() {
    local _willPrint=
    if [ -n "$fGenerateCompileCmds" ] || [ -n "$fLinkWorkspace" ]; then
        _willPrint=1
    fi
    if [ -z "$_willPrint" ] && [ -n "$fNeedBuild" ] && [[ ${#fModels[@]} -le 1 ]]; then
        local _dbFile="$fWorkingDir/bin/build_tools/compile_db/compile_commands_${fBuildModel}_irisc.json"
        [ -f "$_dbFile" ] && _willPrint=1
    fi

    if [ -z "$_willPrint" ]; then
        linkWorkspaceFiles
        removeWriteFromJson
        return
    fi

    echo -e "$NOTATION ${BOLD}Post-build housekeeping:${RESET}"
    linkWorkspaceFiles
    removeWriteFromJson
    echo "$SEPARATOR"
}

# Deep clean using git clean -fdx; caller must cd to repo and call requireGitRepo first
runGitClean() {
    echo -e "$NOTATION ${CYAN}Deep cleaning with git clean -fdx...${RESET}"
    local excludeOpts="--exclude=*.code-workspace --exclude=$STATE_FILE --exclude=*.mlx --exclude=.mcp.json"
    if [ -z "$fRMCompileCommandsJson" ]; then
        if [ -L "$fCompileCommandsJson" ]; then
            local realFile
            realFile=$(readlink -f "$fCompileCommandsJson")
            excludeOpts="$excludeOpts --exclude=$(basename "$realFile")"
        else
            excludeOpts="$excludeOpts --exclude=$fCompileCommandsJson"
        fi
    fi
    local cleanCmd="git clean -fdx $excludeOpts"
    echo -e "$NOTATION Running: ${BLUE}$cleanCmd${RESET}"
    echo $SEPARATOR
    eval "$cleanCmd"
    echo -e "$NOTATION ${CYAN}Cleaning submodules...${RESET}"
    git submodule foreach --recursive git clean -fdx "$excludeOpts"
    echo -e "$NOTATION ${MAGENTA}Git deep clean completed.${RESET}"
}

# Print the first existing branch on origin from: master_rc, master, main.
# Returns 0 on success (branch name on stdout), 1 if none found.
resolveKeyBranch() {
    local candidate
    for candidate in master_rc master main; do
        if git ls-remote --heads --exit-code origin "$candidate" >/dev/null 2>&1; then
            echo "$candidate"
            return 0
        fi
    done
    return 1
}

runGitOptions() {
    [[ ${#fGitCmds[@]} -eq 0 && -z "$fGitClean" ]] && return 0
    fWorkingDir=$(realpath "$fWorkingDir")
    cd "$fWorkingDir" || exit 1
    requireGitRepo

    # Append git-clean to the cascade queue if requested
    [[ -n "$fGitClean" ]] && fGitCmds+=("git-clean")

    local gitCmdCount=${#fGitCmds[@]}
    local isCascade=$(( gitCmdCount > 1 ? 1 : 0 ))
    local gitStep=0

    # Execute git commands in the exact order specified on the command line
    for cmd in "${fGitCmds[@]}"; do
        ((gitStep++))
        [[ $isCascade -eq 1 ]] && echo -e "$NOTATION ${BOLD}[Git $gitStep/$gitCmdCount]${RESET}"
        case "$cmd" in
            fetch)
                local fetchBranch
                if fetchBranch=$(resolveKeyBranch); then
                    echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git fetch origin $fetchBranch${RESET}"
                    git fetch origin "$fetchBranch"
                else
                    echo -e "$NOTATION ${RED}No master_rc/master/main branch found on origin.${RESET}"
                fi
                # echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git fetch origin --tags${RESET}"
                # git fetch origin --tags
                ;;
            rebase)
                local rebaseBranch
                if ! rebaseBranch=$(resolveKeyBranch); then
                    echo -e "$NOTATION ${RED}No master_rc/master/main branch found on origin.${RESET}"
                    continue
                fi
                local stashed=0
                if ! git diff --quiet 2>/dev/null; then
                    echo -e "$NOTATION ${CYAN}Unstaged changes detected, stashing...${RESET}"
                    local stash_before
                    stash_before=$(git rev-parse --quiet --verify refs/stash 2>/dev/null || true)
                    git stash push -m "jmake-rebase-autostash"
                    local stash_after
                    stash_after=$(git rev-parse --quiet --verify refs/stash 2>/dev/null || true)
                    [[ -n "$stash_after" && "$stash_before" != "$stash_after" ]] && stashed=1
                fi
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git rebase origin/$rebaseBranch${RESET}"
                if git rebase "origin/$rebaseBranch"; then
                    if [[ $stashed -eq 1 ]]; then
                        echo -e "$NOTATION ${CYAN}Rebase succeeded, restoring stashed changes...${RESET}"
                        git stash pop
                    fi
                else
                    echo -e "$NOTATION ${RED}Rebase failed.${RESET}"
                    if [[ $stashed -eq 1 ]]; then
                        echo -e "$NOTATION ${YELLOW}Stashed changes preserved. Run 'git stash pop' after resolving conflicts.${RESET}"
                    fi
                fi
                ;;
            add)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git add -u && git reset HEAD -- $GIT_RESET_PATHS${RESET}"
                git add -u && git reset HEAD -- "$GIT_RESET_PATHS"
                ;;
            commit)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git commit --amend --no-edit${RESET}"
                git commit --amend --no-edit
                ;;
            amend)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git commit --amend${RESET}"
                git commit --amend
                ;;
            push)
                local pushBranch
                if pushBranch=$(resolveKeyBranch); then
                    echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git push origin HEAD:refs/for/$pushBranch${RESET}"
                    git push origin "HEAD:refs/for/$pushBranch"
                else
                    echo -e "$NOTATION ${RED}No master_rc/master/main branch found on origin.${RESET}"
                fi
                ;;
            stat)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git diff --stat${RESET}"
                git diff --stat
                ;;
            diff)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git diff include/ src/${RESET}"
                git diff include/ src/
                ;;
            show)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git show HEAD${RESET}"
                git show HEAD
                ;;
            git-clean)
                runGitClean
                ;;
            clean-submodule)
                echo -e "$NOTATION ${CYAN}Running: ${YELLOW}git submodule deinit --all -f${RESET}"
                git submodule deinit --all -f
                ;;
        esac
        if [[ $? -ne 0 ]]; then
            echo -e "$NOTATION ${RED}$cmd failed, aborting.${RESET}"
            exit 1
        fi
    done

    [[ $isCascade -eq 1 ]] && echo -e "$NOTATION ${GREEN}Congratulations! All $gitCmdCount git commands completed successfully.${RESET}"
    # If only git options were given (no build), exit after completing them
    [[ -z "$fNeedBuild"    &&
       -z "$fClean"        &&
       -z "$fLinkWorkspace" &&
       -z "$fBurn"         &&
       -z "$fBurnOfficial" &&
       -z "$fFwReset"      &&
       -z "$fMftInstall"   &&
       -z "$fMftStart"     &&
       -z "$fMftStop"      &&
       -z "$fMftRestart"   &&
       -z "$fOfedRestart"  &&
       -z "$fOfedStart"    &&
       -z "$fOfedStop"     &&
       -z "$fPowerCycle"   &&
       -z "$fPowerOn"      &&
       -z "$fPowerOff"     &&
       -z "$fDockerGroup"  ]] && exit 0
}

