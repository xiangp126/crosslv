# minfo/malloc/sqme/midle/scancelme are shell aliases/functions defined in
# this file, not standalone executables. Non-interactive bash does not expand
# aliases by default, so we must shopt + source before eval can resolve them.
FWV_ALIAS_FILE="/mswg/projects/fw/fw_ver/hca_fw_tools/.fwvalias"
# NOTE: .fwvalias is sourced inline from main() (see maybeSourceFwvAlias).
# We can't wrap that in a helper function: top-level `declare -A` in .fwvalias
# becomes LOCAL when source runs inside a function, so the project_full_names
# arrays vanish on return, leaving func_alias_reset to call fwresetfunc with
# `-d` as $1 (chip arg empty). Sourcing in main() scope keeps the arrays
# visible (via dynamic scoping) to every function called from main.

runRegInfo() {
    [[ -z "$fRegInfo" ]] && return
    echo "$SEPARATOR"
    echo -e "$NOTATION ${CYAN}Querying regression servers...${RESET}"
    local cmd="minfo"
    echo -e "$NOTATION Running: ${YELLOW}$cmd${RESET}"
    eval "$cmd"
    echo "$SEPARATOR"
