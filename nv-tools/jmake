# Run ipmi_command.sh and detect session/auth failures that it may print while
# still exiting 0 (e.g. "Error: Unable to establish IPMI v2 / RMCP+ session").
# Usage: runIpmiAction <server> <on|off|cycle|reset|status>
# Returns:
#   0  on success
#   2  on RMCP+/auth session failure (caller may choose a fallback path)
#   1  on any other failure
# Streams ipmi_command.sh output to the user.
runIpmiAction() {
    local server="$1"
    local action="$2"
    local output rc
    output=$(ipmi_command.sh "$server" "$action" 2>&1)
    rc=$?
    echo "$output" | sed 's/^/  /'
    if echo "$output" | grep -qiE 'Unable to establish IPMI|RMCP\+|RAKP|Authentication|Invalid password|Unauthorized'; then
        return 2
    fi
    if [[ $rc -ne 0 ]]; then
        return 1
    fi
    return 0
}

runPowerCycle() {
    [[ -z "$fPowerCycle" ]] && return
    local server="$fPowerCycle"
    local ipmiCmd="ipmi_command.sh"
    local sleepSec=20
    rejectSelfTarget "$server"
    requireIpmiCmd

    local cycleStartTime=$(date +%s)

    echo "$SEPARATOR"
    echo -e "$NOTATION ${BOLD}Power Cycling ${CYAN}$server${RESET}"
    echo "$SEPARATOR"

    echo -e "$NOTATION ${CYAN}Powering off...${RESET}"
    echo -e "$NOTATION Running: ${YELLOW}$ipmiCmd $server off${RESET}"
    runIpmiAction "$server" off
    local rc=$?
    if [[ $rc -eq 2 ]]; then
        # RMCP+/auth failure: skip the off/wait/on dance and power-cycle in-band via ssh.
        echo -e "$NOTATION ${YELLOW}ipmi_command.sh could not establish IPMI/RMCP+ session.${RESET}"
        echo -e "$NOTATION ${CYAN}Falling back to: ${YELLOW}ssh $server sudo ipmitool power cycle${RESET}"
        if ! ssh -o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null "$server" "sudo ipmitool power cycle"; then
            echo -e "$NOTATION ${RED}Error: ssh fallback (sudo ipmitool power cycle) failed${RESET}"
            exit 1
        fi
        local cycleEndTime=$(date +%s)
        echo -e "${GREEN}✓ Power cycle sent via ssh${RESET} at $(getCurrentTime) in $(formatElapsed $((cycleEndTime - cycleStartTime)))"
        echo "$SEPARATOR"
        return
    fi
    if [[ $rc -ne 0 ]]; then
        echo -e "$NOTATION ${RED}Error: IPMI power off failed${RESET}"
        exit 1
    fi
    echo -e "${GREEN}✓ Power off sent${RESET}"

    echo -e "$NOTATION ${CYAN}Waiting ${sleepSec}s for shutdown...${RESET}"
    sleep "$sleepSec"

    echo -e "$NOTATION ${CYAN}Powering on...${RESET}"
    echo -e "$NOTATION Running: ${YELLOW}$ipmiCmd $server on${RESET}"
    if ! runIpmiAction "$server" on; then
        echo -e "$NOTATION ${RED}Error: IPMI power on failed${RESET}"
        exit 1
    fi
    echo -e "$NOTATION ${CYAN}Pinging $server until it's back...${RESET}"
    ping "$server" | grep -m 1 "bytes from" &>/dev/null
    local cycleEndTime=$(date +%s)
    echo -e "${GREEN}✓ Power cycle completed for $server${RESET} at $(getCurrentTime) in $(formatElapsed $((cycleEndTime - cycleStartTime)))"
    echo "$SEPARATOR"
}

rejectSelfTarget() {
    local server="$1"
    local localHost
    localHost=$(hostname -s 2>/dev/null)
    if [[ "${server%%.*}" == "$localHost" ]]; then
        echo -e "$NOTATION ${RED}Error: Refusing to power-off/cycle the local machine (${YELLOW}$localHost${RED})${RESET}"
        exit 1
    fi
}

requireIpmiCmd() {
