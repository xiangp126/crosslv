# Wrappers for AI coding tools (claude, codex). Two responsibilities:
#
#   1. Ensure NVM-managed Node.js is on PATH before invocation. `jc
#      --claude` / `jc --codex` install via npm on both Linux and macOS,
#      so the nvm bin dir must be activated before the binary is reachable
#      in a fresh interactive shell. Done idempotently — once $NVM_BIN is
#      set, we skip the (slow) `nvm use` call.
#
#   2. Recognise auto-approve flags / env vars (see knobs below) and
#      launch a ja background daemon against the current tmux pane, so
#      permission prompts get auto-confirmed for the lifetime of the
#      daemon. The wrapper persists across invocations (no unset -f) —
#      otherwise we'd lose the ability to parse --auto-approve on the
#      second call. ja persists across claude restarts by default, so
#      subsequent plain `claude` invocations get auto-approve "for free"
#      via ja's ▶ Resumed mechanism.
#
# User-facing knobs (per AI; replace <TOOL> with CLAUDE or CODEX):
#
#   --auto-approve  /  -y          Per-invocation flag. Stripped from
#                                  $@ before claude is exec'd, so the
#                                  real binary never sees it. Triggers
#                                  ja daemon launch for THIS invocation.
#                                  Subsequent invocations don't need it
#                                  again — once ja is up in daemon mode
#                                  it keeps approving across restarts.
#
#   <TOOL>_AUTO_APPROVE=1          Env-var equivalent of the flag above.
#                                  Set once in your shell (or export from
#                                  ~/.bashrc.local etc.) to make every
#                                  invocation auto-approve without typing
#                                  -y each time. Only the matching tool's
#                                  variable applies — CLAUDE_AUTO_APPROVE=1
#                                  has no effect on `codex`, and vice versa.
#
#   Examples:
#     claude -y                    one-shot auto-approve
#     CLAUDE_AUTO_APPROVE=1 claude  one-shot via env-var (same effect)
#     export CLAUDE_AUTO_APPROVE=1  persistent default in this shell
#     export CODEX_AUTO_APPROVE=1   same for codex
#     unset CLAUDE_AUTO_APPROVE     turn off the persistent default
#
# Stop the daemon at any time with: ja --stop  (or ja --stop -t <pane>).
#
# Helper: start a ja background daemon for the current tmux pane. Two
# guards, then delegate to ja:
#   1. inside tmux (ja can't monitor without a pane to watch)
#   2. ja is on PATH
# Everything else — detaching (setsid), the log file under ~/.local/ja,
# single-instance dedup, and the user-facing status line — is handled by
# `ja --daemon` itself (it self-daemonizes and keys all its runtime files
# by the pane_id). The wrapper just resolves the current pane_id and hands
# off, so there's a single source of truth for ja's runtime layout.
_ai_start_ja_if_needed() {
    local ai="$1"            # "claude" or "codex"
    # ANSI escapes for the fallback messages — match the palette ja uses.
    local _C_RED=$'\033[31m' _C_CYAN=$'\033[36m' _C_GREY=$'\033[90m' _C_RESET=$'\033[0m'

    if [[ -z "$TMUX" ]]; then
        printf '%s%s:%s --auto-approve requires running inside tmux. %sFalling back.%s\n' \
            "$_C_RED" "$ai" "$_C_RESET" "$_C_GREY" "$_C_RESET" >&2
        return 0
    fi
    if ! command -v ja &>/dev/null; then
        printf '%s%s:%s --auto-approve needs %s'\''ja'\''%s on PATH. %sFalling back.%s\n' \
            "$_C_RED" "$ai" "$_C_RESET" "$_C_CYAN" "$_C_RESET" "$_C_GREY" "$_C_RESET" >&2
        return 0
    fi
    local paneid
    paneid=$(tmux display-message -p '#{pane_id}' 2>/dev/null)
    if [[ -z "$paneid" ]]; then
        printf '%s%s:%s --auto-approve could not resolve current tmux pane. %sFalling back.%s\n' \
            "$_C_RED" "$ai" "$_C_RESET" "$_C_GREY" "$_C_RESET" >&2
        return 0
    fi
    # Delegate everything to ja. `--daemon` makes ja self-detach (new
    # session via setsid, its own log file under ~/.local/ja keyed by the
    # pane_id), dedup against an already-running daemon for this pane, and
    # print its own "daemon started / already running" status line — so the
    # wrapper no longer mirrors ja's path rule, redirects logs, or races on
    # the lockfile. Persistence across AI restarts is ja's default, so no
    # extra flag is needed. Binding by pane_id (not the M:7.1 index) means
    # the daemon follows the pane if it is later moved/relinked.
    #
    # We intentionally do NOT pass --$ai as an AI filter: -y means
    # "auto-approve", not "only approve <this AI>", so the daemon keeps
    # working if the pane later switches claude<->codex. Users who want a
    # strict filter can launch ja manually: ja -D --claude.
    ja --daemon -t "$paneid"
}

# Decide whether an AI invocation will open the interactive TUI (the only
# place approval prompts appear) and therefore warrants a ja auto-approver.
# Returns 1 (skip ja) for:
#   * help / version flags          — claude -h, --help, --version, -V
#   * headless print mode           — -p / --print (runs non-interactively)
#   * non-interactive subcommands   — mcp, doctor, update, install, config,
#                                     migrate-installer, setup-token,
#                                     completion (claude) and exec, login,
#                                     logout, apply (codex)
# Returns 0 (start ja) otherwise: bare REPL, a one-shot prompt, --continue,
# --resume, etc. Arg-only — no tmux/env side effects (that's _ai_start_ja).
_ai_wants_ja() {
    local _a
    for _a in "$@"; do
        case "$_a" in
            -h|--help|--version|-V|-p|--print) return 1 ;;
        esac
    done
    case "${1:-}" in
        mcp|doctor|update|install|migrate-installer|config|setup-token|completion|exec|login|logout|apply)
            return 1 ;;
    esac
    return 0
}

# Per-AI wrapper. Runs every invocation (no unset -f) — overhead is one
# nvm gate check + one $@ scan, both negligible.
#
# The eval interpolates the AI name twice:
#   * `$_ai_cmd` (no escape)   — expanded NOW, baked into the function
#   * `\"\$@\"` etc. (escaped) — expanded at CALL time inside the function
# So $_AI_NAME below is the string "CLAUDE" or "CODEX" baked in at
# definition time, and \${!_envname} is dereferenced at call time.
_ai_nvm_tools=(codex claude)
for _ai_cmd in "${_ai_nvm_tools[@]}"; do
    _AI_NAME_UC="${_ai_cmd^^}"   # CLAUDE / CODEX (bash 4+)
    # Baked-in per-invocation defaults. Both tools auto-approve (-y) by
    # default; only claude also defaults to --verbose (codex has no such
    # flag). Expanded NOW (unescaped), so each function gets its own literal.
    _AI_DEFAULTS='-y'
    [[ "$_ai_cmd" == claude ]] && _AI_DEFAULTS='-y --verbose'
    eval "$_ai_cmd() {
        # Prepend the baked defaults, then let the loop below normalise them.
        set -- $_AI_DEFAULTS \"\$@\"
        # Strip --auto-approve / -y from \$@; record whether it appeared.
        # Also honor ${_AI_NAME_UC}_AUTO_APPROVE=1 env var as a persistent default.
        # --verbose is collapsed to a single flag (default + explicit don't stack).
        local _auto=0 _verbose=0 _args=() _arg
        [[ \"\$${_AI_NAME_UC}_AUTO_APPROVE\" == 1 ]] && _auto=1
        for _arg in \"\$@\"; do
            case \"\$_arg\" in
                --auto-approve|-y) _auto=1 ;;
                --verbose) _verbose=1 ;;
                *) _args+=(\"\$_arg\") ;;
            esac
        done
        (( _verbose )) && _args+=(--verbose)

        # NVM activation. Idempotent — skip if the AI's binary is already
        # findable. If not, source nvm.sh directly (rather than calling the
        # lazy 'nvm' stub, which can silently misbehave under exec bash /
        # subshells where NVM_BIN was unset). nvm use default then puts
        # the right node version's bin on PATH.
        if [[ -z \"\$(type -P $_ai_cmd)\" ]]; then
            [ -s \"\$NVM_DIR/nvm.sh\" ] && source \"\$NVM_DIR/nvm.sh\" >/dev/null
            # --silent skips nvm_print_npm_version, which can hang on \`npm --version\`
            nvm use default --silent >/dev/null 2>&1
        fi
        # Refresh Cursor/VS Code IPC socket so that Claude Code's IDE
        # extension shows \"Connected\" inside tmux. Linux-only — on macOS
        # the standalone 'code' binary doesn't recognise -p and the call
        # is just dead overhead (warning swallowed by &>/dev/null).
        # [[ \"\$_UNAME_S\" == 'Linux' ]] && [[ -n \"\$TMUX\" ]] && \\
        #     [[ -d \"\$HOME/.vscode-server/cli/servers\" || -d \"\$HOME/.cursor-server/bin\" ]] && \\
        #     code -p &>/dev/null

        # Only start ja for invocations that actually open the interactive
        # TUI. Help/version, headless print mode and subcommands like mcp or
        # doctor never show approval prompts, so a daemon for them is waste.
        if (( _auto )) && _ai_wants_ja \"\${_args[@]}\"; then
            _ai_start_ja_if_needed $_ai_cmd
        fi

        command $_ai_cmd \"\${_args[@]}\"
    }"
done
unset _ai_cmd _AI_NAME_UC _AI_DEFAULTS

